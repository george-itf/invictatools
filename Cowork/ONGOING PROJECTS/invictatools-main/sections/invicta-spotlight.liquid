{% comment %}
  ============================================
  INVICTA SPOTLIGHT v1.0 — Asymmetric editorial grid
  ============================================
  Replaces promo banners with a 3-card layout:
  - Primary card (tall, dark bg, left column)
  - Two secondary cards (white bg, right column)

  Trade 15.4.0 Compatible
  ============================================
{% endcomment %}

<style>
  /* ============================================
     INVICTA SPOTLIGHT v1.0
     ============================================ */

  #spotlight-{{ section.id }} {
    background: {{ section.settings.section_bg | default: '#f5f5f6' }};
    padding-top: {{ section.settings.padding_top | default: 40 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 40 }}px;
  }

  #spotlight-{{ section.id }} .inv-spotlight__container {
    max-width: var(--inv-container, 1400px);
    margin: 0 auto;
    padding: 0 var(--inv-page-gutter, 1.5rem);
  }

  #spotlight-{{ section.id }} .inv-spotlight__grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 16px;
  }

  /* --- Cards base --- */
  #spotlight-{{ section.id }} .inv-spotlight__card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  #spotlight-{{ section.id }} .inv-spotlight__card:hover {
    transform: translateY(-2px);
    box-shadow: var(--inv-shadow-md, 0 4px 12px rgba(0,0,0,0.1));
  }

  #spotlight-{{ section.id }} .inv-spotlight__card:focus-visible {
    outline: 2px solid var(--inv-accent);
    outline-offset: 2px;
  }

  /* --- Primary card --- */
  #spotlight-{{ section.id }} .inv-spotlight__card--primary {
    grid-row: 1 / 3;
    background: var(--inv-dark, #1a1a1a);
    border: none;
  }

  /* --- Secondary cards --- */
  #spotlight-{{ section.id }} .inv-spotlight__card--secondary {
    background: var(--inv-bg-elevated);
    border: 1px solid var(--inv-border, #e5e7eb);
  }

  /* --- Card images --- */
  #spotlight-{{ section.id }} .inv-spotlight__card-image {
    width: 100%;
    overflow: hidden;
  }

  #spotlight-{{ section.id }} .inv-spotlight__card--secondary .inv-spotlight__card-image {
    aspect-ratio: 16 / 10;
  }

  #spotlight-{{ section.id }} .inv-spotlight__card--primary .inv-spotlight__card-image {
    aspect-ratio: auto;
    flex: 1;
    min-height: 240px;
  }

  #spotlight-{{ section.id }} .inv-spotlight__card-image--empty {
    background: var(--inv-bg-soft, #f3f4f6);
  }

  #spotlight-{{ section.id }} .inv-spotlight__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* --- Card body --- */
  #spotlight-{{ section.id }} .inv-spotlight__card-body {
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  /* --- Tag badges --- */
  #spotlight-{{ section.id }} .inv-spotlight__tag {
    display: inline-flex;
    align-self: flex-start;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 4px 10px;
    line-height: 1.3;
  }

  #spotlight-{{ section.id }} .inv-spotlight__tag--new {
    background: var(--inv-accent);
    color: #fff;
  }

  #spotlight-{{ section.id }} .inv-spotlight__tag--deal {
    background: var(--inv-success);
    color: #fff;
  }

  #spotlight-{{ section.id }} .inv-spotlight__tag--featured {
    background: var(--inv-dark, #1a1a1a);
    color: #fff;
  }

  /* --- Titles --- */
  #spotlight-{{ section.id }} .inv-spotlight__title {
    font-family: var(--inv-font-display);
    text-transform: uppercase;
    font-weight: 800;
    line-height: 1.15;
    margin: 0;
  }

  #spotlight-{{ section.id }} .inv-spotlight__card--primary .inv-spotlight__title {
    font-size: 28px;
    color: #fff;
  }

  #spotlight-{{ section.id }} .inv-spotlight__card--secondary .inv-spotlight__title {
    font-size: 22px;
    color: var(--inv-fg);
  }

  /* --- Subtitle (primary only) --- */
  #spotlight-{{ section.id }} .inv-spotlight__subtitle {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.4;
    margin: 0;
  }

  /* --- CTA links --- */
  #spotlight-{{ section.id }} .inv-spotlight__cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: #fff;
    margin-top: auto;
    transition: gap 0.15s ease;
  }

  #spotlight-{{ section.id }} .inv-spotlight__cta--dark {
    color: var(--inv-accent);
  }

  #spotlight-{{ section.id }} .inv-spotlight__card:hover .inv-spotlight__cta {
    gap: 10px;
  }

  #spotlight-{{ section.id }} .inv-spotlight__cta svg {
    width: 14px;
    height: 14px;
  }

  /* --- Price --- */
  #spotlight-{{ section.id }} .inv-spotlight__price {
    display: flex;
    align-items: baseline;
    gap: 8px;
    flex-wrap: wrap;
  }

  #spotlight-{{ section.id }} .inv-spotlight__price-current {
    font-size: 22px;
    font-weight: 800;
    color: var(--inv-fg);
    line-height: 1.1;
  }

  #spotlight-{{ section.id }} .inv-spotlight__price-current--sale {
    color: var(--inv-accent);
  }

  #spotlight-{{ section.id }} .inv-spotlight__price-was {
    text-decoration: line-through;
    color: var(--inv-fg-subtle);
    font-size: 13px;
  }

  #spotlight-{{ section.id }} .inv-spotlight__price-vat {
    font-size: 11px;
    color: var(--inv-fg-muted);
  }

  /* ----------------------------------------
     MOBILE (< 990px): single column
     ---------------------------------------- */
  @media (max-width: 989px) {
    #spotlight-{{ section.id }} .inv-spotlight__grid {
      grid-template-columns: 1fr;
    }

    #spotlight-{{ section.id }} .inv-spotlight__card--primary {
      grid-row: auto;
    }
  }

  /* ----------------------------------------
     MOBILE (< 750px): tighter gap
     ---------------------------------------- */
  @media (max-width: 749px) {
    #spotlight-{{ section.id }} .inv-spotlight__grid {
      gap: 12px;
    }

    #spotlight-{{ section.id }} .inv-spotlight__card--primary .inv-spotlight__title {
      font-size: 24px;
    }

    #spotlight-{{ section.id }} .inv-spotlight__card--secondary .inv-spotlight__title {
      font-size: 18px;
    }
  }

  /* ----------------------------------------
     REDUCED MOTION
     ---------------------------------------- */
  @media (prefers-reduced-motion: reduce) {
    #spotlight-{{ section.id }} .inv-spotlight__card {
      transition: none;
    }
    #spotlight-{{ section.id }} .inv-spotlight__card:hover {
      transform: none;
    }
    #spotlight-{{ section.id }} .inv-spotlight__cta {
      transition: none;
    }
  }
</style>

<section class="inv-spotlight" id="spotlight-{{ section.id }}">
  <div class="inv-spotlight__container">
    <div class="inv-spotlight__grid">

      {%- comment -%} PRIMARY CARD {%- endcomment -%}
      <a href="{{ section.settings.primary_link | default: '#' }}"
         class="inv-spotlight__card inv-spotlight__card--primary"
         aria-label="{{ section.settings.primary_title | escape }}">

        {%- if section.settings.primary_image != blank -%}
          <div class="inv-spotlight__card-image">
            <img
              src="{{ section.settings.primary_image | image_url: width: 800 }}"
              srcset="{{ section.settings.primary_image | image_url: width: 400 }} 400w,
                      {{ section.settings.primary_image | image_url: width: 600 }} 600w,
                      {{ section.settings.primary_image | image_url: width: 800 }} 800w"
              sizes="(max-width: 989px) 100vw, 33vw"
              alt="{{ section.settings.primary_image.alt | escape }}"
              loading="lazy"
              width="{{ section.settings.primary_image.width }}"
              height="{{ section.settings.primary_image.height }}"
              class="inv-spotlight__img"
            >
          </div>
        {%- else -%}
          <div class="inv-spotlight__card-image inv-spotlight__card-image--empty"></div>
        {%- endif -%}

        <div class="inv-spotlight__card-body">
          {%- if section.settings.primary_tag != blank -%}
            <span class="inv-spotlight__tag inv-spotlight__tag--{{ section.settings.primary_tag_style | default: 'new' }}">
              {{ section.settings.primary_tag }}
            </span>
          {%- endif -%}

          {%- if section.settings.primary_title != blank -%}
            <h3 class="inv-spotlight__title">{{ section.settings.primary_title }}</h3>
          {%- endif -%}

          {%- if section.settings.primary_subtitle != blank -%}
            <p class="inv-spotlight__subtitle">{{ section.settings.primary_subtitle }}</p>
          {%- endif -%}

          <span class="inv-spotlight__cta">
            {{ section.settings.primary_cta | default: 'Shop Now' }}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </div>
      </a>

      {%- comment -%} SECONDARY CARD 1 {%- endcomment -%}
      <a href="{{ section.settings.card2_link | default: '#' }}"
         class="inv-spotlight__card inv-spotlight__card--secondary"
         aria-label="{{ section.settings.card2_title | escape }}">

        {%- if section.settings.card2_image != blank -%}
          <div class="inv-spotlight__card-image">
            <img
              src="{{ section.settings.card2_image | image_url: width: 600 }}"
              srcset="{{ section.settings.card2_image | image_url: width: 300 }} 300w,
                      {{ section.settings.card2_image | image_url: width: 450 }} 450w,
                      {{ section.settings.card2_image | image_url: width: 600 }} 600w"
              sizes="(max-width: 989px) 100vw, 33vw"
              alt="{{ section.settings.card2_image.alt | escape }}"
              loading="lazy"
              width="{{ section.settings.card2_image.width }}"
              height="{{ section.settings.card2_image.height }}"
              class="inv-spotlight__img"
            >
          </div>
        {%- else -%}
          <div class="inv-spotlight__card-image inv-spotlight__card-image--empty"></div>
        {%- endif -%}

        <div class="inv-spotlight__card-body">
          {%- if section.settings.card2_tag != blank -%}
            <span class="inv-spotlight__tag inv-spotlight__tag--{{ section.settings.card2_tag_style | default: 'featured' }}">
              {{ section.settings.card2_tag }}
            </span>
          {%- endif -%}
          {%- if section.settings.card2_title != blank -%}
            <h3 class="inv-spotlight__title">{{ section.settings.card2_title }}</h3>
          {%- endif -%}
          {%- if section.settings.card2_price != blank -%}
            <div class="inv-spotlight__price">
              <span class="inv-spotlight__price-current">{{ section.settings.card2_price }}</span>
              {%- if section.settings.card2_was_price != blank -%}
                <span class="inv-spotlight__price-was">{{ section.settings.card2_was_price }}</span>
              {%- endif -%}
              {%- if section.settings.card2_price_sub != blank -%}
                <span class="inv-spotlight__price-vat">{{ section.settings.card2_price_sub }}</span>
              {%- endif -%}
            </div>
          {%- endif -%}
          <span class="inv-spotlight__cta inv-spotlight__cta--dark">
            {{ section.settings.card2_cta | default: 'View Product' }}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </div>
      </a>

      {%- comment -%} SECONDARY CARD 2 {%- endcomment -%}
      <a href="{{ section.settings.card3_link | default: '#' }}"
         class="inv-spotlight__card inv-spotlight__card--secondary"
         aria-label="{{ section.settings.card3_title | escape }}">

        {%- if section.settings.card3_image != blank -%}
          <div class="inv-spotlight__card-image">
            <img
              src="{{ section.settings.card3_image | image_url: width: 600 }}"
              srcset="{{ section.settings.card3_image | image_url: width: 300 }} 300w,
                      {{ section.settings.card3_image | image_url: width: 450 }} 450w,
                      {{ section.settings.card3_image | image_url: width: 600 }} 600w"
              sizes="(max-width: 989px) 100vw, 33vw"
              alt="{{ section.settings.card3_image.alt | escape }}"
              loading="lazy"
              width="{{ section.settings.card3_image.width }}"
              height="{{ section.settings.card3_image.height }}"
              class="inv-spotlight__img"
            >
          </div>
        {%- else -%}
          <div class="inv-spotlight__card-image inv-spotlight__card-image--empty"></div>
        {%- endif -%}

        <div class="inv-spotlight__card-body">
          {%- if section.settings.card3_tag != blank -%}
            <span class="inv-spotlight__tag inv-spotlight__tag--{{ section.settings.card3_tag_style | default: 'deal' }}">
              {{ section.settings.card3_tag }}
            </span>
          {%- endif -%}
          {%- if section.settings.card3_title != blank -%}
            <h3 class="inv-spotlight__title">{{ section.settings.card3_title }}</h3>
          {%- endif -%}
          {%- if section.settings.card3_price != blank -%}
            <div class="inv-spotlight__price">
              <span class="inv-spotlight__price-current inv-spotlight__price-current--sale">{{ section.settings.card3_price }}</span>
              {%- if section.settings.card3_was_price != blank -%}
                <span class="inv-spotlight__price-was">{{ section.settings.card3_was_price }}</span>
              {%- endif -%}
              {%- if section.settings.card3_price_sub != blank -%}
                <span class="inv-spotlight__price-vat">{{ section.settings.card3_price_sub }}</span>
              {%- endif -%}
            </div>
          {%- endif -%}
          <span class="inv-spotlight__cta inv-spotlight__cta--dark">
            {{ section.settings.card3_cta | default: 'View Product' }}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </div>
      </a>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Invicta Spotlight",
  "settings": [
    { "type": "header", "content": "Primary Card (Left)" },
    { "type": "image_picker", "id": "primary_image", "label": "Image" },
    { "type": "url", "id": "primary_link", "label": "Link" },
    { "type": "text", "id": "primary_tag", "label": "Tag badge", "default": "New Range" },
    { "type": "select", "id": "primary_tag_style", "label": "Tag style", "default": "new",
      "options": [
        { "value": "new", "label": "Red (New)" },
        { "value": "deal", "label": "Green (Deal)" },
        { "value": "featured", "label": "Dark (Featured)" }
      ]
    },
    { "type": "text", "id": "primary_title", "label": "Title", "default": "Viper Fuel Cell Nails" },
    { "type": "text", "id": "primary_subtitle", "label": "Subtitle", "default": "Premium gas nailer consumables. Full range in stock." },
    { "type": "text", "id": "primary_cta", "label": "CTA text", "default": "Shop Now" },
    { "type": "header", "content": "Card 2 (Top Right)" },
    { "type": "image_picker", "id": "card2_image", "label": "Image" },
    { "type": "url", "id": "card2_link", "label": "Link" },
    { "type": "text", "id": "card2_tag", "label": "Tag badge", "default": "Just Landed" },
    { "type": "select", "id": "card2_tag_style", "label": "Tag style", "default": "featured",
      "options": [
        { "value": "new", "label": "Red (New)" },
        { "value": "deal", "label": "Green (Deal)" },
        { "value": "featured", "label": "Dark (Featured)" }
      ]
    },
    { "type": "text", "id": "card2_title", "label": "Title", "default": "Makita RM350D Robotic Mower" },
    { "type": "text", "id": "card2_price", "label": "Price", "info": "Leave blank to hide" },
    { "type": "text", "id": "card2_was_price", "label": "Was price", "info": "Shows strikethrough" },
    { "type": "text", "id": "card2_price_sub", "label": "Price subtext", "info": "e.g. (£1,915.83 ex)" },
    { "type": "text", "id": "card2_cta", "label": "CTA text", "default": "View Product" },
    { "type": "header", "content": "Card 3 (Bottom Right)" },
    { "type": "image_picker", "id": "card3_image", "label": "Image" },
    { "type": "url", "id": "card3_link", "label": "Link" },
    { "type": "text", "id": "card3_tag", "label": "Tag badge", "default": "Spring Deal" },
    { "type": "select", "id": "card3_tag_style", "label": "Tag style", "default": "deal",
      "options": [
        { "value": "new", "label": "Red (New)" },
        { "value": "deal", "label": "Green (Deal)" },
        { "value": "featured", "label": "Dark (Featured)" }
      ]
    },
    { "type": "text", "id": "card3_title", "label": "Title", "default": "DeWalt DW088K Cross Line Laser" },
    { "type": "text", "id": "card3_price", "label": "Price" },
    { "type": "text", "id": "card3_was_price", "label": "Was price" },
    { "type": "text", "id": "card3_price_sub", "label": "Price subtext" },
    { "type": "text", "id": "card3_cta", "label": "CTA text", "default": "View Product" },
    { "type": "header", "content": "Section" },
    { "type": "color", "id": "section_bg", "label": "Background colour", "default": "#f5f5f6" },
    { "type": "range", "id": "padding_top", "label": "Top padding", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 40 }
  ],
  "presets": [{ "name": "Invicta Spotlight" }]
}
{% endschema %}
