{% comment %}
  ============================================================================
  INVICTA HERO v3.3.1 — Full-bleed dark hero with text + image
  ============================================================================
  Two-column hero. Two display modes:
  - "promotion" (default): product-led promotional hero with price callout
  - "brand": editorial brand statement hero with ghost secondary CTA

  Updates in v3.3:
  - hero_mode select setting (promotion | brand)
  - Brand mode: red rule before eyebrow, --inv-text-3xl heading,
    ghost secondary CTA, image left-edge gradient fade, no price callout

  Trade 15.4.0 Compatible
  Usage: Add via theme editor or templates/index.json
  ============================================================================
{% endcomment %}

{%- liquid
  assign hero_mode = section.settings.hero_mode | default: 'promotion'
  assign show_price = false
  if hero_mode == 'promotion' and section.settings.price_text != blank
    assign show_price = true
  endif
-%}

{%- if section.settings.hero_image != blank -%}
  {%- comment -%}
    LCP image preload. Mobile preload omitted on purpose: the visual column
    is hidden on <990px so loading the image early on those viewports wastes
    bandwidth and delays the real LCP element (the heading text).
  {%- endcomment -%}
  <link rel="preload" as="image"
    imagesrcset="{{ section.settings.hero_image | image_url: width: 500, format: 'webp' }} 500w,
                 {{ section.settings.hero_image | image_url: width: 680, format: 'webp' }} 680w"
    imagesizes="(max-width: 989px) 0px, 380px"
    media="(min-width: 990px)"
    fetchpriority="high">
{%- endif -%}

<section
  class="inv-hero-v3 inv-hero-v3--{{ hero_mode }}"
  id="hero-v3-{{ section.id }}"
  aria-label="{{ section.settings.heading | escape }}"
>
  <div class="inv-hero-v3__container{% if section.settings.hero_image == blank %} inv-hero-v3__container--full{% endif %}">
    {%- comment -%} LEFT COLUMN: Text content {%- endcomment -%}
    <div class="inv-hero-v3__content">
      {%- if section.settings.eyebrow_text != blank -%}
        <span class="inv-hero-v3__eyebrow">{{ section.settings.eyebrow_text }}</span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="inv-hero-v3__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <p class="inv-hero-v3__desc">{{ section.settings.description }}</p>
      {%- endif -%}

      <div class="inv-hero-v3__ctas">
        {%- if section.settings.button_text != blank -%}
          <a
            href="{{ section.settings.button_link | default: '#' }}"
            class="inv-hero-v3__btn inv-hero-v3__btn--primary"
          >
            {{ section.settings.button_text }}
          </a>
        {%- endif -%}

        {%- if section.settings.secondary_text != blank -%}
          <a
            href="{{ section.settings.secondary_link | default: '#' }}"
            class="inv-hero-v3__btn inv-hero-v3__btn--secondary"
          >
            {{ section.settings.secondary_text }}
          </a>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} RIGHT COLUMN: image (clean for promotion, faded for brand) {%- endcomment -%}
    {%- if section.settings.hero_image != blank -%}
      <div class="inv-hero-v3__visual">
        <img
          src="{{ section.settings.hero_image | image_url: width: 680, format: 'webp' }}"
          srcset="{{ section.settings.hero_image | image_url: width: 500, format: 'webp' }} 500w,
                  {{ section.settings.hero_image | image_url: width: 680, format: 'webp' }} 680w"
          sizes="380px"
          alt="{{ section.settings.heading | escape }}"
          width="{{ section.settings.hero_image.width }}"
          height="{{ section.settings.hero_image.height }}"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          class="inv-hero-v3__image"
        >
        {%- if show_price -%}
          <div class="inv-hero-v3__price-tag">
            <div class="inv-hero-v3__price-label">{{ section.settings.price_label | default: 'From' }}</div>
            <div class="inv-hero-v3__price-value">{{ section.settings.price_text }}</div>
            {%- if section.settings.price_subtext != blank -%}
              <div class="inv-hero-v3__price-sub">{{ section.settings.price_subtext }}</div>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  /* ============================================================================
     INVICTA HERO v3.3 — Full-bleed dark hero
     Subtle background texture via pseudo-elements
     ============================================================================ */

  #hero-v3-{{ section.id }} {
    background: {{ section.settings.background_color | default: '#2d2d2d' }};
    padding-top: {{ section.settings.padding_top | default: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 0 }}px;
    position: relative;
    overflow: hidden;
  }

  #hero-v3-{{ section.id }}::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 20% 80%, rgba(225,29,38,0.06) 0%, transparent 50%),
      radial-gradient(circle at 80% 20%, rgba(255,255,255,0.03) 0%, transparent 40%);
    pointer-events: none;
  }

  #hero-v3-{{ section.id }}::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--inv-accent);
    z-index: 1;
  }

  #hero-v3-{{ section.id }} .inv-hero-v3__container {
    max-width: var(--inv-container, 1400px);
    margin: 0 auto;
    padding: 0 var(--inv-page-gutter, 1.5rem);
    display: grid;
    grid-template-columns: 1fr;
    /* CLS fix: reserve hero height across all viewports. Mobile uses a
       smaller min-height because the right-column image is hidden there. */
    min-height: 320px;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  @media (min-width: 990px) {
    #hero-v3-{{ section.id }} .inv-hero-v3__container {
      min-height: 380px;
    }
  }

  /* When no image: content takes full width */
  #hero-v3-{{ section.id }} .inv-hero-v3__container--full .inv-hero-v3__content {
    grid-column: 1 / -1;
  }

  /* --- Left column: content --- */
  #hero-v3-{{ section.id }} .inv-hero-v3__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--inv-space-xl) 0;
  }

  /* Eyebrow tag (promotion mode default) */
  #hero-v3-{{ section.id }} .inv-hero-v3__eyebrow {
    display: inline-flex;
    align-self: flex-start;
    background: var(--inv-accent);
    color: var(--inv-bg-elevated);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 5px 14px;
    margin-bottom: var(--inv-space-md);
    line-height: 1.3;
  }

  /* Heading */
  #hero-v3-{{ section.id }} .inv-hero-v3__heading {
    font-family: var(--inv-font-display);
    font-size: 28px;
    font-weight: 900;
    text-transform: uppercase;
    color: var(--inv-bg-elevated);
    line-height: 1.05;
    letter-spacing: -0.5px;
    margin: 0 0 var(--inv-space-md) 0;
  }

  /* Description */
  #hero-v3-{{ section.id }} .inv-hero-v3__desc {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.55;
    max-width: 400px;
    margin: 0 0 var(--inv-space-lg) 0;
  }

  /* CTA container */
  #hero-v3-{{ section.id }} .inv-hero-v3__ctas {
    display: flex;
    flex-direction: column;
    gap: var(--inv-space-sm);
    align-items: flex-start;
  }

  /* CTA buttons base */
  #hero-v3-{{ section.id }} .inv-hero-v3__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    text-decoration: none;
    height: 48px;
    padding: 0 28px;
    transition: background var(--inv-duration-normal) ease,
                border-color var(--inv-duration-normal) ease;
  }

  #hero-v3-{{ section.id }} .inv-hero-v3__btn:focus-visible {
    outline: 2px solid var(--inv-accent);
    outline-offset: 2px;
  }

  /* Primary CTA */
  #hero-v3-{{ section.id }} .inv-hero-v3__btn--primary {
    background: var(--inv-accent);
    color: var(--inv-bg-elevated);
    border: none;
  }

  #hero-v3-{{ section.id }} .inv-hero-v3__btn--primary:hover {
    background: var(--inv-accent-hover);
  }

  /* Secondary CTA (promotion default) */
  #hero-v3-{{ section.id }} .inv-hero-v3__btn--secondary {
    background: transparent;
    color: var(--inv-bg-elevated);
    border: 1.5px solid rgba(255, 255, 255, 0.3);
  }

  #hero-v3-{{ section.id }} .inv-hero-v3__btn--secondary:hover {
    border-color: var(--inv-bg-elevated);
  }

  /* --- Right column: visual --- */
  #hero-v3-{{ section.id }} .inv-hero-v3__visual {
    display: none;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  #hero-v3-{{ section.id }} .inv-hero-v3__image {
    max-width: 380px;
    max-height: 380px;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  /* --- Price callout --- */
  #hero-v3-{{ section.id }} .inv-hero-v3__price-tag {
    position: absolute;
    bottom: 20px;
    right: -10px;
    background: var(--inv-bg-elevated);
    padding: 10px 16px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.2);
    z-index: 2;
  }

  #hero-v3-{{ section.id }} .inv-hero-v3__price-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--inv-fg-muted);
    font-weight: 600;
  }

  #hero-v3-{{ section.id }} .inv-hero-v3__price-value {
    font-size: 26px;
    font-weight: 800;
    color: var(--inv-fg);
    line-height: 1.1;
  }

  #hero-v3-{{ section.id }} .inv-hero-v3__price-sub {
    font-size: 11px;
    color: var(--inv-fg-muted);
  }

  /* ============================================================
     BRAND MODE OVERRIDES
     A statement hero that sells the business, not a product.
     ============================================================ */
  #hero-v3-{{ section.id }}.inv-hero-v3--brand {
    background: {{ section.settings.background_color | default: '#0f0f0f' }};
  }

  /* Brand eyebrow: text only with red rule before */
  #hero-v3-{{ section.id }}.inv-hero-v3--brand .inv-hero-v3__eyebrow {
    background: transparent;
    color: rgba(255, 255, 255, 0.85);
    padding: 0;
    margin-bottom: var(--inv-space-md);
    align-items: center;
    gap: 12px;
    font-size: 12px;
    letter-spacing: 1.5px;
  }

  #hero-v3-{{ section.id }}.inv-hero-v3--brand .inv-hero-v3__eyebrow::before {
    content: '';
    display: inline-block;
    width: 24px;
    height: 2px;
    background: var(--inv-accent);
    flex-shrink: 0;
  }

  /* Brand heading: larger statement scale */
  #hero-v3-{{ section.id }}.inv-hero-v3--brand .inv-hero-v3__heading {
    font-size: var(--inv-text-3xl);
    line-height: 0.95;
    letter-spacing: -1px;
    max-width: 560px;
  }

  /* Brand description */
  #hero-v3-{{ section.id }}.inv-hero-v3--brand .inv-hero-v3__desc {
    font-size: 17px;
    max-width: 460px;
    color: rgba(255, 255, 255, 0.65);
  }

  /* Brand secondary CTA: ghost outline */
  #hero-v3-{{ section.id }}.inv-hero-v3--brand .inv-hero-v3__btn--secondary {
    background: transparent;
    color: var(--inv-bg-elevated);
    border: 1.5px solid rgba(255, 255, 255, 0.5);
  }

  #hero-v3-{{ section.id }}.inv-hero-v3--brand .inv-hero-v3__btn--secondary:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: var(--inv-bg-elevated);
  }

  /* Brand image: gradient fade on left edge */
  #hero-v3-{{ section.id }}.inv-hero-v3--brand .inv-hero-v3__visual {
    position: relative;
  }

  #hero-v3-{{ section.id }}.inv-hero-v3--brand .inv-hero-v3__visual::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    width: 35%;
    background: linear-gradient(
      to right,
      {{ section.settings.background_color | default: '#0f0f0f' }} 0%,
      rgba(15, 15, 15, 0) 100%
    );
    z-index: 2;
    pointer-events: none;
  }

  /* ----------------------------------------
     MOBILE (<750px)
     ---------------------------------------- */
  @media (max-width: 749px) {
    #hero-v3-{{ section.id }} .inv-hero-v3__container {
      padding: 0 var(--inv-space-md);
    }
  }

  /* ----------------------------------------
     TABLET (750px+)
     ---------------------------------------- */
  @media (min-width: 750px) {
    #hero-v3-{{ section.id }} .inv-hero-v3__heading {
      font-size: 40px;
    }

    #hero-v3-{{ section.id }} .inv-hero-v3__ctas {
      flex-direction: row;
      gap: var(--inv-space-sm-plus);
    }
  }

  /* ----------------------------------------
     DESKTOP (990px+)
     ---------------------------------------- */
  @media (min-width: 990px) {
    #hero-v3-{{ section.id }} .inv-hero-v3__container {
      grid-template-columns: 1fr 1fr;
    }

    #hero-v3-{{ section.id }} .inv-hero-v3__content {
      padding-right: var(--inv-space-2xl);
    }

    #hero-v3-{{ section.id }} .inv-hero-v3__heading {
      font-size: 54px;
    }

    /* Brand heading scales bigger via --inv-text-3xl clamp */
    #hero-v3-{{ section.id }}.inv-hero-v3--brand .inv-hero-v3__heading {
      font-size: var(--inv-text-3xl);
    }

    #hero-v3-{{ section.id }} .inv-hero-v3__visual {
      display: flex;
    }

    /* Brand image fills more of the column */
    #hero-v3-{{ section.id }}.inv-hero-v3--brand .inv-hero-v3__image {
      max-width: 520px;
      max-height: 460px;
      width: 100%;
      object-fit: cover;
    }
  }

  /* ----------------------------------------
     REDUCED MOTION
     ---------------------------------------- */
  @media (prefers-reduced-motion: reduce) {
    #hero-v3-{{ section.id }} .inv-hero-v3__btn {
      transition: none;
    }
    #hero-v3-{{ section.id }}::before,
    #hero-v3-{{ section.id }}::after {
      animation: none;
    }
  }
</style>

{% schema %}
{
  "name": "Hero v3",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Mode"
    },
    {
      "type": "select",
      "id": "hero_mode",
      "label": "Hero mode",
      "default": "promotion",
      "options": [
        { "value": "promotion", "label": "Promotion (product-led with price callout)" },
        { "value": "brand", "label": "Brand statement (editorial)" }
      ],
      "info": "Promotion: classic deal hero with red eyebrow tag and price callout. Brand: editorial statement hero with red rule eyebrow, larger heading, ghost secondary CTA, and image gradient fade."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow text",
      "default": "Premier Diamond Products",
      "info": "Promotion mode: red tag. Brand mode: text with red rule before."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "P6-TWC Triple Disc Wall Chaser Blade"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Professional grade diamond blade. Built for continuous use on site. In stock now at Canterbury and Ramsgate with free next-day delivery."
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image",
      "info": "Right column. Promotion: clean product shot. Brand: lifestyle image. Hidden on mobile."
    },
    {
      "type": "header",
      "content": "Primary CTA"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "SHOP PREMIER DIAMOND"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Secondary CTA"
    },
    {
      "type": "text",
      "id": "secondary_text",
      "label": "Button text",
      "default": "View All Deals"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Price Callout (Promotion mode only)"
    },
    {
      "type": "text",
      "id": "price_label",
      "label": "Price label",
      "default": "From",
      "info": "Small text above price"
    },
    {
      "type": "text",
      "id": "price_text",
      "label": "Price",
      "info": "Leave blank to hide price callout. Hidden automatically in Brand mode."
    },
    {
      "type": "text",
      "id": "price_subtext",
      "label": "Price subtext",
      "info": "e.g. (£35.83 ex VAT)"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour",
      "default": "#2d2d2d",
      "info": "Brand mode looks best on #0f0f0f"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Hero v3",
      "settings": {
        "hero_mode": "promotion",
        "eyebrow_text": "Premier Diamond Products",
        "heading": "P6-TWC Triple Disc Wall Chaser Blade",
        "description": "Professional grade diamond blade. Built for continuous use on site. In stock now at Canterbury and Ramsgate with free next-day delivery.",
        "button_text": "SHOP PREMIER DIAMOND",
        "secondary_text": "View All Deals",
        "background_color": "#2d2d2d"
      }
    }
  ]
}
{% endschema %}
