{% comment %}
  ============================================================================
  INVICTA HERO v3.2 — Full-bleed dark hero with text + product image
  ============================================================================
  Two-column hero: text content left, clean product image right.
  Red eyebrow tag, condensed uppercase title, dual CTAs.
  Subtle background texture via pseudo-elements, price callout badge.

  Updates in v3.2:
  - Larger heading (54px desktop, 40px tablet, 28px mobile)
  - Improved description legibility (opacity 0.7, 16px)
  - Larger product image (380px)
  - Background texture via ::before pseudo-element
  - Bottom accent line via ::after pseudo-element
  - Price callout badge on product image

  Trade 15.4.0 Compatible
  Usage: Add via theme editor or templates/index.json
  ============================================================================
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800&display=swap" rel="stylesheet">

<section
  class="inv-hero-v3"
  id="hero-v3-{{ section.id }}"
  aria-label="{{ section.settings.heading | escape }}"
>
  <div class="inv-hero-v3__container{% if section.settings.hero_image == blank %} inv-hero-v3__container--full{% endif %}">
    {%- comment -%} LEFT COLUMN: Text content {%- endcomment -%}
    <div class="inv-hero-v3__content">
      {%- if section.settings.eyebrow_text != blank -%}
        <span class="inv-hero-v3__eyebrow">{{ section.settings.eyebrow_text }}</span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="inv-hero-v3__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <p class="inv-hero-v3__desc">{{ section.settings.description }}</p>
      {%- endif -%}

      <div class="inv-hero-v3__ctas">
        {%- if section.settings.button_text != blank -%}
          <a
            href="{{ section.settings.button_link | default: '#' }}"
            class="inv-hero-v3__btn inv-hero-v3__btn--primary"
          >
            {{ section.settings.button_text }}
          </a>
        {%- endif -%}

        {%- if section.settings.secondary_text != blank -%}
          <a
            href="{{ section.settings.secondary_link | default: '#' }}"
            class="inv-hero-v3__btn inv-hero-v3__btn--secondary"
          >
            {{ section.settings.secondary_text }}
          </a>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} RIGHT COLUMN: Product image (clean, no overlay) {%- endcomment -%}
    {%- if section.settings.hero_image != blank -%}
      <div class="inv-hero-v3__visual">
        <img
          src="{{ section.settings.hero_image | image_url: width: 680 }}"
          srcset="{{ section.settings.hero_image | image_url: width: 340 }} 340w,
                  {{ section.settings.hero_image | image_url: width: 500 }} 500w,
                  {{ section.settings.hero_image | image_url: width: 680 }} 680w"
          sizes="(max-width: 989px) 0px, 380px"
          alt="{{ section.settings.heading | escape }}"
          width="{{ section.settings.hero_image.width }}"
          height="{{ section.settings.hero_image.height }}"
          loading="eager"
          fetchpriority="high"
          class="inv-hero-v3__image"
        >
        {%- if section.settings.price_text != blank -%}
          <div class="inv-hero-v3__price-tag">
            <div class="inv-hero-v3__price-label">{{ section.settings.price_label | default: 'From' }}</div>
            <div class="inv-hero-v3__price-value">{{ section.settings.price_text }}</div>
            {%- if section.settings.price_subtext != blank -%}
              <div class="inv-hero-v3__price-sub">{{ section.settings.price_subtext }}</div>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  /* ============================================================================
     INVICTA HERO v3.2 — Full-bleed dark hero
     Subtle background texture via pseudo-elements
     ============================================================================ */

  #hero-v3-{{ section.id }} {
    background: {{ section.settings.background_color | default: '#2d2d2d' }};
    padding-top: {{ section.settings.padding_top | default: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 0 }}px;
    position: relative;
    overflow: hidden;
  }

  #hero-v3-{{ section.id }}::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 20% 80%, rgba(225,29,38,0.06) 0%, transparent 50%),
      radial-gradient(circle at 80% 20%, rgba(255,255,255,0.03) 0%, transparent 40%);
    pointer-events: none;
  }

  #hero-v3-{{ section.id }}::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--inv-accent);
    z-index: 1;
  }

  #hero-v3-{{ section.id }} .inv-hero-v3__container {
    max-width: var(--inv-container, 1400px);
    margin: 0 auto;
    padding: 0 var(--inv-space-xl);
    display: grid;
    grid-template-columns: 1fr;
    min-height: 380px;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  /* When no image: content takes full width */
  #hero-v3-{{ section.id }} .inv-hero-v3__container--full .inv-hero-v3__content {
    grid-column: 1 / -1;
  }

  /* --- Left column: content --- */
  #hero-v3-{{ section.id }} .inv-hero-v3__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--inv-space-xl) 0;
  }

  /* Eyebrow tag */
  #hero-v3-{{ section.id }} .inv-hero-v3__eyebrow {
    display: inline-flex;
    align-self: flex-start;
    background: var(--inv-accent);
    color: var(--inv-bg-elevated);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 5px 14px;
    margin-bottom: var(--inv-space-md);
    line-height: 1.3;
  }

  /* Heading */
  #hero-v3-{{ section.id }} .inv-hero-v3__heading {
    font-family: 'Barlow Condensed', Impact, 'Arial Narrow', sans-serif;
    font-size: 28px;
    font-weight: 900;
    text-transform: uppercase;
    color: var(--inv-bg-elevated);
    line-height: 1.05;
    letter-spacing: -0.5px;
    margin: 0 0 var(--inv-space-md) 0;
  }

  /* Description */
  #hero-v3-{{ section.id }} .inv-hero-v3__desc {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.55;
    max-width: 400px;
    margin: 0 0 var(--inv-space-lg) 0;
  }

  /* CTA container */
  #hero-v3-{{ section.id }} .inv-hero-v3__ctas {
    display: flex;
    flex-direction: column;
    gap: var(--inv-space-sm);
    align-items: flex-start;
  }

  /* CTA buttons base */
  #hero-v3-{{ section.id }} .inv-hero-v3__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    text-decoration: none;
    padding: 13px 28px;
    transition: background var(--inv-duration-normal) ease,
                border-color var(--inv-duration-normal) ease;
    min-height: var(--inv-touch-target-min);
  }

  #hero-v3-{{ section.id }} .inv-hero-v3__btn:focus-visible {
    outline: 2px solid var(--inv-accent);
    outline-offset: 2px;
  }

  /* Primary CTA */
  #hero-v3-{{ section.id }} .inv-hero-v3__btn--primary {
    background: var(--inv-accent);
    color: var(--inv-bg-elevated);
    border: none;
  }

  #hero-v3-{{ section.id }} .inv-hero-v3__btn--primary:hover {
    background: var(--inv-accent-hover);
  }

  /* Secondary CTA */
  #hero-v3-{{ section.id }} .inv-hero-v3__btn--secondary {
    background: transparent;
    color: var(--inv-bg-elevated);
    border: 1.5px solid rgba(255, 255, 255, 0.3);
  }

  #hero-v3-{{ section.id }} .inv-hero-v3__btn--secondary:hover {
    border-color: var(--inv-bg-elevated);
  }

  /* --- Right column: visual --- */
  #hero-v3-{{ section.id }} .inv-hero-v3__visual {
    display: none;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  #hero-v3-{{ section.id }} .inv-hero-v3__image {
    max-width: 380px;
    max-height: 380px;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  /* --- Price callout --- */
  #hero-v3-{{ section.id }} .inv-hero-v3__price-tag {
    position: absolute;
    bottom: 20px;
    right: -10px;
    background: var(--inv-bg-elevated);
    padding: 10px 16px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.2);
    z-index: 2;
  }

  #hero-v3-{{ section.id }} .inv-hero-v3__price-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--inv-fg-muted);
    font-weight: 600;
  }

  #hero-v3-{{ section.id }} .inv-hero-v3__price-value {
    font-size: 26px;
    font-weight: 800;
    color: var(--inv-fg);
    line-height: 1.1;
  }

  #hero-v3-{{ section.id }} .inv-hero-v3__price-sub {
    font-size: 11px;
    color: var(--inv-fg-muted);
  }

  /* ----------------------------------------
     MOBILE (<750px)
     ---------------------------------------- */
  @media (max-width: 749px) {
    #hero-v3-{{ section.id }} .inv-hero-v3__container {
      padding: 0 var(--inv-space-md);
    }
  }

  /* ----------------------------------------
     TABLET (750px+)
     ---------------------------------------- */
  @media (min-width: 750px) {
    #hero-v3-{{ section.id }} .inv-hero-v3__heading {
      font-size: 40px;
    }

    #hero-v3-{{ section.id }} .inv-hero-v3__ctas {
      flex-direction: row;
      gap: var(--inv-space-sm-plus);
    }
  }

  /* ----------------------------------------
     DESKTOP (990px+)
     ---------------------------------------- */
  @media (min-width: 990px) {
    #hero-v3-{{ section.id }} .inv-hero-v3__container {
      grid-template-columns: 1fr 1fr;
    }

    #hero-v3-{{ section.id }} .inv-hero-v3__content {
      padding-right: var(--inv-space-2xl);
    }

    #hero-v3-{{ section.id }} .inv-hero-v3__heading {
      font-size: 54px;
    }

    #hero-v3-{{ section.id }} .inv-hero-v3__visual {
      display: flex;
    }
  }

  /* ----------------------------------------
     REDUCED MOTION
     ---------------------------------------- */
  @media (prefers-reduced-motion: reduce) {
    #hero-v3-{{ section.id }} .inv-hero-v3__btn {
      transition: none;
    }
    #hero-v3-{{ section.id }}::before,
    #hero-v3-{{ section.id }}::after {
      animation: none;
    }
  }
</style>

{% schema %}
{
  "name": "Hero v3",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow text",
      "default": "Premier Diamond Products",
      "info": "Small red tag above the heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "P6-TWC Triple Disc Wall Chaser Blade"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Professional grade diamond blade. Built for continuous use on site. In stock now at Canterbury and Ramsgate with free next-day delivery."
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image",
      "info": "Product image for right column. Hidden on mobile."
    },
    {
      "type": "header",
      "content": "Primary CTA"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "SHOP PREMIER DIAMOND"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Secondary CTA"
    },
    {
      "type": "text",
      "id": "secondary_text",
      "label": "Button text",
      "default": "View All Deals"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "header",
      "content": "Price Callout"
    },
    {
      "type": "text",
      "id": "price_label",
      "label": "Price label",
      "default": "From",
      "info": "Small text above price"
    },
    {
      "type": "text",
      "id": "price_text",
      "label": "Price",
      "info": "Leave blank to hide price callout"
    },
    {
      "type": "text",
      "id": "price_subtext",
      "label": "Price subtext",
      "info": "e.g. (£35.83 ex VAT)"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour",
      "default": "#2d2d2d"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Hero v3",
      "settings": {
        "eyebrow_text": "Premier Diamond Products",
        "heading": "P6-TWC Triple Disc Wall Chaser Blade",
        "description": "Professional grade diamond blade. Built for continuous use on site. In stock now at Canterbury and Ramsgate with free next-day delivery.",
        "button_text": "SHOP PREMIER DIAMOND",
        "secondary_text": "View All Deals",
        "background_color": "#2d2d2d"
      }
    }
  ]
}
{% endschema %}
