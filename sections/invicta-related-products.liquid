{% comment %}
  ============================================================================
  INVICTA RELATED PRODUCTS v2.0 (Gate 8: Smart Context)
  ============================================================================

  Context-aware product recommendations section.

  Behaviour:
    - Bare unit products → "Complete Your Setup" with compatible_products metafield first
    - Consumable products → "Works With These Tools" heading
    - Default → "You May Also Like" with Shopify Recommendations API

  Cards:  snippets/invicta-product-card.liquid
  Styles: assets/invicta-related-products.css
  ============================================================================
{% endcomment %}

{{ 'invicta-related-products.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} .inv-related {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .inv-related {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  comment
    Gate 8: Determine product context for heading and recommendation source
  endcomment
  assign related_heading = section.settings.heading
  assign related_intent = 'related'
  assign use_metafield_products = false
  assign context_type = 'default'

  assign title_lower = product.title | downcase
  assign is_bare_unit = false
  assign is_consumable = false

  comment — Bare unit detection
  endcomment
  if title_lower contains 'bare' or title_lower contains 'body only'
    assign is_bare_unit = true
  else
    for tag in product.tags
      assign tag_check = tag | downcase | strip
      if tag_check == 'bare' or tag_check == 'bare-unit' or tag_check == 'body-only'
        assign is_bare_unit = true
        break
      endif
    endfor
  endif

  comment — Consumable detection via collection handles
  endcomment
  unless is_bare_unit
    for col in product.collections
      assign col_handle = col.handle | downcase
      if col_handle contains 'disc' or col_handle contains 'blade' or col_handle contains 'bit' or col_handle contains 'abrasive'
        assign is_consumable = true
        break
      endif
    endfor
  endunless

  if is_bare_unit
    assign related_heading = 'Complete Your Setup'
    assign related_intent = 'complementary'
    assign context_type = 'bare-unit'
    comment — Use compatible_products metafield if populated
    endcomment
    assign compat_mf = product.metafields.custom.compatible_products
    if compat_mf != blank
      assign use_metafield_products = true
    endif
  elsif is_consumable
    assign related_heading = 'Works With These Tools'
    assign context_type = 'consumable'
  endif
-%}

{%- if use_metafield_products -%}
  {%- comment -%} === BARE UNIT: Render compatible products directly from metafield === {%- endcomment -%}
  {%- liquid
    assign mf_handles = compat_mf | replace: '[', '' | replace: ']', '' | replace: '"', '' | split: ','
    assign valid_count = 0
    for h in mf_handles
      assign h_clean = h | strip
      if h_clean != blank
        assign p = all_products[h_clean]
        if p != blank and p.title != blank
          assign valid_count = valid_count | plus: 1
        endif
      endif
    endfor
  -%}
  {%- if valid_count > 0 -%}
    <div class="inv-related" data-related-products data-product-id="{{ product.id }}">
      <div class="inv-related__container">
        <div class="inv-related__header">
          <h2 class="inv-related__title">{{ related_heading }}</h2>
        </div>
        <ul class="inv-related__grid" role="list">
          {%- assign shown = 0 -%}
          {%- for h in mf_handles -%}
            {%- if shown >= section.settings.products_to_show -%}{%- break -%}{%- endif -%}
            {%- assign h_clean = h | strip -%}
            {%- if h_clean == blank -%}{%- continue -%}{%- endif -%}
            {%- assign mf_product = all_products[h_clean] -%}
            {%- if mf_product == blank or mf_product.title == blank -%}{%- continue -%}{%- endif -%}
            <li class="inv-related__item">
              {% render 'invicta-product-card', product: mf_product, card_index: forloop.index %}
            </li>
            {%- assign shown = shown | plus: 1 -%}
          {%- endfor -%}
        </ul>
      </div>
    </div>
  {%- endif -%}

{%- elsif recommendations.performed and recommendations.products_count > 0 -%}
  {%- comment -%} === AJAX RE-RENDER: Shopify populated recommendations === {%- endcomment -%}
  <div class="inv-related" data-related-products data-product-id="{{ product.id }}">
    <div class="inv-related__container">
      <div class="inv-related__header">
        <h2 class="inv-related__title">{{ related_heading }}</h2>
      </div>
      <ul class="inv-related__grid" role="list">
        {%- for product in recommendations.products limit: section.settings.products_to_show -%}
          <li class="inv-related__item">
            {% render 'invicta-product-card', product: product, card_index: forloop.index %}
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </div>

{%- else -%}
  {%- comment -%} === INITIAL PAGE LOAD: Show skeleton, JS will fetch === {%- endcomment -%}
  <div
    class="inv-related inv-related--hidden"
    data-related-products
    data-product-id="{{ product.id }}"
    data-limit="{{ section.settings.products_to_show }}"
    data-intent="{{ related_intent }}"
  >
    <div class="inv-related__container">
      <div class="inv-related__header">
        <h2 class="inv-related__title">{{ related_heading }}</h2>
      </div>
      <div class="inv-related__skeleton" data-related-skeleton>
        {%- for i in (1..4) -%}
          <div class="inv-related__skeleton-card">
            <div class="inv-related__skeleton-img"></div>
            <div class="inv-related__skeleton-body">
              <div class="inv-related__skeleton-line"></div>
              <div class="inv-related__skeleton-line"></div>
              <div class="inv-related__skeleton-price"></div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>

  <script>
  (function() {
    var container = document.querySelector('#shopify-section-{{ section.id }} [data-related-products]');
    if (!container) return;

    var productId = container.dataset.productId;
    var limit = container.dataset.limit || {{ section.settings.products_to_show }};
    var intent = container.dataset.intent || 'related';
    if (!productId) return;

    var sectionId = '{{ section.id }}';
    var url = '/recommendations/products?section_id=' + sectionId + '&product_id=' + productId + '&limit=' + limit + '&intent=' + intent;

    fetch(url)
      .then(function(r) { return r.text(); })
      .then(function(html) {
        var temp = document.createElement('div');
        temp.innerHTML = html;
        var freshSection = temp.querySelector('[data-related-products]');

        if (freshSection && freshSection.querySelector('.inv-related__item')) {
          container.parentNode.replaceChild(freshSection, container);
        } else {
          container.remove();
        }
      })
      .catch(function() {
        container.remove();
      });
  })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Related Products",
  "tag": "section",
  "class": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "You May Also Like"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Related Products"
    }
  ]
}
{% endschema %}
