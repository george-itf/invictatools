{%- if cart != empty and cart.items.size > 0 -%}
  {{ 'cart-recommendations.css' | asset_url | stylesheet_tag }}

  {%- style -%}
    #shopify-section-{{ section.id }} .inv-cart-recs {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }
    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} .inv-cart-recs {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
  {%- endstyle -%}

  <div class="inv-cart-recs inv-cart-recs--loading"
       data-cart-recs
       data-product-id="{{ cart.items.first.product.id }}"
       data-limit="{{ section.settings.products_to_show | default: 6 }}">
    <div class="page-width">
      <h2 class="inv-cart-recs__title">{{ section.settings.heading | default: 'Complete Your Order' }}</h2>

      <div class="inv-cart-recs__skeleton" data-cart-recs-skeleton>
        {%- for i in (1..4) -%}
          <div class="inv-cart-recs__skeleton-card">
            <div class="inv-cart-recs__skeleton-img"></div>
            <div class="inv-cart-recs__skeleton-body">
              <div class="inv-cart-recs__skeleton-line"></div>
              <div class="inv-cart-recs__skeleton-line inv-cart-recs__skeleton-line--short"></div>
              <div class="inv-cart-recs__skeleton-line inv-cart-recs__skeleton-line--price"></div>
            </div>
          </div>
        {%- endfor -%}
      </div>

      {%- if recommendations.performed -%}
        {%- if recommendations.products.size > 0 -%}
          <ul class="inv-cart-recs__grid" role="list">
            {%- for product in recommendations.products limit: section.settings.products_to_show -%}
              <li class="inv-cart-recs__item">
                {%- render 'invicta-product-card', product: product, card_index: forloop.index -%}
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>

  <script src="{{ 'invicta-cart-ui.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{% schema %}
{
  "name": "Cart Recommendations",
  "class": "cart-recommendations-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Complete Your Order"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 8,
      "step": 1,
      "default": 6,
      "label": "Products to show"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 48
    }
  ],
  "templates": ["cart"]
}
{% endschema %}
