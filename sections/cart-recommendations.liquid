{%- if cart != empty and cart.items.size > 0 -%}
  {{ 'cart-recommendations.css' | asset_url | stylesheet_tag }}

  {%- style -%}
    #shopify-section-{{ section.id }} .inv-cart-recs {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }
    @media screen and (min-width: 750px) {
      #shopify-section-{{ section.id }} .inv-cart-recs {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
  {%- endstyle -%}

  {%- liquid
    assign vat_divisor = 100 | plus: settings.inv_vat_rate
    assign vat_rounding = vat_divisor | divided_by: 2
    assign heading = section.settings.heading | default: 'Complete the Job'
  -%}

  <div class="inv-cart-recs inv-cart-recs--loading"
       data-cart-recs
       data-product-id="{{ cart.items.first.product.id }}"
       data-limit="{{ section.settings.products_to_show | default: 6 }}">
    <div class="page-width">

      <div class="inv-cart-recs__header">
        <h2 class="inv-cart-recs__title">{{ heading }}</h2>
        <span class="inv-cart-recs__sub">Add to your order</span>
      </div>

      <div class="inv-cart-recs__skeleton" data-cart-recs-skeleton aria-hidden="true">
        {%- for i in (1..4) -%}
          <div class="inv-cart-recs__skeleton-card">
            <div class="inv-cart-recs__skeleton-img"></div>
            <div class="inv-cart-recs__skeleton-body">
              <div class="inv-cart-recs__skeleton-line"></div>
              <div class="inv-cart-recs__skeleton-line inv-cart-recs__skeleton-line--short"></div>
              <div class="inv-cart-recs__skeleton-line inv-cart-recs__skeleton-line--price"></div>
            </div>
          </div>
        {%- endfor -%}
      </div>

      {%- if recommendations.performed -%}
        {%- if recommendations.products.size > 0 -%}
          <ul class="inv-cart-recs__rail" role="list">
            {%- for product in recommendations.products limit: section.settings.products_to_show -%}
              {%- liquid
                assign rec_variant = product.selected_or_first_available_variant
                assign rec_price = rec_variant.price
                assign rec_price_ex = rec_price | times: 100 | plus: vat_rounding | divided_by: vat_divisor
                assign rec_img = product.featured_image
              -%}
              <li class="inv-cart-recs__item">
                <a href="{{ product.url }}" class="inv-cart-recs__card" aria-label="{{ product.title | escape }}">
                  <div class="inv-cart-recs__img" aria-hidden="true">
                    {%- if rec_img -%}
                      <img
                        src="{{ rec_img | image_url: width: 140 }}"
                        srcset="{{ rec_img | image_url: width: 140 }} 1x, {{ rec_img | image_url: width: 280 }} 2x"
                        alt=""
                        loading="lazy"
                        width="70"
                        height="70"
                      >
                    {%- endif -%}
                  </div>
                  <span class="inv-cart-recs__name">{{ product.title | escape }}</span>
                  <span class="inv-cart-recs__price">{{ rec_price | money }}</span>
                </a>
                {%- if rec_variant.available -%}
                  <form action="{{ routes.cart_add_url }}" method="post" enctype="multipart/form-data" class="inv-cart-recs__add-form" data-product-id="{{ product.id }}">
                    <input type="hidden" name="id" value="{{ rec_variant.id }}">
                    <button type="submit" class="inv-cart-recs__add" aria-label="Add {{ product.title | escape }} to cart">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    </button>
                  </form>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>

  <script src="{{ 'invicta-cart-ui.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{% schema %}
{
  "name": "Cart Recommendations",
  "class": "cart-recommendations-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Complete the Job"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 8,
      "step": 1,
      "default": 6,
      "label": "Products to show"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 48
    }
  ],
  "templates": ["cart"]
}
{% endschema %}
