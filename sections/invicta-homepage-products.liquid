{% comment %}
  ============================================================================
  INVICTA HOMEPAGE PRODUCTS v1.0 — Asymmetric products + credibility sidebar
  ============================================================================
  Two-column homepage section. Left column (~70%): product grid pulled from a
  configurable collection, rendered with the standard invicta-product-card
  snippet. Right column (~30%): sticky credibility sidebar with three
  stacked blocks — Why Invicta stats, Customer Ratings, and Trade Account CTA.

  The sidebar reinforces trust passively as visitors browse.

  Trade 15.4.0 Compatible
  ============================================================================
{% endcomment %}

{%- liquid
  assign coll = section.settings.collection
  assign max_products = section.settings.max_products | default: 6
  assign heading_text = section.settings.heading | default: 'Best Sellers'
  assign view_all_url = '#'
  if coll.url != blank
    assign view_all_url = coll.url
  elsif coll != blank and coll != ''
    assign lookup = collections[coll]
    if lookup.url != blank
      assign view_all_url = lookup.url
    endif
  endif

  assign trade_heading = section.settings.trade_heading | default: 'Trade Account'
  assign trade_description = section.settings.trade_description
  assign trade_button_text = section.settings.trade_button_text | default: 'Apply Now →'
  assign trade_button_link = section.settings.trade_button_link | default: '#'
-%}

<section class="inv-hpp" id="hpp-{{ section.id }}" aria-label="{{ heading_text | escape }}">
  <div class="inv-hpp__container">
    <div class="inv-hpp__layout">

      {%- comment -%} ====================================
          LEFT COLUMN: PRODUCT GRID
          ==================================== {%- endcomment -%}
      <div class="inv-hpp__main">
        <div class="inv-hpp__header">
          <h2 class="inv-hpp__heading">{{ heading_text | escape }}</h2>
          {%- if coll != blank -%}
            <a href="{{ view_all_url }}" class="inv-hpp__view-all">
              View all <span aria-hidden="true">&rarr;</span>
            </a>
          {%- endif -%}
        </div>

        {%- if coll.products.size > 0 -%}
          <ul class="inv-hpp__grid" role="list">
            {%- for product in coll.products limit: max_products -%}
              <li class="inv-hpp__grid-item">
                {% render 'invicta-product-card', product: product, card_index: forloop.index %}
              </li>
            {%- endfor -%}
          </ul>
        {%- else -%}
          <p class="inv-hpp__empty">Configure a collection in the section settings to display products.</p>
        {%- endif -%}
      </div>

      {%- comment -%} ====================================
          RIGHT COLUMN: CREDIBILITY SIDEBAR
          ==================================== {%- endcomment -%}
      <aside class="inv-hpp__sidebar" aria-label="Why shop with Invicta Tools">

        {%- comment -%} BLOCK 1: Why Invicta stats {%- endcomment -%}
        <div class="inv-hpp__block inv-hpp__block--stats">
          <h3 class="inv-hpp__block-heading">Why Invicta</h3>
          <div class="inv-hpp__stats">
            {%- assign stats = 'stat_1,stat_2,stat_3,stat_4' | split: ',' -%}
            {%- for s in stats -%}
              {%- assign num_key = s | append: '_number' -%}
              {%- assign label_key = s | append: '_label' -%}
              {%- assign num_val = section.settings[num_key] -%}
              {%- assign label_val = section.settings[label_key] -%}
              {%- if num_val != blank -%}
                <div class="inv-hpp__stat">
                  <span class="inv-hpp__stat-num">{{ num_val | escape }}</span>
                  <span class="inv-hpp__stat-label">{{ label_val | escape }}</span>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>

        {%- comment -%} BLOCK 2: Customer Ratings {%- endcomment -%}
        {%- assign has_ratings = false -%}
        {%- for r in (1..3) -%}
          {%- assign txt_key = 'rating_' | append: r | append: '_text' -%}
          {%- if section.settings[txt_key] != blank -%}
            {%- assign has_ratings = true -%}
          {%- endif -%}
        {%- endfor -%}

        {%- if has_ratings -%}
          <div class="inv-hpp__block inv-hpp__block--ratings">
            <h3 class="inv-hpp__block-heading">Customer Ratings</h3>
            <ul class="inv-hpp__ratings" role="list">
              {%- for r in (1..3) -%}
                {%- assign plat_key = 'rating_' | append: r | append: '_platform' -%}
                {%- assign txt_key = 'rating_' | append: r | append: '_text' -%}
                {%- assign url_key = 'rating_' | append: r | append: '_url' -%}
                {%- assign plat = section.settings[plat_key] | default: 'Google' -%}
                {%- assign txt = section.settings[txt_key] -%}
                {%- assign rurl = section.settings[url_key] -%}
                {%- if txt != blank -%}
                  {%- assign initial = plat | slice: 0 | upcase -%}
                  {%- assign plat_lower = plat | downcase -%}
                  {%- if plat_lower contains 'trustpilot' -%}
                    {%- assign initial = '★' -%}
                  {%- endif -%}
                  <li class="inv-hpp__rating-item">
                    <a
                      href="{{ rurl | default: '#' }}"
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inv-hpp__rating"
                      aria-label="{{ txt | escape }} - opens in new tab"
                    >
                      <span class="inv-hpp__rating-icon inv-hpp__rating-icon--{{ plat_lower }}" aria-hidden="true">{{ initial }}</span>
                      <span class="inv-hpp__rating-text">{{ txt | escape }}</span>
                      <span class="inv-hpp__rating-arrow" aria-hidden="true">&rarr;</span>
                    </a>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}

        {%- comment -%} BLOCK 3: Trade Account CTA {%- endcomment -%}
        <div class="inv-hpp__block inv-hpp__block--trade">
          <div class="inv-hpp__trade">
            <h3 class="inv-hpp__trade-heading">{{ trade_heading | escape }}</h3>
            {%- if trade_description != blank -%}
              <p class="inv-hpp__trade-desc">{{ trade_description | escape }}</p>
            {%- endif -%}
            <a href="{{ trade_button_link }}" class="inv-hpp__trade-btn">
              {{ trade_button_text | escape }}
            </a>
          </div>
        </div>

      </aside>

    </div>
  </div>
</section>

<style>
  /* ============================================================================
     INVICTA HOMEPAGE PRODUCTS v1.0
     Asymmetric layout: products left, credibility sidebar right.
     ============================================================================ */

  #hpp-{{ section.id }} {
    background: {{ section.settings.background_color | default: '#ffffff' }};
    padding-top: {{ section.settings.padding_top | default: 48 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 48 }}px;
  }

  #hpp-{{ section.id }} .inv-hpp__container {
    max-width: var(--inv-container, 1400px);
    margin: 0 auto;
    padding: 0 var(--inv-page-gutter, 1.5rem);
  }

  #hpp-{{ section.id }} .inv-hpp__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--inv-space-xl);
  }

  /* ----------------------------------------
     MAIN COLUMN — header + product grid
     ---------------------------------------- */
  #hpp-{{ section.id }} .inv-hpp__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--inv-space-md);
    border-bottom: 3px solid var(--inv-accent);
    padding-bottom: var(--inv-space-md);
    margin-bottom: var(--inv-space-lg);
  }

  #hpp-{{ section.id }} .inv-hpp__heading {
    font-family: var(--inv-font-body);
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 800;
    color: var(--inv-fg);
    margin: 0;
    line-height: 1.15;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  #hpp-{{ section.id }} .inv-hpp__view-all {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--inv-accent);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-decoration: none;
    white-space: nowrap;
    transition: gap var(--inv-duration-normal) ease;
  }

  #hpp-{{ section.id }} .inv-hpp__view-all:hover { gap: 10px; }

  #hpp-{{ section.id }} .inv-hpp__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--inv-space-md);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  #hpp-{{ section.id }} .inv-hpp__grid-item {
    display: flex;
    width: 100%;
  }

  #hpp-{{ section.id }} .inv-hpp__empty {
    text-align: center;
    padding: var(--inv-space-xl);
    color: var(--inv-fg-muted);
    background: var(--inv-bg);
    border: 1px dashed var(--inv-border);
  }

  /* ----------------------------------------
     SIDEBAR — credibility column
     ---------------------------------------- */
  #hpp-{{ section.id }} .inv-hpp__sidebar {
    background: var(--inv-bg);
    border-left: 1px solid var(--inv-border);
    padding: var(--inv-space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--inv-space-lg);
  }

  #hpp-{{ section.id }} .inv-hpp__block {
    padding-bottom: var(--inv-space-lg);
    border-bottom: 1px solid var(--inv-border);
  }

  #hpp-{{ section.id }} .inv-hpp__block:last-child {
    padding-bottom: 0;
    border-bottom: none;
  }

  #hpp-{{ section.id }} .inv-hpp__block-heading {
    font-family: var(--inv-font-body);
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--inv-fg-muted);
    margin: 0 0 var(--inv-space-md);
  }

  /* --- Stats grid (2x2) --- */
  #hpp-{{ section.id }} .inv-hpp__stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--inv-space-sm);
  }

  #hpp-{{ section.id }} .inv-hpp__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: var(--inv-bg-elevated);
    border: 1px solid var(--inv-border);
    padding: var(--inv-space-sm-plus) var(--inv-space-sm);
    min-height: 76px;
  }

  #hpp-{{ section.id }} .inv-hpp__stat-num {
    font-family: var(--inv-font-display);
    font-size: var(--inv-text-xl);
    font-weight: 900;
    color: var(--inv-fg);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  #hpp-{{ section.id }} .inv-hpp__stat-label {
    font-size: 10px;
    font-weight: 700;
    color: var(--inv-fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: 6px;
    line-height: 1.2;
  }

  /* --- Ratings list --- */
  #hpp-{{ section.id }} .inv-hpp__ratings {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--inv-space-sm);
  }

  #hpp-{{ section.id }} .inv-hpp__rating {
    display: grid;
    grid-template-columns: 28px 1fr auto;
    align-items: center;
    gap: var(--inv-space-sm-plus);
    background: var(--inv-bg-elevated);
    border: 1px solid var(--inv-border);
    padding: 10px var(--inv-space-sm-plus);
    text-decoration: none;
    transition: border-color var(--inv-duration-normal) ease;
  }

  #hpp-{{ section.id }} .inv-hpp__rating:hover {
    border-color: var(--inv-fg-subtle);
  }

  #hpp-{{ section.id }} .inv-hpp__rating:focus-visible {
    outline: 2px solid var(--inv-accent);
    outline-offset: 2px;
  }

  #hpp-{{ section.id }} .inv-hpp__rating-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    color: #fff;
    font-weight: 800;
    font-size: 14px;
    line-height: 1;
    text-transform: uppercase;
  }

  #hpp-{{ section.id }} .inv-hpp__rating-icon--google { background: #4285F4; }
  #hpp-{{ section.id }} .inv-hpp__rating-icon--facebook { background: #1877F2; font-style: italic; }
  #hpp-{{ section.id }} .inv-hpp__rating-icon--trustpilot { background: #00b67a; }

  #hpp-{{ section.id }} .inv-hpp__rating-text {
    font-size: 13px;
    font-weight: 700;
    color: var(--inv-fg);
    line-height: 1.2;
  }

  #hpp-{{ section.id }} .inv-hpp__rating-arrow {
    color: var(--inv-fg-subtle);
    font-size: 14px;
    transition: color var(--inv-duration-normal) ease,
                transform var(--inv-duration-normal) ease;
  }

  #hpp-{{ section.id }} .inv-hpp__rating:hover .inv-hpp__rating-arrow {
    color: var(--inv-accent);
    transform: translateX(2px);
  }

  /* --- Trade CTA box --- */
  #hpp-{{ section.id }} .inv-hpp__trade {
    background: var(--inv-dark-deep);
    color: var(--inv-bg-elevated);
    padding: var(--inv-space-md);
  }

  #hpp-{{ section.id }} .inv-hpp__trade-heading {
    font-family: var(--inv-font-display);
    font-size: 22px;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--inv-bg-elevated);
    margin: 0 0 var(--inv-space-sm);
    line-height: 1.1;
    letter-spacing: 0.02em;
  }

  #hpp-{{ section.id }} .inv-hpp__trade-desc {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.45;
    margin: 0 0 var(--inv-space-md);
  }

  #hpp-{{ section.id }} .inv-hpp__trade-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 44px;
    background: var(--inv-accent);
    color: var(--inv-bg-elevated);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-decoration: none;
    transition: background var(--inv-duration-normal) ease;
  }

  #hpp-{{ section.id }} .inv-hpp__trade-btn:hover {
    background: var(--inv-accent-hover);
  }

  /* ----------------------------------------
     TABLET (750-989px): sidebar moves below grid, displays horizontally
     ---------------------------------------- */
  @media (min-width: 750px) and (max-width: 989px) {
    #hpp-{{ section.id }} .inv-hpp__grid {
      grid-template-columns: repeat(3, 1fr);
    }

    #hpp-{{ section.id }} .inv-hpp__sidebar {
      flex-direction: row;
      gap: var(--inv-space-md);
      border-left: none;
      border-top: 1px solid var(--inv-border);
    }

    #hpp-{{ section.id }} .inv-hpp__block {
      flex: 1 1 33%;
      padding-bottom: 0;
      border-bottom: none;
      border-right: 1px solid var(--inv-border);
      padding-right: var(--inv-space-md);
    }

    #hpp-{{ section.id }} .inv-hpp__block:last-child {
      border-right: none;
      padding-right: 0;
    }
  }

  /* ----------------------------------------
     DESKTOP (990px+): two-column asymmetric
     ---------------------------------------- */
  @media (min-width: 990px) {
    #hpp-{{ section.id }} .inv-hpp__layout {
      grid-template-columns: 1fr 280px;
      gap: var(--inv-space-xl);
    }

    #hpp-{{ section.id }} .inv-hpp__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ----------------------------------------
     MOBILE (<750px)
     ---------------------------------------- */
  @media (max-width: 749px) {
    #hpp-{{ section.id }} .inv-hpp__container {
      padding-left: var(--inv-mobile-gutter);
      padding-right: var(--inv-mobile-gutter);
    }

    #hpp-{{ section.id }} .inv-hpp__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--inv-mobile-card-gap);
    }

    #hpp-{{ section.id }} .inv-hpp__sidebar {
      border-left: none;
      border-top: 1px solid var(--inv-border);
      padding: var(--inv-space-md);
    }
  }

  /* ----------------------------------------
     REDUCED MOTION
     ---------------------------------------- */
  @media (prefers-reduced-motion: reduce) {
    #hpp-{{ section.id }} .inv-hpp__view-all,
    #hpp-{{ section.id }} .inv-hpp__rating,
    #hpp-{{ section.id }} .inv-hpp__rating-arrow,
    #hpp-{{ section.id }} .inv-hpp__trade-btn {
      transition: none;
    }

    #hpp-{{ section.id }} .inv-hpp__rating:hover .inv-hpp__rating-arrow {
      transform: none;
    }
  }
</style>

{% schema %}
{
  "name": "Homepage Products",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Product Grid"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Best Sellers"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Max products",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "header",
      "content": "Sidebar — Why Invicta Stats"
    },
    {
      "type": "text",
      "id": "stat_1_number",
      "label": "Stat 1 number",
      "default": "30+"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stat 1 label",
      "default": "Years Trading"
    },
    {
      "type": "text",
      "id": "stat_2_number",
      "label": "Stat 2 number",
      "default": "15k+"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Stat 2 label",
      "default": "Products"
    },
    {
      "type": "text",
      "id": "stat_3_number",
      "label": "Stat 3 number",
      "default": "25+"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stat 3 label",
      "default": "Brands"
    },
    {
      "type": "text",
      "id": "stat_4_number",
      "label": "Stat 4 number",
      "default": "2"
    },
    {
      "type": "text",
      "id": "stat_4_label",
      "label": "Stat 4 label",
      "default": "Kent Branches"
    },
    {
      "type": "header",
      "content": "Sidebar — Customer Ratings"
    },
    {
      "type": "text",
      "id": "rating_1_platform",
      "label": "Rating 1 platform",
      "default": "Google",
      "info": "Used for icon styling. Choose 'Google', 'Facebook', or 'Trustpilot'."
    },
    {
      "type": "text",
      "id": "rating_1_text",
      "label": "Rating 1 text",
      "default": "4.7 ★ on Google"
    },
    {
      "type": "url",
      "id": "rating_1_url",
      "label": "Rating 1 URL"
    },
    {
      "type": "text",
      "id": "rating_2_platform",
      "label": "Rating 2 platform",
      "default": "Facebook"
    },
    {
      "type": "text",
      "id": "rating_2_text",
      "label": "Rating 2 text",
      "default": "4.8 ★ on Facebook"
    },
    {
      "type": "url",
      "id": "rating_2_url",
      "label": "Rating 2 URL"
    },
    {
      "type": "text",
      "id": "rating_3_platform",
      "label": "Rating 3 platform",
      "default": "Trustpilot"
    },
    {
      "type": "text",
      "id": "rating_3_text",
      "label": "Rating 3 text",
      "default": "4.4 ★ on Trustpilot"
    },
    {
      "type": "url",
      "id": "rating_3_url",
      "label": "Rating 3 URL"
    },
    {
      "type": "header",
      "content": "Sidebar — Trade Account CTA"
    },
    {
      "type": "text",
      "id": "trade_heading",
      "label": "Heading",
      "default": "Trade Account"
    },
    {
      "type": "textarea",
      "id": "trade_description",
      "label": "Description",
      "default": "Volume pricing, credit terms, dedicated account manager"
    },
    {
      "type": "text",
      "id": "trade_button_text",
      "label": "Button text",
      "default": "Apply Now →"
    },
    {
      "type": "url",
      "id": "trade_button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 48,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Homepage Products",
      "settings": {
        "heading": "Best Sellers",
        "max_products": 6
      }
    }
  ]
}
{% endschema %}
