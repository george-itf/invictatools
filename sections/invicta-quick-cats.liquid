{% comment %}
  ============================================================================
  INVICTA QUICK CATEGORIES v4.0 — Vertical nav grid
  ============================================================================
  Single-row grid of vertical category cards: circular icon at the top,
  title in the middle, optional product count beneath. Section header
  carries the heading on the left and an optional "view all" link on the
  right. Designed for above-the-fold homepage placement.

  v4.0 changes:
  - Card body switched from horizontal (icon-left) to vertical stack
  - Icon now sits inside a soft white circular badge over a card-soft
    background — accent recolours on hover
  - Default desktop column count raised to 7 to fit the full category set

  Trade 15.4.0 Compatible
  ============================================================================
{% endcomment %}

{%- liquid
  assign bg_color = section.settings.background_color | default: '#ffffff'
  assign pad_top = section.settings.padding_top | default: 40
  assign pad_bottom = section.settings.padding_bottom | default: 40
  assign cols_desktop = section.settings.columns_desktop | default: 7
  assign heading_text = section.settings.heading
  assign heading_link = section.settings.heading_link
  assign heading_link_text = section.settings.heading_link_text | default: 'View all categories'
-%}

<style>
  #shopify-section-{{ section.id }} { display: block; }

  #shopify-section-{{ section.id }} .inv-quick-cats {
    display: block;
    background: {{ bg_color }};
    padding-top: {{ pad_top }}px;
    padding-bottom: {{ pad_bottom }}px;
  }

  #shopify-section-{{ section.id }} .inv-quick-cats__container {
    max-width: var(--inv-container, 1400px);
    margin: 0 auto;
    padding: 0 var(--inv-page-gutter, 1.5rem);
  }

  #shopify-section-{{ section.id }} .inv-quick-cats__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--inv-space-md);
    border-bottom: 3px solid var(--inv-accent);
    padding-bottom: var(--inv-space-md);
    margin-bottom: var(--inv-space-lg);
  }

  #shopify-section-{{ section.id }} .inv-quick-cats__heading {
    font-family: var(--inv-font-body);
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 800;
    color: var(--inv-fg);
    margin: 0;
    line-height: 1.15;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .inv-quick-cats__view-all {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--inv-accent);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-decoration: none;
    white-space: nowrap;
    transition: gap var(--inv-duration-normal) ease;
  }

  #shopify-section-{{ section.id }} .inv-quick-cats__view-all:hover { gap: 10px; }

  #shopify-section-{{ section.id }} .inv-quick-cats__grid {
    display: grid;
    grid-template-columns: repeat({{ cols_desktop }}, 1fr);
    gap: var(--inv-space-sm-plus);
  }

  #shopify-section-{{ section.id }} .inv-quick-cats__card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    gap: 10px;
    background: var(--inv-bg);
    border: 1px solid var(--inv-border);
    border-radius: 0;
    padding: 22px 12px 18px;
    text-decoration: none;
    min-height: 156px;
    text-align: center;
    transition: border-color var(--inv-duration-normal) ease,
                background-color var(--inv-duration-normal) ease,
                transform var(--inv-duration-normal) ease;
  }

  #shopify-section-{{ section.id }} .inv-quick-cats__card:hover {
    border-color: var(--inv-accent);
    background: var(--inv-bg-elevated);
    transform: translateY(-2px);
  }

  #shopify-section-{{ section.id }} .inv-quick-cats__card:focus-visible {
    outline: var(--inv-focus-ring-width) solid var(--inv-accent);
    outline-offset: var(--inv-focus-ring-offset);
  }

  #shopify-section-{{ section.id }} .inv-quick-cats__icon {
    display: flex;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--inv-bg-elevated);
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    overflow: hidden;
    box-shadow: inset 0 0 0 1px var(--inv-border-subtle);
    transition: box-shadow var(--inv-duration-normal) ease;
  }

  /* Photo variant — collection image fills the circle */
  #shopify-section-{{ section.id }} .inv-quick-cats__icon--photo {
    background: var(--inv-bg-soft);
  }

  #shopify-section-{{ section.id }} .inv-quick-cats__card:hover .inv-quick-cats__icon {
    box-shadow: inset 0 0 0 2px var(--inv-accent);
  }

  #shopify-section-{{ section.id }} .inv-quick-cats__icon svg {
    width: 26px;
    height: 26px;
    color: var(--inv-fg);
    display: block;
    transition: color var(--inv-duration-normal) ease;
  }

  #shopify-section-{{ section.id }} .inv-quick-cats__card:hover .inv-quick-cats__icon svg {
    color: var(--inv-accent);
  }

  /* Custom icon (SVG-style upload) — small, centred */
  #shopify-section-{{ section.id }} .inv-quick-cats__icon img {
    width: 28px;
    height: 28px;
    object-fit: contain;
    display: block;
  }

  /* Collection photo — fills the circular badge */
  #shopify-section-{{ section.id }} .inv-quick-cats__icon img.inv-quick-cats__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .inv-quick-cats__body {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .inv-quick-cats__title {
    font-size: 13px;
    font-weight: 800;
    color: var(--inv-fg);
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .inv-quick-cats__card:hover .inv-quick-cats__title {
    color: var(--inv-accent);
  }

  #shopify-section-{{ section.id }} .inv-quick-cats__desc {
    font-size: 11px;
    color: var(--inv-fg-muted);
    line-height: 1.35;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 100%;
  }

  #shopify-section-{{ section.id }} .inv-quick-cats__count {
    font-size: 11px;
    color: var(--inv-fg-subtle);
    line-height: 1.3;
    margin-top: 0;
    font-weight: 500;
  }

  #shopify-section-{{ section.id }} .inv-quick-cats__empty {
    text-align: center;
    padding: var(--inv-space-xl) 0;
    color: var(--inv-fg-muted);
  }

  @media (max-width: 1199px) {
    #shopify-section-{{ section.id }} .inv-quick-cats__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .inv-quick-cats__container {
      padding-left: var(--inv-mobile-gutter);
      padding-right: var(--inv-mobile-gutter);
    }

    #shopify-section-{{ section.id }} .inv-quick-cats__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--inv-mobile-card-gap);
    }

    #shopify-section-{{ section.id }} .inv-quick-cats__card {
      padding: 16px 10px 14px;
      min-height: 132px;
    }

    #shopify-section-{{ section.id }} .inv-quick-cats__icon {
      width: 48px;
      height: 48px;
    }

    #shopify-section-{{ section.id }} .inv-quick-cats__icon svg,
    #shopify-section-{{ section.id }} .inv-quick-cats__icon img:not(.inv-quick-cats__photo) {
      width: 22px;
      height: 22px;
    }

    #shopify-section-{{ section.id }} .inv-quick-cats__title { font-size: 12px; }
    #shopify-section-{{ section.id }} .inv-quick-cats__desc { font-size: 10px; }

    #shopify-section-{{ section.id }} .inv-quick-cats__header {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--inv-space-sm);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .inv-quick-cats__card,
    #shopify-section-{{ section.id }} .inv-quick-cats__icon,
    #shopify-section-{{ section.id }} .inv-quick-cats__view-all { transition: none; }
    #shopify-section-{{ section.id }} .inv-quick-cats__card:hover { transform: none; }
  }
</style>

<section class="inv-quick-cats">
  <div class="inv-quick-cats__container">

    {%- if heading_text != blank or heading_link != blank -%}
      <div class="inv-quick-cats__header">
        {%- if heading_text != blank -%}
          <h2 class="inv-quick-cats__heading">{{ heading_text | escape }}</h2>
        {%- else -%}
          <span></span>
        {%- endif -%}
        {%- if heading_link != blank -%}
          <a href="{{ heading_link }}" class="inv-quick-cats__view-all">
            {{ heading_link_text | escape }} <span aria-hidden="true">&rarr;</span>
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="inv-quick-cats__grid">
        {%- for block in section.blocks -%}

          {%- liquid
            assign cat_url = '#'
            assign cat_collection_setting = block.settings.collection
            assign cat_custom_link = block.settings.custom_link

            if cat_collection_setting.url != blank
              assign cat_url = cat_collection_setting.url
            elsif cat_collection_setting.handle != blank
              assign cat_url = cat_collection_setting.url | default: '/collections/' | append: cat_collection_setting.handle
            elsif cat_collection_setting != blank and cat_collection_setting != ''
              assign lookup_collection = collections[cat_collection_setting]
              if lookup_collection.url != blank
                assign cat_url = lookup_collection.url
              else
                assign cat_url = '/collections/' | append: cat_collection_setting
              endif
            elsif cat_custom_link != blank
              assign cat_url = cat_custom_link
            endif

            assign cat_title = block.settings.title | default: 'Category'
            assign cat_desc = block.settings.description
            assign cat_icon = block.settings.icon | default: 'drill'
            assign cat_custom_icon = block.settings.custom_icon

            assign inv_show_count = block.settings.show_count
            assign inv_product_count = 0
            if cat_collection_setting.products_count
              assign inv_product_count = cat_collection_setting.products_count
            elsif cat_collection_setting != blank and cat_collection_setting != ''
              assign lookup_collection = collections[cat_collection_setting]
              if lookup_collection.products_count
                assign inv_product_count = lookup_collection.products_count
              endif
            endif

            assign cat_image = blank
            if cat_collection_setting.image != blank
              assign cat_image = cat_collection_setting.image
            elsif cat_collection_setting != blank and cat_collection_setting != ''
              assign lookup_collection = collections[cat_collection_setting]
              if lookup_collection.image != blank
                assign cat_image = lookup_collection.image
              endif
            endif
          -%}

          <a href="{{ cat_url }}" class="inv-quick-cats__card" {{ block.shopify_attributes }}>
            <div class="inv-quick-cats__icon{% if cat_image != blank %} inv-quick-cats__icon--photo{% endif %}">
              {%- if cat_image != blank -%}
                <img class="inv-quick-cats__photo" src="{{ cat_image | image_url: width: 128 }}" alt="" width="56" height="56" loading="lazy">
              {%- elsif cat_custom_icon != blank -%}
                <img src="{{ cat_custom_icon | image_url: width: 56 }}" alt="" width="28" height="28" loading="lazy">
              {%- else -%}
                {%- case cat_icon -%}
                  {%- when 'drill' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true"><path d="M14 4l6 6-8 8-6-6 8-8z"/><path d="M14 4l-4-2"/><path d="M20 10l2-4"/><path d="M6 12L2 8"/><path d="M12 18l-4 4"/></svg>
                  {%- when 'impact' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true"><circle cx="12" cy="12" r="8"/><circle cx="12" cy="12" r="3"/><path d="M12 4v1"/><path d="M12 19v1"/><path d="M4 12h1"/><path d="M19 12h1"/></svg>
                  {%- when 'grinder' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true"><path d="M2 12h6l2-2h6l2 2h4"/><path d="M8 12v6"/><path d="M6 18h4"/><path d="M18 8V6a2 2 0 0 0-2-2H8"/><path d="M14 8l4-4"/></svg>
                  {%- when 'battery' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true"><rect x="2" y="7" width="18" height="12" rx="2"/><path d="M22 11v4"/><path d="M6 11v4"/><path d="M10 11v4"/><path d="M14 11v4"/></svg>
                  {%- when 'saw' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/><path d="M12 2v4"/><path d="M12 18v4"/><path d="M2 12h4"/><path d="M18 12h4"/><path d="M4.93 4.93l2.83 2.83"/><path d="M16.24 16.24l2.83 2.83"/><path d="M4.93 19.07l2.83-2.83"/><path d="M16.24 7.76l2.83-2.83"/></svg>
                  {%- when 'storage' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v3"/><path d="M2 12h20"/><path d="M12 12v3"/></svg>
                  {%- when 'safety' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                  {%- when 'outdoor' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                  {%- when 'workwear' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true"><path d="M16 3h-2a4 4 0 0 1-8 0H4l-2 5 4 1v12h12V9l4-1-2-5z"/></svg>
                  {%- when 'ppe' -%}
                    {%- comment -%} Hard hat — used for "PPE" category. {%- endcomment -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true"><path d="M3 17h18"/><path d="M5 17a7 7 0 0 1 14 0"/><path d="M9 10V6a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v4"/><path d="M3 17v2h18v-2"/></svg>
                  {%- when 'adhesive' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true"><path d="M9 2h6v6H9z"/><path d="M8 8h8l1 4-2 10H9L7 12z"/><circle cx="12" cy="15" r="2"/></svg>
                  {%- else -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true"><circle cx="12" cy="12" r="10"/></svg>
                {%- endcase -%}
              {%- endif -%}
            </div>

            <div class="inv-quick-cats__body">
              <h3 class="inv-quick-cats__title">{{ cat_title | escape }}</h3>
              {%- if cat_desc != blank -%}
                <span class="inv-quick-cats__desc">{{ cat_desc | escape }}</span>
              {%- endif -%}
              {%- if inv_show_count and inv_product_count > 0 -%}
                <span class="inv-quick-cats__count">{{ inv_product_count }}+ items</span>
              {%- endif -%}
            </div>
          </a>

        {%- endfor -%}
      </div>
    {%- else -%}
      <p class="inv-quick-cats__empty">{{ 'invicta.sections.quick_cats.empty_state' | t }}</p>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Quick Categories",
  "tag": "section",
  "class": "section-quick-cats",
  "max_blocks": 8,
  "settings": [
    { "type": "header", "content": "Header" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by Category" },
    { "type": "url", "id": "heading_link", "label": "View-all link", "info": "Optional. Right-aligned link in the header." },
    { "type": "text", "id": "heading_link_text", "label": "View-all link text", "default": "View all categories" },
    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "columns_desktop", "label": "Columns (Desktop)", "min": 3, "max": 8, "step": 1, "default": 7 },
    { "type": "color", "id": "background_color", "label": "Background Colour", "default": "#ffffff" },
    { "type": "range", "id": "padding_top", "label": "Padding Top", "min": 0, "max": 100, "step": 4, "default": 40, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Padding Bottom", "min": 0, "max": 100, "step": 4, "default": 40, "unit": "px" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Cordless Drills" },
        { "type": "text", "id": "description", "label": "Description", "info": "Short subtitle (e.g. 'Drills, grinders, saws'). Optional." },
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "url", "id": "custom_link", "label": "Custom Link", "info": "Used if no collection selected" },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "drill",
          "options": [
            { "value": "drill", "label": "Drill" },
            { "value": "impact", "label": "Impact Driver" },
            { "value": "grinder", "label": "Grinder" },
            { "value": "battery", "label": "Battery" },
            { "value": "saw", "label": "Saw" },
            { "value": "storage", "label": "Storage" },
            { "value": "safety", "label": "Safety" },
            { "value": "outdoor", "label": "Outdoor" },
            { "value": "workwear", "label": "Workwear" },
            { "value": "ppe", "label": "PPE / Hard hat" },
            { "value": "adhesive", "label": "Adhesive / Sealant" }
          ]
        },
        { "type": "image_picker", "id": "custom_icon", "label": "Custom Icon Image", "info": "Overrides built-in icon. Will be inverted to white." },
        { "type": "checkbox", "id": "show_count", "label": "Show product count", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "Quick Categories",
      "settings": { "heading": "Shop by Category", "columns_desktop": 4 },
      "blocks": [
        { "type": "category", "settings": { "title": "Cordless Drills", "description": "Drills & impact drivers", "icon": "drill" } },
        { "type": "category", "settings": { "title": "Grinders", "description": "Angle, die, surface", "icon": "grinder" } },
        { "type": "category", "settings": { "title": "Nailers", "description": "First & second fix", "icon": "impact" } },
        { "type": "category", "settings": { "title": "Batteries", "description": "All major platforms", "icon": "battery" } },
        { "type": "category", "settings": { "title": "Saws", "description": "Circular, mitre, jig", "icon": "saw" } },
        { "type": "category", "settings": { "title": "Power Tool Kits", "description": "Combo & twin packs", "icon": "storage" } },
        { "type": "category", "settings": { "title": "PPE & Workwear", "description": "Boots, jackets, hi-vis", "icon": "workwear" } },
        { "type": "category", "settings": { "title": "Adhesives & Sealants", "description": "Soudal, CT1, Sika", "icon": "adhesive" } }
      ]
    }
  ]
}
{% endschema %}