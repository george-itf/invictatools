{% comment %}
  ============================================================================
  INVICTA HERO SPLIT v2.0
  Trade-style hero with bold promo cards and auto-rotating slideshow
  ============================================================================
{% endcomment %}

{%- liquid
  assign slides = ''
  assign slide_count = 0
  for block in section.blocks
    if block.type == 'slide'
      assign slide_count = slide_count | plus: 1
    endif
  endfor
-%}

<style>
  /* ============================================
     HERO SPLIT - MAIN STRUCTURE
     ============================================ */

  .inv-hero-split {
    background: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  .inv-hero-split__container {
    max-width: var(--inv-container, 1400px);
    margin: 0 auto;
    padding: 0 var(--inv-gutter, 24px);
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 20px;
  }

  /* ============================================
     MAIN HERO PANEL
     ============================================ */

  .inv-hero-split__main {
    background: #2d2d2d;
    min-height: 280px;
    position: relative;
    overflow: hidden;
  }

  /* --- Slideshow --- */
  .inv-hero-split__slides {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 280px;
  }

  .inv-hero-split__slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 40px;
    opacity: 0;
    transition: opacity 400ms ease;
    pointer-events: none;
    z-index: 1;
  }

  .inv-hero-split__slide--active {
    opacity: 1;
    pointer-events: auto;
    z-index: 2;
  }

  /* Single slide — keep absolute positioning (fills parent), just skip transition */
  .inv-hero-split__slides--single .inv-hero-split__slide {
    opacity: 1;
    pointer-events: auto;
    transition: none;
  }

  .inv-hero-split__content {
    max-width: 400px;
    position: relative;
    z-index: 2;
  }

  .inv-hero-split__badge {
    display: inline-block;
    background: #e11d26;
    color: #fff;
    padding: 6px 12px;
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 12px;
  }

  .inv-hero-split__heading {
    font-size: clamp(26px, 3.5vw, 36px);
    font-weight: 900;
    color: #fff;
    line-height: 1.1;
    margin: 0 0 12px 0;
    text-transform: uppercase;
    letter-spacing: -0.01em;
  }

  .inv-hero-split__subheading {
    font-size: 15px;
    color: rgba(255, 255, 255, 0.75);
    margin: 0 0 20px 0;
    line-height: 1.5;
  }

  .inv-hero-split__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--inv-accent);
    color: #fff;
    padding: 14px 28px;
    font-size: 14px;
    font-weight: 800;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    transition: background 0.15s, gap 0.15s;
  }

  .inv-hero-split__btn:hover {
    background: var(--inv-accent-hover);
    gap: 12px;
    filter: brightness(0.9);
  }

  .inv-hero-split__btn-wrap {
    position: absolute;
    z-index: 3;
    /* top/left set via inline style from theme settings */
  }

  .inv-hero-split__btn:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }

  .inv-hero-split__product-image {
    position: absolute;
    right: 24px;
    bottom: 0;
    max-width: 260px;
    max-height: 90%;
    object-fit: contain;
    z-index: 1;
  }

  /* Mobile image - hidden by default */
  .inv-hero-split__mobile-image {
    display: none;
  }

  /* ============================================
     SLIDESHOW CONTROLS
     ============================================ */

  .inv-hero-split__dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    padding: 12px 0 4px;
    z-index: 10;
  }

  .inv-hero-split__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 2px solid #e11d26;
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: background 200ms ease;
  }

  .inv-hero-split__dot--active {
    background: #e11d26;
  }

  .inv-hero-split__dot:hover {
    background: #e11d26;
    opacity: 0.7;
  }

  .inv-hero-split__dot:focus-visible {
    outline: 2px solid #e11d26;
    outline-offset: 2px;
  }

  /* Arrow controls */
  .inv-hero-split__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    background: rgba(0, 0, 0, 0.4);
    color: #fff;
    border: none;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    transition: opacity 200ms ease, background 200ms ease;
  }

  .inv-hero-split__main:hover .inv-hero-split__arrow {
    opacity: 1;
  }

  .inv-hero-split__arrow:hover {
    background: rgba(0, 0, 0, 0.6);
  }

  .inv-hero-split__arrow:focus-visible {
    opacity: 1;
    outline: 2px solid #fff;
    outline-offset: 2px;
  }

  .inv-hero-split__arrow--prev {
    left: 12px;
  }

  .inv-hero-split__arrow--next {
    right: 12px;
  }

  .inv-hero-split__arrow svg {
    width: 18px;
    height: 18px;
  }

  /* Hide controls for single slide */
  .inv-hero-split__controls--hidden {
    display: none !important;
  }

  /* ============================================
     SIDEBAR PROMO CARDS
     Matches site: sharp edges, clean #e11d26 red,
     subtle lift hover, 8px radius buttons
     ============================================ */

  .inv-hero-split__side {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* --- Card Base --- */
  .inv-hero-split__card {
    flex: 1;
    display: grid;
    grid-template-columns: 5px 1fr;
    grid-template-rows: 1fr auto;
    text-decoration: none;
    position: relative;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .inv-hero-split__card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
  }

  .inv-hero-split__card:focus-visible {
    outline: 2px solid #e11d26;
    outline-offset: 2px;
  }

  /* --- Left accent stripe --- */
  .inv-hero-split__card-stripe {
    grid-row: 1 / -1;
    grid-column: 1;
    z-index: 2;
  }

  .inv-hero-split__card--sale .inv-hero-split__card-stripe,
  .inv-hero-split__card--brand .inv-hero-split__card-stripe {
    background: #fbbf24;
  }

  .inv-hero-split__card--info .inv-hero-split__card-stripe {
    background: #e11d26;
  }

  .inv-hero-split__card--light .inv-hero-split__card-stripe,
  .inv-hero-split__card--white .inv-hero-split__card-stripe,
  .inv-hero-split__card--outline .inv-hero-split__card-stripe {
    background: #e11d26;
  }

  .inv-hero-split__card--warning .inv-hero-split__card-stripe {
    background: #1a1a1a;
  }

  .inv-hero-split__card--success .inv-hero-split__card-stripe {
    background: #fff;
  }

  /* --- Background image layer --- */
  .inv-hero-split__card-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .inv-hero-split__card-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.35s ease;
  }

  .inv-hero-split__card:hover .inv-hero-split__card-bg img {
    transform: scale(1.05);
  }

  /* --- Gradient overlay --- */
  .inv-hero-split__card-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .inv-hero-split__card--sale .inv-hero-split__card-overlay {
    background: #e11d26;
  }

  .inv-hero-split__card--brand .inv-hero-split__card-overlay {
    background: #e11d26;
  }

  .inv-hero-split__card--info .inv-hero-split__card-overlay {
    background: #1a1a1a;
  }

  .inv-hero-split__card--light .inv-hero-split__card-overlay {
    background: #f5f5f5;
  }

  .inv-hero-split__card--warning .inv-hero-split__card-overlay {
    background: #f59e0b;
  }

  .inv-hero-split__card--success .inv-hero-split__card-overlay {
    background: #16a34a;
  }

  .inv-hero-split__card--white .inv-hero-split__card-overlay {
    background: #fff;
  }

  .inv-hero-split__card--outline .inv-hero-split__card-overlay {
    background: #fff;
  }

  .inv-hero-split__card--outline {
    border: 2px solid #e5e5e5;
  }

  /* With bg image, overlay becomes semi-transparent gradient */
  .inv-hero-split__card--has-image .inv-hero-split__card-overlay {
    opacity: 0.92;
  }

  /* --- Shimmer sweep on hover --- */
  .inv-hero-split__card-shimmer {
    position: absolute;
    inset: 0;
    z-index: 5;
    pointer-events: none;
    overflow: hidden;
  }

  .inv-hero-split__card-shimmer::after {
    content: '';
    position: absolute;
    top: -50%;
    left: -60%;
    width: 40%;
    height: 200%;
    background: linear-gradient(
      105deg,
      transparent 40%,
      rgba(255, 255, 255, 0.1) 45%,
      rgba(255, 255, 255, 0.2) 50%,
      rgba(255, 255, 255, 0.1) 55%,
      transparent 60%
    );
    transform: translateX(-100%);
    transition: none;
  }

  .inv-hero-split__card:hover .inv-hero-split__card-shimmer::after {
    animation: inv-card-shimmer 0.6s ease-out forwards;
  }

  .inv-hero-split__card--light .inv-hero-split__card-shimmer::after,
  .inv-hero-split__card--white .inv-hero-split__card-shimmer::after,
  .inv-hero-split__card--outline .inv-hero-split__card-shimmer::after {
    background: linear-gradient(
      105deg,
      transparent 40%,
      rgba(0, 0, 0, 0.02) 45%,
      rgba(0, 0, 0, 0.04) 50%,
      rgba(0, 0, 0, 0.02) 55%,
      transparent 60%
    );
  }

  @keyframes inv-card-shimmer {
    0%   { transform: translateX(-100%); }
    100% { transform: translateX(350%); }
  }

  /* --- Corner ribbon --- */
  .inv-hero-split__card-ribbon {
    position: absolute;
    top: 14px;
    right: -30px;
    z-index: 6;
    background: #fbbf24;
    color: #1a1a1a;
    font-size: 10px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 4px 36px;
    transform: rotate(45deg);
  }

  .inv-hero-split__card--info .inv-hero-split__card-ribbon {
    background: #e11d26;
    color: #fff;
  }

  /* --- Card body --- */
  .inv-hero-split__card-body {
    grid-column: 2;
    grid-row: 1;
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 20px 24px;
    gap: 10px;
  }

  /* --- Icon + Callout row --- */
  .inv-hero-split__card-top-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .inv-hero-split__card-icon-wrap {
    position: relative;
    width: 40px;
    height: 40px;
    flex-shrink: 0;
  }

  .inv-hero-split__card-icon {
    width: 40px;
    height: 40px;
    border-radius: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 2;
    background: rgba(255, 255, 255, 0.15);
  }

  .inv-hero-split__card--light .inv-hero-split__card-icon,
  .inv-hero-split__card--white .inv-hero-split__card-icon,
  .inv-hero-split__card--outline .inv-hero-split__card-icon {
    background: #e11d26;
  }

  .inv-hero-split__card-icon svg {
    width: 20px;
    height: 20px;
    color: #fff;
  }

  /* Pulse ring on hover */
  .inv-hero-split__card-icon-wrap::after {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 0;
    border: 2px solid rgba(255, 255, 255, 0.25);
    z-index: 1;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .inv-hero-split__card--light .inv-hero-split__card-icon-wrap::after,
  .inv-hero-split__card--white .inv-hero-split__card-icon-wrap::after,
  .inv-hero-split__card--outline .inv-hero-split__card-icon-wrap::after {
    border-color: rgba(225, 29, 38, 0.25);
  }

  .inv-hero-split__card:hover .inv-hero-split__card-icon-wrap::after {
    opacity: 1;
    animation: inv-icon-ping 1s ease-out infinite;
  }

  @keyframes inv-icon-ping {
    0%   { inset: -3px; opacity: 0.5; }
    100% { inset: -12px; opacity: 0; }
  }

  /* --- Callout stat --- */
  .inv-hero-split__card-callout {
    font-size: clamp(18px, 2vw, 22px);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #fff;
  }

  .inv-hero-split__card--light .inv-hero-split__card-callout,
  .inv-hero-split__card--white .inv-hero-split__card-callout,
  .inv-hero-split__card--outline .inv-hero-split__card-callout {
    color: #e11d26;
  }

  /* --- Title & subtitle --- */
  .inv-hero-split__card-content {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .inv-hero-split__card-content h3 {
    font-size: 14px;
    font-weight: 800;
    line-height: 1.2;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #fff;
  }

  .inv-hero-split__card-content p {
    font-size: 13px;
    font-weight: 500;
    margin: 0;
    line-height: 1.3;
    color: rgba(255, 255, 255, 0.7);
  }

  .inv-hero-split__card--light .inv-hero-split__card-content h3,
  .inv-hero-split__card--white .inv-hero-split__card-content h3,
  .inv-hero-split__card--outline .inv-hero-split__card-content h3 {
    color: #1a1a1a;
  }

  .inv-hero-split__card--light .inv-hero-split__card-content p,
  .inv-hero-split__card--white .inv-hero-split__card-content p,
  .inv-hero-split__card--outline .inv-hero-split__card-content p {
    color: var(--inv-fg-muted);
  }

  /* --- CTA button (matches site button style) --- */
  .inv-hero-split__card-cta {
    grid-column: 2;
    grid-row: 2;
    position: relative;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 20px;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #fff;
    background: rgba(0, 0, 0, 0.2);
    transition: background 0.2s ease, gap 0.15s ease;
  }

  .inv-hero-split__card:hover .inv-hero-split__card-cta {
    background: rgba(0, 0, 0, 0.35);
    gap: 12px;
  }

  .inv-hero-split__card-cta svg {
    width: 14px;
    height: 14px;
    transition: transform 0.15s ease;
  }

  .inv-hero-split__card:hover .inv-hero-split__card-cta svg {
    transform: translateX(3px);
  }

  /* Light card CTA: red button */
  .inv-hero-split__card--light .inv-hero-split__card-cta,
  .inv-hero-split__card--white .inv-hero-split__card-cta,
  .inv-hero-split__card--outline .inv-hero-split__card-cta {
    color: #fff;
    background: #e11d26;
  }

  .inv-hero-split__card--light:hover .inv-hero-split__card-cta,
  .inv-hero-split__card--white:hover .inv-hero-split__card-cta,
  .inv-hero-split__card--outline:hover .inv-hero-split__card-cta {
    background: var(--inv-accent-hover);
  }

  .inv-hero-split__card--warning .inv-hero-split__card-cta {
    color: #1a1a1a;
    background: rgba(0, 0, 0, 0.1);
  }

  .inv-hero-split__card--warning:hover .inv-hero-split__card-cta {
    background: rgba(0, 0, 0, 0.18);
  }

  /* ============================================
     RESPONSIVE
     ============================================ */

  @media (max-width: 989px) {
    .inv-hero-split__container {
      grid-template-columns: 1fr;
    }

    .inv-hero-split__side {
      flex-direction: row;
    }

    .inv-hero-split__card {
      flex: 1;
    }

    .inv-hero-split__product-image {
      max-width: 180px;
    }
  }

  @media (max-width: 749px) {
    .inv-hero-split {
      padding: 0;
    }

    .inv-hero-split__container {
      padding: 0;
      gap: 0;
    }

    .inv-hero-split__slides {
      min-height: auto;
    }

    .inv-hero-split__slide {
      position: relative;
      inset: auto;
      width: 100%;
      height: auto;
      display: flex;
      flex-direction: column;
      text-align: center;
      padding: 0;
      min-height: auto;
      overflow: visible;
      background-image: none !important;
      background: #2d2d2d;
    }

    /* Hide inactive slides on mobile — keep them out of flow */
    .inv-hero-split__slide:not(.inv-hero-split__slide--active) {
      position: absolute;
      inset: 0;
      height: 0;
      overflow: hidden;
    }

    .inv-hero-split__main {
      min-height: auto;
      background: #2d2d2d;
    }

    .inv-hero-split__mobile-image {
      display: block !important;
      width: 100%;
      height: auto;
    }

    .inv-hero-split__content {
      display: block;
      max-width: 100%;
      padding: 16px 16px 12px;
      text-align: center;
    }

    .inv-hero-split__btn-wrap {
      position: static;
      text-align: center;
      padding: 0;
    }

    .inv-hero-split__btn {
      width: 100%;
      justify-content: center;
    }

    .inv-hero-split__heading {
      font-size: 22px;
    }

    .inv-hero-split__subheading {
      font-size: 14px;
    }

    .inv-hero-split__product-image {
      display: none;
      content-visibility: hidden;
      contain-intrinsic-size: 0;
    }

    .inv-hero-split__side {
      flex-direction: column;
    }

    .inv-hero-split__card {
      min-height: auto;
    }

    .inv-hero-split__card-body {
      padding: 14px 16px;
      gap: 6px;
    }

    .inv-hero-split__card-top-row {
      gap: 10px;
    }

    .inv-hero-split__card-icon-wrap {
      width: 32px;
      height: 32px;
    }

    .inv-hero-split__card-icon {
      width: 32px;
      height: 32px;
      border-radius: 0;
    }

    .inv-hero-split__card-icon svg {
      width: 16px;
      height: 16px;
    }

    .inv-hero-split__card-callout {
      font-size: 16px;
    }

    .inv-hero-split__card-content h3 {
      font-size: 12px;
    }

    .inv-hero-split__card-content p {
      font-size: 12px;
    }

    .inv-hero-split__card-cta {
      padding: 10px 16px;
      font-size: 12px;
      min-height: 44px;
    }

    .inv-hero-split__card-ribbon {
      top: 10px;
      right: -28px;
      font-size: 9px;
      padding: 3px 34px;
    }

    .inv-hero-split__card-bg img {
      display: none;
    }

    .inv-hero-split__card-shimmer {
      display: none;
    }

    .inv-hero-split__arrow {
      display: none;
    }

    .inv-hero-split__dots {
      padding: 8px 0;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .inv-hero-split__slide {
      transition: none;
    }

    .inv-hero-split__btn,
    .inv-hero-split__card,
    .inv-hero-split__card-cta,
    .inv-hero-split__card-cta svg,
    .inv-hero-split__card-bg img {
      transition: none;
    }

    .inv-hero-split__card:hover {
      transform: none;
    }

    .inv-hero-split__card:hover .inv-hero-split__card-shimmer::after {
      animation: none;
    }

    .inv-hero-split__card:hover .inv-hero-split__card-icon-wrap::after {
      animation: none;
    }

    .inv-hero-split__card:hover .inv-hero-split__card-bg img {
      transform: none;
    }
  }
</style>

<section class="inv-hero-split">
  <div class="inv-hero-split__container">

    {%- comment -%} MAIN HERO PANEL WITH SLIDESHOW {%- endcomment -%}
    <div class="inv-hero-split__main" data-hero-slideshow>
      <div class="inv-hero-split__slides{% if slide_count <= 1 %} inv-hero-split__slides--single{% endif %}">
        {%- assign slide_index = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'slide' -%}
            {%- assign slide_image = block.settings.image -%}
            {%- assign slide_heading = block.settings.heading -%}
            {%- assign slide_subheading = block.settings.subheading -%}
            {%- assign slide_button_text = block.settings.button_text -%}
            {%- assign slide_button_link = block.settings.button_link -%}
            {%- assign slide_btn_y = block.settings.button_position_y -%}
            {%- assign slide_btn_x = block.settings.button_position_x -%}

            <div
              class="inv-hero-split__slide{% if slide_index == 0 %} inv-hero-split__slide--active{% endif %}"
              {% if slide_image %}style="background-image: url('{{ slide_image | image_url: width: 1200 }}');"{% endif %}
              data-slide-index="{{ slide_index }}"
              {{ block.shopify_attributes }}
              role="group"
              aria-roledescription="slide"
              aria-label="Slide {{ slide_index | plus: 1 }} of {{ slide_count }}"
            >
              {%- if slide_image -%}
                <img
                  src="{{ slide_image | image_url: width: 800 }}"
                  srcset="{{ slide_image | image_url: width: 400 }} 400w,
                          {{ slide_image | image_url: width: 600 }} 600w,
                          {{ slide_image | image_url: width: 800 }} 800w"
                  sizes="(max-width: 749px) 100vw, 800px"
                  alt="{{ slide_heading | default: 'Hero image' | escape }}"
                  class="inv-hero-split__mobile-image"
                  {% if slide_index == 0 %}loading="eager" fetchpriority="high"{% else %}loading="lazy"{% endif %}
                  width="{{ slide_image.width }}"
                  height="{{ slide_image.height }}"
                >
              {%- endif -%}

              <div class="inv-hero-split__content">
                {%- if section.settings.badge_text != blank -%}
                  <span class="inv-hero-split__badge">{{ section.settings.badge_text }}</span>
                {%- endif -%}

                {%- if slide_heading != blank -%}
                  <h1 class="inv-hero-split__heading">{{ slide_heading }}</h1>
                {%- endif -%}

                {%- if slide_subheading != blank -%}
                  <p class="inv-hero-split__subheading">{{ slide_subheading }}</p>
                {%- endif -%}
              </div>

              {%- if slide_button_text != blank -%}
                <div class="inv-hero-split__btn-wrap" style="top: {{ slide_btn_y }}%; left: {{ slide_btn_x }}%;">
                  <a href="{{ slide_button_link }}" class="inv-hero-split__btn" style="font-size: {{ section.settings.button_font_size }}px; padding: {{ section.settings.button_padding_vertical }}px {{ section.settings.button_padding_horizontal }}px;{% if section.settings.button_bg_color != blank %} background: {{ section.settings.button_bg_color }};{% endif %}{% if section.settings.button_text_color != blank %} color: {{ section.settings.button_text_color }};{% endif %}">
                    {{ slide_button_text }}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                  </a>
                </div>
              {%- endif -%}
            </div>

            {%- assign slide_index = slide_index | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- comment -%} Arrow controls (hidden if single slide) {%- endcomment -%}
      {%- if slide_count > 1 -%}
        <button class="inv-hero-split__arrow inv-hero-split__arrow--prev" data-slide-prev aria-label="Previous slide">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M15 18l-6-6 6-6"/>
          </svg>
        </button>
        <button class="inv-hero-split__arrow inv-hero-split__arrow--next" data-slide-next aria-label="Next slide">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M9 18l6-6-6-6"/>
          </svg>
        </button>
      {%- endif -%}
    </div>

    {%- comment -%} Navigation dots (below main panel, hidden if single slide) {%- endcomment -%}
    {%- if slide_count > 1 -%}
      <div class="inv-hero-split__dots" data-slide-dots aria-label="Slide navigation" style="grid-column: 1;">
        {%- for i in (1..slide_count) -%}
          {%- assign dot_index = i | minus: 1 -%}
          <button
            class="inv-hero-split__dot{% if dot_index == 0 %} inv-hero-split__dot--active{% endif %}"
            data-slide-dot="{{ dot_index }}"
            aria-label="Go to slide {{ i }}"
          ></button>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} SIDEBAR PROMO CARDS — Bold Trade Banners {%- endcomment -%}
    <div class="inv-hero-split__side">
      {%- for block in section.blocks -%}
        {%- if block.type == 'promo_card' -%}
          {%- assign has_image = false -%}
          {%- if block.settings.card_image != blank -%}
            {%- assign has_image = true -%}
          {%- endif -%}

          <a
            href="{{ block.settings.link }}"
            class="inv-hero-split__card inv-hero-split__card--{{ block.settings.style }}{% if has_image %} inv-hero-split__card--has-image{% endif %}"
            {{ block.shopify_attributes }}
            aria-label="{{ block.settings.title | escape }}"
          >

            {%- comment -%} Background image layer {%- endcomment -%}
            {%- if has_image -%}
              <div class="inv-hero-split__card-bg">
                <img
                  src="{{ block.settings.card_image | image_url: width: 600 }}"
                  alt=""
                  role="presentation"
                  loading="lazy"
                  width="{{ block.settings.card_image.width }}"
                  height="{{ block.settings.card_image.height }}"
                >
              </div>
            {%- endif -%}

            {%- comment -%} Gradient overlay {%- endcomment -%}
            <div class="inv-hero-split__card-overlay"></div>

            {%- comment -%} Shimmer sweep {%- endcomment -%}
            <div class="inv-hero-split__card-shimmer"></div>

            {%- comment -%} Bold left accent stripe {%- endcomment -%}
            <div class="inv-hero-split__card-stripe"></div>

            {%- comment -%} Corner ribbon {%- endcomment -%}
            {%- if block.settings.ribbon_text != blank -%}
              <span class="inv-hero-split__card-ribbon">{{ block.settings.ribbon_text }}</span>
            {%- endif -%}

            {%- comment -%} Card body {%- endcomment -%}
            <div class="inv-hero-split__card-body">

              {%- comment -%} Icon + Callout row {%- endcomment -%}
              <div class="inv-hero-split__card-top-row">
                <div class="inv-hero-split__card-icon-wrap">
                  <div
                    class="inv-hero-split__card-icon"
                    {% if block.settings.custom_icon_bg != blank %}style="background: {{ block.settings.custom_icon_bg }};"{% endif %}
                  >
                    {%- assign icon_style = '' -%}
                    {%- if block.settings.custom_icon_color != blank -%}
                      {%- assign icon_style = 'style="color: ' | append: block.settings.custom_icon_color | append: ';"' -%}
                    {%- endif -%}
                    {%- case block.settings.icon -%}
                      {%- when 'tag' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" {{ icon_style }}>
                          <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/>
                          <line x1="7" y1="7" x2="7.01" y2="7"/>
                        </svg>
                      {%- when 'store' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" {{ icon_style }}>
                          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                          <polyline points="9 22 9 12 15 12 15 22"/>
                        </svg>
                      {%- when 'truck' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" {{ icon_style }}>
                          <rect x="1" y="3" width="15" height="13"/>
                          <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                          <circle cx="5.5" cy="18.5" r="2.5"/>
                          <circle cx="18.5" cy="18.5" r="2.5"/>
                        </svg>
                      {%- when 'percent' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" {{ icon_style }}>
                          <line x1="19" y1="5" x2="5" y2="19"/>
                          <circle cx="6.5" cy="6.5" r="2.5"/>
                          <circle cx="17.5" cy="17.5" r="2.5"/>
                        </svg>
                      {%- when 'clock' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" {{ icon_style }}>
                          <circle cx="12" cy="12" r="10"/>
                          <polyline points="12 6 12 12 16 14"/>
                        </svg>
                      {%- when 'gift' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" {{ icon_style }}>
                          <polyline points="20 12 20 22 4 22 4 12"/>
                          <rect x="2" y="7" width="20" height="5"/>
                          <line x1="12" y1="22" x2="12" y2="7"/>
                          <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/>
                          <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>
                        </svg>
                      {%- when 'zap' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" {{ icon_style }}>
                          <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                        </svg>
                      {%- when 'tool' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" {{ icon_style }}>
                          <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
                        </svg>
                      {%- when 'battery' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" {{ icon_style }}>
                          <rect x="2" y="7" width="16" height="10" rx="1"/>
                          <line x1="22" y1="11" x2="22" y2="13"/>
                          <line x1="6" y1="11" x2="6" y2="13"/>
                          <line x1="10" y1="11" x2="10" y2="13"/>
                        </svg>
                    {%- endcase -%}
                  </div>
                </div>

                {%- comment -%} Callout stat — the BIG visual anchor {%- endcomment -%}
                {%- if block.settings.callout_text != blank -%}
                  <div class="inv-hero-split__card-callout">{{ block.settings.callout_text }}</div>
                {%- endif -%}
              </div>

              {%- comment -%} Title & subtitle {%- endcomment -%}
              <div class="inv-hero-split__card-content">
                <h3 {% if block.settings.custom_title_color != blank %}style="color: {{ block.settings.custom_title_color }};"{% endif %}>{{ block.settings.title }}</h3>
                {%- if block.settings.text != blank -%}
                  <p {% if block.settings.custom_subtitle_color != blank %}style="color: {{ block.settings.custom_subtitle_color }}; opacity: 1;"{% endif %}>{{ block.settings.text }}</p>
                {%- endif -%}
              </div>
            </div>

            {%- comment -%} CTA Button {%- endcomment -%}
            <span class="inv-hero-split__card-cta">
              {{ block.settings.cta_text | default: 'Shop Now' }}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </span>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

{%- if slide_count > 1 -%}
<script>
  (function() {
    var container = document.querySelector('[data-hero-slideshow]');
    if (!container) return;

    var slides = container.querySelectorAll('[data-slide-index]');
    var dots = document.querySelectorAll('[data-slide-dot]');
    var prevBtn = container.querySelector('[data-slide-prev]');
    var nextBtn = container.querySelector('[data-slide-next]');
    var total = slides.length;
    var current = 0;
    var interval = null;
    var DELAY = 5000;

    function goTo(index) {
      slides[current].classList.remove('inv-hero-split__slide--active');
      if (dots[current]) dots[current].classList.remove('inv-hero-split__dot--active');
      current = ((index % total) + total) % total;
      slides[current].classList.add('inv-hero-split__slide--active');
      if (dots[current]) dots[current].classList.add('inv-hero-split__dot--active');
    }

    function next() { goTo(current + 1); }
    function prev() { goTo(current - 1); }

    function startAutoplay() {
      stopAutoplay();
      interval = setInterval(next, DELAY);
    }

    function stopAutoplay() {
      if (interval) { clearInterval(interval); interval = null; }
    }

    // Arrow buttons
    if (prevBtn) prevBtn.addEventListener('click', function() { prev(); startAutoplay(); });
    if (nextBtn) nextBtn.addEventListener('click', function() { next(); startAutoplay(); });

    // Dot buttons
    dots.forEach(function(dot) {
      dot.addEventListener('click', function() {
        goTo(parseInt(this.getAttribute('data-slide-dot'), 10));
        startAutoplay();
      });
    });

    // Pause on hover
    container.addEventListener('mouseenter', stopAutoplay);
    container.addEventListener('mouseleave', startAutoplay);

    // Keyboard navigation
    container.addEventListener('keydown', function(e) {
      if (e.key === 'ArrowLeft') { prev(); startAutoplay(); }
      if (e.key === 'ArrowRight') { next(); startAutoplay(); }
    });

    // Start
    startAutoplay();
  })();
</script>
{%- endif -%}

