{% comment %}
  ============================================================================
  INVICTA PAGE CONTENT v1.0 — Structured content shell for info / policy pages
  ============================================================================
  Drops a readable, branded content area onto any page. Renders the page's
  body content automatically when no blocks are added (so default Shopify
  pages get the new typography for free), or renders a stack of structured
  blocks when the merchant configures them.

  Block types:
    rich_text  — long-form copy with proper hierarchy and max-width
    callout    — coloured highlight box (info / warning / success / accent)
    key_value  — single label : value row (e.g. "Service: Royal Mail Tracked 24")
    accordion  — collapsible section using <details>; one item per block
    stat_row   — three stats side-by-side (e.g. "Years / Products / Branches")
    divider    — hairline rule between sections

  Trade 15.4.0 Compatible
  ============================================================================
{% endcomment %}

{%- liquid
  assign max_width = section.settings.max_width | default: 760
  assign bg = section.settings.background_color | default: '#ffffff'
  assign use_blocks = false
  if section.blocks.size > 0
    assign use_blocks = true
  endif
-%}

<section
  class="inv-page-content"
  id="page-content-{{ section.id }}"
>
  <div class="inv-page-content__container">
    {%- if use_blocks -%}
      {%- for block in section.blocks -%}
        {%- case block.type -%}

          {%- when 'rich_text' -%}
            <div class="inv-page-content__block inv-page-content__rte" {{ block.shopify_attributes }}>
              {{ block.settings.text }}
            </div>

          {%- when 'callout' -%}
            {%- assign tone = block.settings.tone | default: 'info' -%}
            <aside class="inv-page-content__block inv-callout inv-callout--{{ tone }}" {{ block.shopify_attributes }}>
              {%- if block.settings.icon != 'none' -%}
                <span class="inv-callout__icon" aria-hidden="true">
                  {%- case block.settings.icon -%}
                    {%- when 'info' -%}
                      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                    {%- when 'warning' -%}
                      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                    {%- when 'check' -%}
                      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    {%- when 'truck' -%}
                      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                    {%- when 'phone' -%}
                      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                  {%- endcase -%}
                </span>
              {%- endif -%}
              <div class="inv-callout__body">
                {%- if block.settings.heading != blank -%}
                  <h3 class="inv-callout__heading">{{ block.settings.heading | escape }}</h3>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <div class="inv-callout__text">{{ block.settings.text }}</div>
                {%- endif -%}
              </div>
            </aside>

          {%- when 'key_value' -%}
            <dl class="inv-page-content__block inv-kv" {{ block.shopify_attributes }}>
              <dt class="inv-kv__label">{{ block.settings.label | escape }}</dt>
              <dd class="inv-kv__value">{{ block.settings.value }}</dd>
            </dl>

          {%- when 'accordion' -%}
            <details
              class="inv-page-content__block inv-accordion{% if block.settings.open_default %} inv-accordion--open{% endif %}"
              {% if block.settings.open_default %}open{% endif %}
              {{ block.shopify_attributes }}
            >
              <summary class="inv-accordion__summary">
                <span class="inv-accordion__heading">{{ block.settings.heading | escape }}</span>
                <span class="inv-accordion__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true">
                    <polyline points="6 9 12 15 18 9"/>
                  </svg>
                </span>
              </summary>
              <div class="inv-accordion__panel">{{ block.settings.text }}</div>
            </details>

          {%- when 'stat_row' -%}
            <div class="inv-page-content__block inv-stat-row" {{ block.shopify_attributes }}>
              {%- if block.settings.stat_1_value != blank -%}
                <div class="inv-stat-row__item">
                  <span class="inv-stat-row__num">{{ block.settings.stat_1_value | escape }}</span>
                  <span class="inv-stat-row__label">{{ block.settings.stat_1_label | escape }}</span>
                </div>
              {%- endif -%}
              {%- if block.settings.stat_2_value != blank -%}
                <div class="inv-stat-row__item">
                  <span class="inv-stat-row__num">{{ block.settings.stat_2_value | escape }}</span>
                  <span class="inv-stat-row__label">{{ block.settings.stat_2_label | escape }}</span>
                </div>
              {%- endif -%}
              {%- if block.settings.stat_3_value != blank -%}
                <div class="inv-stat-row__item">
                  <span class="inv-stat-row__num">{{ block.settings.stat_3_value | escape }}</span>
                  <span class="inv-stat-row__label">{{ block.settings.stat_3_label | escape }}</span>
                </div>
              {%- endif -%}
            </div>

          {%- when 'divider' -%}
            <hr class="inv-page-content__block inv-divider" {{ block.shopify_attributes }}>

        {%- endcase -%}
      {%- endfor -%}
    {%- else -%}
      {%- comment -%} Auto-render the page's body content (default Shopify pages benefit from the new typography). {%- endcomment -%}
      <div class="inv-page-content__rte">
        {{ page.content }}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  #page-content-{{ section.id }} {
    background: {{ bg }};
    padding-top: {{ section.settings.padding_top | default: 32 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 64 }}px;
  }

  #page-content-{{ section.id }} .inv-page-content__container {
    max-width: {{ max_width }}px;
    margin: 0 auto;
    padding: 0 var(--inv-page-gutter, 1.5rem);
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* ---- Rich text ---- */
  #page-content-{{ section.id }} .inv-page-content__rte {
    font-size: 16px;
    line-height: 1.7;
    color: var(--inv-fg-secondary);
  }

  #page-content-{{ section.id }} .inv-page-content__rte > * + * {
    margin-top: 1em;
  }

  #page-content-{{ section.id }} .inv-page-content__rte h2,
  #page-content-{{ section.id }} .inv-page-content__rte h3,
  #page-content-{{ section.id }} .inv-page-content__rte h4 {
    color: var(--inv-fg);
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.01em;
    text-transform: none;
    margin-top: 1.6em;
  }

  #page-content-{{ section.id }} .inv-page-content__rte h2 { font-size: 26px; }
  #page-content-{{ section.id }} .inv-page-content__rte h3 { font-size: 20px; }
  #page-content-{{ section.id }} .inv-page-content__rte h4 { font-size: 17px; }

  #page-content-{{ section.id }} .inv-page-content__rte p { margin: 0; }

  #page-content-{{ section.id }} .inv-page-content__rte a {
    color: var(--inv-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  #page-content-{{ section.id }} .inv-page-content__rte a:hover {
    color: var(--inv-accent-hover);
  }

  #page-content-{{ section.id }} .inv-page-content__rte ul,
  #page-content-{{ section.id }} .inv-page-content__rte ol {
    padding-left: 1.4em;
  }

  #page-content-{{ section.id }} .inv-page-content__rte li + li {
    margin-top: 0.4em;
  }

  #page-content-{{ section.id }} .inv-page-content__rte strong { color: var(--inv-fg); }

  /* ---- Callout ---- */
  #page-content-{{ section.id }} .inv-callout {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 18px 20px;
    border-left: 4px solid var(--inv-accent);
    background: var(--inv-bg-soft);
  }

  #page-content-{{ section.id }} .inv-callout__icon {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--inv-accent);
    margin-top: 2px;
  }

  #page-content-{{ section.id }} .inv-callout__heading {
    font-size: 15px;
    font-weight: 800;
    color: var(--inv-fg);
    margin: 0 0 4px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  #page-content-{{ section.id }} .inv-callout__text {
    font-size: 15px;
    line-height: 1.55;
    color: var(--inv-fg-secondary);
  }

  #page-content-{{ section.id }} .inv-callout__text > * { margin: 0; }
  #page-content-{{ section.id }} .inv-callout__text > * + * { margin-top: 0.5em; }

  /* Tone variants */
  #page-content-{{ section.id }} .inv-callout--info {
    border-left-color: var(--inv-info);
    background: var(--inv-info-bg);
  }
  #page-content-{{ section.id }} .inv-callout--info .inv-callout__icon { color: var(--inv-info-dark); }

  #page-content-{{ section.id }} .inv-callout--warning {
    border-left-color: var(--inv-warning-dark);
    background: var(--inv-warning-bg);
  }
  #page-content-{{ section.id }} .inv-callout--warning .inv-callout__icon { color: var(--inv-warning-darker); }

  #page-content-{{ section.id }} .inv-callout--success {
    border-left-color: var(--inv-success);
    background: var(--inv-success-light);
  }
  #page-content-{{ section.id }} .inv-callout--success .inv-callout__icon { color: var(--inv-success-dark); }

  #page-content-{{ section.id }} .inv-callout--accent {
    border-left-color: var(--inv-accent);
    background: var(--inv-accent-soft);
  }
  #page-content-{{ section.id }} .inv-callout--accent .inv-callout__icon { color: var(--inv-accent); }

  /* ---- Key value ---- */
  #page-content-{{ section.id }} .inv-kv {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 8px 24px;
    margin: 0;
    padding: 14px 0;
    border-bottom: 1px solid var(--inv-border-subtle);
    font-size: 15px;
  }

  #page-content-{{ section.id }} .inv-kv__label {
    font-weight: 700;
    color: var(--inv-fg);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 13px;
  }

  #page-content-{{ section.id }} .inv-kv__value {
    color: var(--inv-fg-secondary);
    line-height: 1.55;
    margin: 0;
  }

  /* Stack consecutive key-values without doubling borders */
  #page-content-{{ section.id }} .inv-kv + .inv-kv {
    margin-top: -24px;
  }

  /* ---- Accordion ---- */
  #page-content-{{ section.id }} .inv-accordion {
    border: 1px solid var(--inv-border);
    background: var(--inv-bg-elevated);
  }

  #page-content-{{ section.id }} .inv-accordion__summary {
    list-style: none;
    cursor: pointer;
    padding: 16px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    color: var(--inv-fg);
    font-weight: 700;
    transition: background var(--inv-duration-normal) ease;
  }

  #page-content-{{ section.id }} .inv-accordion__summary::-webkit-details-marker { display: none; }
  #page-content-{{ section.id }} .inv-accordion__summary:hover { background: var(--inv-bg-soft); }

  #page-content-{{ section.id }} .inv-accordion__heading {
    font-size: 15px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  #page-content-{{ section.id }} .inv-accordion__icon {
    color: var(--inv-accent);
    transition: transform var(--inv-duration-normal) ease;
    flex-shrink: 0;
  }

  #page-content-{{ section.id }} .inv-accordion[open] .inv-accordion__icon {
    transform: rotate(180deg);
  }

  #page-content-{{ section.id }} .inv-accordion__panel {
    padding: 0 20px 20px;
    color: var(--inv-fg-secondary);
    line-height: 1.65;
    font-size: 15px;
  }

  #page-content-{{ section.id }} .inv-accordion__panel > * { margin: 0; }
  #page-content-{{ section.id }} .inv-accordion__panel > * + * { margin-top: 0.6em; }

  /* ---- Stat row ---- */
  #page-content-{{ section.id }} .inv-stat-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    border-top: 1px solid var(--inv-border-subtle);
    border-bottom: 1px solid var(--inv-border-subtle);
    padding: 24px 0;
  }

  #page-content-{{ section.id }} .inv-stat-row__item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
  }

  #page-content-{{ section.id }} .inv-stat-row__num {
    font-family: var(--inv-font-display);
    font-size: clamp(28px, 3.5vw, 40px);
    font-weight: 900;
    color: var(--inv-accent);
    line-height: 1;
  }

  #page-content-{{ section.id }} .inv-stat-row__label {
    font-size: 12px;
    font-weight: 700;
    color: var(--inv-fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* ---- Divider ---- */
  #page-content-{{ section.id }} .inv-divider {
    border: 0;
    border-top: 1px solid var(--inv-border-subtle);
    margin: 8px 0;
  }

  /* ---- Mobile ---- */
  @media (max-width: 749px) {
    #page-content-{{ section.id }} .inv-page-content__container {
      padding-left: var(--inv-mobile-gutter);
      padding-right: var(--inv-mobile-gutter);
      gap: 18px;
    }

    #page-content-{{ section.id }} .inv-kv {
      grid-template-columns: 1fr;
      gap: 4px;
    }

    #page-content-{{ section.id }} .inv-kv__label { font-size: 12px; }

    #page-content-{{ section.id }} .inv-kv + .inv-kv {
      margin-top: -10px;
    }

    #page-content-{{ section.id }} .inv-stat-row {
      grid-template-columns: 1fr 1fr;
      gap: 16px 12px;
    }

    #page-content-{{ section.id }} .inv-stat-row__item:nth-child(3) {
      grid-column: 1 / -1;
    }

    #page-content-{{ section.id }} .inv-callout { padding: 14px 16px; }
  }
</style>

{% schema %}
{
  "name": "Page Content",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "header", "content": "Layout" },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 640,
      "max": 1100,
      "step": 20,
      "unit": "px",
      "default": 760,
      "info": "Narrower widths are easier to read for long-form copy."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 8,
      "max": 96,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 24,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    { "type": "header", "content": "Empty state" },
    {
      "type": "paragraph",
      "content": "If you don't add any blocks below, the page's body content (set under Pages in the Shopify admin) is rendered automatically using these styles."
    }
  ],
  "blocks": [
    {
      "type": "rich_text",
      "name": "Rich text",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Add your content here.</p>"
        }
      ]
    },
    {
      "type": "callout",
      "name": "Callout box",
      "settings": [
        {
          "type": "select",
          "id": "tone",
          "label": "Tone",
          "default": "info",
          "options": [
            { "value": "info", "label": "Info (blue)" },
            { "value": "warning", "label": "Warning (amber)" },
            { "value": "success", "label": "Success (green)" },
            { "value": "accent", "label": "Accent (red)" }
          ]
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "info",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "info", "label": "Info" },
            { "value": "warning", "label": "Warning" },
            { "value": "check", "label": "Check" },
            { "value": "truck", "label": "Delivery truck" },
            { "value": "phone", "label": "Phone" }
          ]
        },
        { "type": "text", "id": "heading", "label": "Heading" },
        { "type": "richtext", "id": "text", "label": "Text" }
      ]
    },
    {
      "type": "key_value",
      "name": "Key / value row",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Service" },
        { "type": "richtext", "id": "value", "label": "Value", "default": "<p>Royal Mail Tracked 24</p>" }
      ]
    },
    {
      "type": "accordion",
      "name": "Accordion item",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Question or section title" },
        { "type": "richtext", "id": "text", "label": "Body" },
        {
          "type": "checkbox",
          "id": "open_default",
          "label": "Open by default",
          "default": false
        }
      ]
    },
    {
      "type": "stat_row",
      "name": "Stat row",
      "settings": [
        { "type": "text", "id": "stat_1_value", "label": "Stat 1 value", "default": "30+" },
        { "type": "text", "id": "stat_1_label", "label": "Stat 1 label", "default": "Years trading" },
        { "type": "text", "id": "stat_2_value", "label": "Stat 2 value", "default": "15,000+" },
        { "type": "text", "id": "stat_2_label", "label": "Stat 2 label", "default": "Products" },
        { "type": "text", "id": "stat_3_value", "label": "Stat 3 value", "default": "2" },
        { "type": "text", "id": "stat_3_label", "label": "Stat 3 label", "default": "Kent branches" }
      ]
    },
    {
      "type": "divider",
      "name": "Divider",
      "settings": []
    }
  ],
  "presets": [
    {
      "name": "Page Content"
    }
  ]
}
{% endschema %}
