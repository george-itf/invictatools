{% comment %}
  ============================================
  BRAND SCHEMA v1.2
  ============================================
  Zero-visual section — outputs JSON-LD only
  BreadcrumbList + WebPage/Brand structured data
  Trade 15.4.0 Compatible

  v1.2 changes:
  - Removed manufacturer: Organization and publisher: Organization blocks.
    The "JSON-LD for SEO" app emits Organisation schema for the shop, and
    having it here too produced duplicate Organisation entities in Google
    Rich Results (3× detected on brand pages). If that app is removed,
    restore these blocks from git history prior to this commit.

  v1.1 changes (retained):
  - Optional brand_logo, brand_image, brand_sameas settings so each brand
    page can emit unique logo, hero image, and social URLs.
  - WebPage emits primaryImageOfPage when brand_image is set.
  ============================================
{% endcomment %}

{%- comment -%} ===== Meta Description Fallback ===== {%- endcomment -%}
{%- unless page_description != blank -%}
  {%- if section.settings.brand_description != blank -%}
    <meta name="description" content="{{ section.settings.brand_description | strip_html | truncate: 160 | escape }}">
  {%- else -%}
    <meta name="description" content="Shop {{ section.settings.brand_name }} tools at Invicta Tools. Browse our range of professional {{ section.settings.brand_name }} power tools, accessories and consumables with trade prices and fast delivery.">
  {%- endif -%}
{%- endunless -%}

{%- comment -%} ===== BreadcrumbList Schema ===== {%- endcomment -%}
{%- if section.settings.brand_name != blank -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": {{ shop.url | json }}
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": {{ section.settings.parent_title | default: "Brands" | json }},
      "item": {{ shop.url | append: section.settings.parent_url | json }}
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": {{ section.settings.brand_name | json }}
    }
  ]
}
</script>

{%- comment -%}
  ===== WebPage + Brand Schema =====
  Per-brand uniqueness comes from template-level settings (brand_description,
  brand_founding_year, brand_country, brand_url) plus optional brand_logo,
  brand_image, and brand_sameas (one URL per line) for stronger signals.
{%- endcomment -%}
{%- liquid
  assign brand_logo_url = ''
  if section.settings.brand_logo != blank
    assign brand_logo_url = section.settings.brand_logo | image_url: width: 600 | prepend: 'https:'
  endif

  assign brand_image_url = ''
  assign brand_image_width = 1200
  assign brand_image_height = 0
  if section.settings.brand_image != blank
    comment
      Clamp requested width to source width so the CDN never upscales.
    endcomment
    if section.settings.brand_image.width < brand_image_width
      assign brand_image_width = section.settings.brand_image.width
    endif
    assign brand_image_url = section.settings.brand_image | image_url: width: brand_image_width | prepend: 'https:'
    assign brand_image_height = section.settings.brand_image.height | times: brand_image_width | divided_by: section.settings.brand_image.width | round
  endif

  assign sameas_list = section.settings.brand_sameas | default: '' | strip | newline_to_br | split: '<br />'
-%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": {{ page.title | json }},
  "url": {{ shop.url | append: page.url | json }},
  "description": {{ section.settings.brand_description | default: page.title | json }}
  {%- if brand_image_url != blank -%}
    ,"primaryImageOfPage": {
      "@type": "ImageObject",
      "url": {{ brand_image_url | json }},
      "width": {{ brand_image_width }},
      "height": {{ brand_image_height }}
    }
  {%- endif -%}
  ,"about": {
    "@type": "Brand",
    "name": {{ section.settings.brand_name | json }}
    {%- if section.settings.brand_description != blank -%}
      ,"description": {{ section.settings.brand_description | json }}
    {%- endif -%}
    {%- if section.settings.brand_url != blank -%}
      ,"url": {{ section.settings.brand_url | json }}
    {%- endif -%}
    {%- if brand_logo_url != blank -%}
      ,"logo": {{ brand_logo_url | json }}
    {%- endif -%}
    {%- if brand_image_url != blank -%}
      ,"image": {{ brand_image_url | json }}
    {%- endif -%}
    {%- if section.settings.brand_founding_year != blank -%}
      ,"foundingDate": {{ section.settings.brand_founding_year | json }}
    {%- endif -%}
    {%- assign sameas_comma = false -%}
    {%- capture sameas_json -%}
      {%- for raw in sameas_list -%}
        {%- assign cleaned = raw | strip -%}
        {%- if cleaned contains 'http' -%}
          {%- if sameas_comma -%},{%- endif -%}
          {{ cleaned | json }}
          {%- assign sameas_comma = true -%}
        {%- endif -%}
      {%- endfor -%}
    {%- endcapture -%}
    {%- if sameas_comma -%}
      ,"sameAs": [{{ sameas_json }}]
    {%- endif -%}
  }
}
</script>
{%- endif -%}
{%- comment -%}
  Deliberately no Organization manufacturer or publisher emission here —
  the "JSON-LD for SEO" app owns all Organization schema. Brand's country
  of origin is carried in brand_description natural-language text.
{%- endcomment -%}

{% schema %}
{
  "name": "Brand Schema",
  "tag": "section",
  "class": "section-brand-schema",
  "settings": [
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand Name"
    },
    {
      "type": "textarea",
      "id": "brand_description",
      "label": "Brand Description (SEO)"
    },
    {
      "type": "url",
      "id": "brand_url",
      "label": "Official Brand Website"
    },
    {
      "type": "text",
      "id": "brand_founding_year",
      "label": "Founding Year"
    },
    {
      "type": "text",
      "id": "brand_country",
      "label": "Country of Origin"
    },
    {
      "type": "image_picker",
      "id": "brand_logo",
      "label": "Brand logo",
      "info": "Square logo used in Brand.logo for rich-result eligibility."
    },
    {
      "type": "image_picker",
      "id": "brand_image",
      "label": "Brand hero image",
      "info": "Representative image. Used as WebPage.primaryImageOfPage and Brand.image."
    },
    {
      "type": "textarea",
      "id": "brand_sameas",
      "label": "Brand social & reference URLs",
      "info": "One full URL per line (https://…). Wikipedia, Facebook, Instagram, manufacturer hub, etc."
    },
    {
      "type": "text",
      "id": "parent_url",
      "label": "Parent Page URL",
      "default": "/pages/shop-by-brand"
    },
    {
      "type": "text",
      "id": "parent_title",
      "label": "Parent Page Title",
      "default": "Brands"
    }
  ],
  "presets": [
    {
      "name": "Brand Schema"
    }
  ]
}
{% endschema %}
