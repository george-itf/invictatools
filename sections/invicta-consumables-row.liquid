{% comment %}
  ============================================================================
  INVICTA CONSUMABLES ROW v1.0
  ============================================================================
  Curated consumables/accessories cross-sell for the current product.
  Reads from product metafield custom.consumables (JSON array of handles).
  Uses invicta-product-card snippet for cards.

  Sits between the main PDP section and Related Products.
  ============================================================================
{% endcomment %}

{{ 'invicta-consumables-row.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign consumables_json = product.metafields.custom.consumables
  if consumables_json == blank
    break
  endif

  assign consumable_handles = consumables_json | replace: '[', '' | replace: ']', '' | replace: '"', '' | split: ','
  assign consumable_count = 0
  for h in consumable_handles
    assign h_clean = h | strip
    if h_clean != blank
      assign test_product = all_products[h_clean]
      if test_product != blank and test_product.title != blank
        assign consumable_count = consumable_count | plus: 1
      endif
    endif
  endfor
-%}

{%- if consumable_count > 0 -%}
{%- style -%}
  #shopify-section-{{ section.id }} .inv-consumables {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .inv-consumables {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="inv-consumables">
  <div class="inv-consumables__container">
    <div class="inv-consumables__header">
      <h2 class="inv-consumables__title">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true" style="vertical-align: -3px; margin-right: 6px;">
          <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
        </svg>
        {{ section.settings.heading }}
      </h2>
    </div>
    <ul class="inv-consumables__grid" role="list">
      {%- assign card_idx = 0 -%}
      {%- for h in consumable_handles -%}
        {%- assign h_clean = h | strip -%}
        {%- if h_clean == blank -%}{%- continue -%}{%- endif -%}
        {%- assign consumable_product = all_products[h_clean] -%}
        {%- if consumable_product == blank or consumable_product.title == blank -%}{%- continue -%}{%- endif -%}
        {%- assign card_idx = card_idx | plus: 1 -%}
        {%- if card_idx > section.settings.products_to_show -%}{%- break -%}{%- endif -%}
        <li class="inv-consumables__item">
          {% render 'invicta-product-card', product: consumable_product, card_index: card_idx %}
        </li>
      {%- endfor -%}
    </ul>
  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Consumables Row",
  "tag": "section",
  "class": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Pros Usually Order With This"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Consumables Row"
    }
  ]
}
{% endschema %}
