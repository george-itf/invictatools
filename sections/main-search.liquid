{% comment %}
  ============================================================================
  INVICTA SEARCH PAGE v2.0
  ============================================================================
  Full search results page with collapsible filter panel.

  Features:
  ✓ Collapsible filter panel with accordion groups
  ✓ Brand filter (checkbox list with local search)
  ✓ Product Type filter (checkbox list with local search)
  ✓ Price range filter (min/max inputs)
  ✓ Availability filter (in-stock toggle)
  ✓ Active filter tags with remove
  ✓ AJAX filtering, sorting, pagination
  ✓ Extracted JS in invicta-search-page.js

  Trade 15.4.0 Compatible
  ============================================================================
{% endcomment %}

{%- liquid
  # ----------------------------------------
  # SETTINGS
  # ----------------------------------------
  assign products_per_page = section.settings.products_per_page
  assign show_sort = section.settings.show_sort
  assign show_filters = section.settings.show_filters
  assign show_price_filter = section.settings.show_price_filter
  assign show_availability_filter = section.settings.show_availability_filter
  assign filters_default_open = section.settings.filters_default_open

  # Grid columns
  assign cols_desktop = section.settings.columns_desktop
  assign cols_tablet = section.settings.columns_tablet
  assign cols_mobile = section.settings.columns_mobile
  assign grid_gap = section.settings.grid_gap

  # Spacing
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom

  # Card settings
  assign card_radius = section.settings.card_radius
  assign card_padding = section.settings.card_padding
  assign image_ratio = section.settings.image_ratio

  # Colours
  assign section_bg = section.settings.section_bg
  assign card_bg = section.settings.card_bg
  assign card_border = section.settings.card_border
  assign image_bg = section.settings.image_bg
  assign badge_bg = section.settings.badge_bg
  assign badge_text = section.settings.badge_text
  assign title_color = section.settings.title_color
  assign price_color = section.settings.price_color
  assign btn_primary_bg = section.settings.btn_primary_bg
  assign btn_primary_text = section.settings.btn_primary_text
  assign btn_secondary_bg = section.settings.btn_secondary_bg
  assign btn_secondary_text = section.settings.btn_secondary_text
  assign btn_secondary_border = section.settings.btn_secondary_border

  # ----------------------------------------
  # SEARCH STATE
  # ----------------------------------------
  assign sort_by = search.sort_by | default: search.default_sort_by
  assign search_terms = search.terms | escape

  # ----------------------------------------
  # DETECT ACTIVE FILTERS
  # ----------------------------------------
  assign has_active_filters = false
  assign total_active = 0
  assign active_price_gte = ''
  assign active_price_lte = ''
  assign active_availability = false
  assign active_types_count = 0

  for filter in search.filters
    if filter.param_name == 'filter.p.vendor' or filter.param_name == 'filter.p.product_type'
      if filter.active_values.size > 0
        assign has_active_filters = true
        assign total_active = total_active | plus: filter.active_values.size
      endif
      if filter.param_name == 'filter.p.product_type'
        assign active_types_count = filter.active_values.size
      endif
    endif

    if filter.param_name == 'filter.v.price'
      if filter.min_value.value != nil
        assign active_price_gte = filter.min_value.value | money_without_currency
        assign has_active_filters = true
        assign total_active = total_active | plus: 1
      endif
      if filter.max_value.value != nil
        assign active_price_lte = filter.max_value.value | money_without_currency
        assign has_active_filters = true
        assign total_active = total_active | plus: 1
      endif
    endif

    if filter.param_name == 'filter.v.availability'
      for value in filter.active_values
        if value.value == '1'
          assign active_availability = true
          assign has_active_filters = true
          assign total_active = total_active | plus: 1
        endif
      endfor
    endif
  endfor

  # ----------------------------------------
  # BUILD SORTED FILTER DATA
  # ----------------------------------------
  # Each filter's values array is sorted by count desc and partitioned
  # into active/inactive lists. Both the filter panel and the product-
  # type chip bar consume these directly — no string encoding / split
  # round-trip, so labels containing '|' are no longer a problem.
  assign has_brands = false
  assign has_types = false
  assign brand_active_values = empty
  assign brand_inactive_values = empty
  assign type_active_values = empty
  assign type_inactive_values = empty

  for filter in search.filters
    case filter.param_name
      when 'filter.p.vendor'
        assign brand_values_sorted = filter.values | sort: 'count' | reverse
        assign brand_active_values = brand_values_sorted | where: 'active', true
        assign brand_inactive_values = brand_values_sorted | where: 'active', false
        if brand_values_sorted.first and brand_values_sorted.first.count > 0
          assign has_brands = true
        endif
      when 'filter.p.product_type'
        assign type_values_sorted = filter.values | sort: 'count' | reverse
        assign type_active_values = type_values_sorted | where: 'active', true
        assign type_inactive_values = type_values_sorted | where: 'active', false
        if type_values_sorted.first and type_values_sorted.first.count > 0
          assign has_types = true
        endif
    endcase
  endfor
-%}

<div
  id="invicta-search"
  class="inv-search"
  data-section-id="{{ section.id }}"
  data-search-terms="{{ search_terms }}"
  data-sort-by="{{ sort_by }}"
  data-page="1"
  style="
    --inv-grid-columns: {{ cols_desktop }};
    --inv-grid-columns-tablet: {{ cols_tablet }};
    --inv-grid-columns-mobile: {{ cols_mobile }};
    --inv-grid-gap: {{ grid_gap }}px;
    --inv-padding-top: {{ padding_top }}px;
    --inv-padding-bottom: {{ padding_bottom }}px;
    --inv-section-bg: {{ section_bg }};
    --inv-card-bg: {{ card_bg }};
    --inv-card-border: {{ card_border }};
    --inv-card-radius: {{ card_radius }}px;
    --inv-card-padding: {{ card_padding }}px;
    --inv-image-bg: {{ image_bg }};
    --inv-image-ratio: {{ image_ratio }}%;
    --inv-badge-bg: {{ badge_bg }};
    --inv-badge-text: {{ badge_text }};
    --inv-title-color: {{ title_color }};
    --inv-price-color: {{ price_color }};
    --inv-btn-primary-bg: {{ btn_primary_bg }};
    --inv-btn-primary-text: {{ btn_primary_text }};
    --inv-btn-secondary-bg: {{ btn_secondary_bg }};
    --inv-btn-secondary-text: {{ btn_secondary_text }};
    --inv-btn-secondary-border: {{ btn_secondary_border }};
  "
>

  {%- comment -%} ========== SEARCH HEADER ========== {%- endcomment -%}
  <div class="inv-search__header">
    <div class="inv-search__container page-width">

      <h1 class="inv-search__title">
        {%- if search.performed -%}
          {%- if search_terms != blank -%}
            {{ 'invicta.search.results_for' | t: terms: search.terms }}
          {%- else -%}
            {{ 'invicta.search.all_products' | t }}
          {%- endif -%}
          {%- if search.results_count > 0 -%}
            <span class="inv-search__result-count">({{ search.results_count }} {% if search.results_count == 1 %}product{% else %}products{% endif %})</span>
          {%- endif -%}
        {%- else -%}
          {{ 'invicta.search.heading' | t }}
        {%- endif -%}
      </h1>

      {%- comment -%}
        Search Input — wired to the same Invicta predictive search system
        as the header (invicta-search.js). data-inv-predictive-search marks
        the wrapper; the JS iterates every instance on the page, so the
        header and the SERP share one codepath and the same dropdown UX
        (stock badges, ex-VAT pricing, recent searches, keyboard nav).
      {%- endcomment -%}
      <div
        class="inv-search__input-wrapper"
        {% if settings.predictive_search_enabled %}data-inv-predictive-search{% endif %}
      >
        <form action="{{ routes.search_url }}" method="get" role="search" class="inv-search__form">
          <input type="hidden" name="type" value="product">
          <input type="hidden" name="options[prefix]" value="last">

          <div class="inv-search__field">
            <label class="visually-hidden" for="inv-search-input">{{ 'general.search.search' | t }}</label>
            <input
              type="search"
              name="q"
              id="inv-search-input"
              class="inv-search__input"
              {% if settings.predictive_search_enabled %}data-inv-search-input{% endif %}
              value="{{ search.terms | escape }}"
              placeholder="{{ 'invicta.search.placeholder' | t }}"
              autocomplete="off"
              autocorrect="off"
              autocapitalize="off"
              spellcheck="false"
              {%- if settings.predictive_search_enabled -%}
                role="combobox"
                aria-expanded="false"
                aria-controls="inv-search-results-serp"
                aria-haspopup="listbox"
                aria-autocomplete="list"
              {%- endif -%}
            >

            <button type="submit" class="inv-search__submit" aria-label="{{ 'invicta.search.submit_label' | t }}">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true">
                <circle cx="11" cy="11" r="8"/>
                <path d="m21 21-4.35-4.35"/>
              </svg>
            </button>

            {%- comment -%}
              Clear stays as a link (not data-inv-search-clear) so the
              fallback behaviour is to navigate to a fresh /search — users
              on the SERP expect Clear to reset the URL, not just blank
              the input.
            {%- endcomment -%}
            {%- if search.terms != blank -%}
              <a href="{{ routes.search_url }}?type=product" class="inv-search__clear" aria-label="{{ 'invicta.search.clear_label' | t }}">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true">
                  <line x1="18" y1="6" x2="6" y2="18"/>
                  <line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
              </a>
            {%- endif -%}
          </div>

          {%- if settings.predictive_search_enabled -%}
            {%- comment -%} Portalled by invicta-search.js to #ps-root on init {%- endcomment -%}
            <div
              id="inv-search-results-serp"
              class="inv-search-results"
              data-inv-search-results
              role="listbox"
              aria-label="Search suggestions"
            ></div>
          {%- endif -%}
        </form>
      </div>

    </div>
  </div>

  {%- if search.performed -%}

    {%- comment -%}
      ========== FILTER PANEL ==========
      Single panel in the DOM. On desktop it renders as an inline accordion
      (toggled by .inv-filter-toggle); on mobile the same element becomes
      a bottom sheet (opened by .inv-filter-mobile-trigger), with the
      sheet head + foot shown only at mobile widths via CSS. JS keeps one
      aria-hidden state for both modes.
    {%- endcomment -%}
    {%- if show_filters and search.filters != empty -%}
      <div class="inv-search__filters-section">
        <div class="inv-search__container page-width">

          {%- comment -%} Desktop-only inline toggle {%- endcomment -%}
          <button
            type="button"
            class="inv-filter-toggle"
            data-filter-toggle
            aria-expanded="{% if filters_default_open %}true{% else %}false{% endif %}"
            aria-controls="inv-filter-panel"
          >
            <svg class="inv-filter-toggle__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true">
              <line x1="4" y1="6" x2="20" y2="6"/>
              <line x1="4" y1="12" x2="16" y2="12"/>
              <line x1="4" y1="18" x2="12" y2="18"/>
            </svg>
            <span>{{ 'invicta.search.filters' | t }}</span>
            {%- if total_active > 0 -%}
              <span class="inv-filter-toggle__badge">{{ total_active }}</span>
            {%- endif -%}
          </button>

          {%- comment -%} Unified filter panel (desktop inline / mobile bottom sheet) {%- endcomment -%}
          <div
            class="inv-filter-panel"
            id="inv-filter-panel"
            data-filter-panel
            aria-hidden="{% if filters_default_open %}false{% else %}true{% endif %}"
            aria-label="Filters"
          >
            {%- comment -%} Sheet header — hidden on desktop via CSS {%- endcomment -%}
            <div class="inv-filter-panel__sheet-head">
              <h2 class="inv-filter-panel__sheet-title">{{ 'invicta.search.filters' | t }}</h2>
              <button type="button" class="inv-filter-panel__sheet-close" data-filter-sheet-close aria-label="Close filters">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true">
                  <line x1="18" y1="6" x2="6" y2="18"/>
                  <line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
              </button>
            </div>

            {%- comment -%} Shared scrollable body {%- endcomment -%}
            <div class="inv-filter-panel__body">
              <div class="inv-filter-panel__grid">

                {%- comment -%} ---- BRAND FILTER ---- {%- endcomment -%}
                {%- if has_brands -%}
                  {%- render 'invicta-search-checkbox-filter',
                      filter_name: 'filter.p.vendor',
                      group_id: 'brand',
                      title_key: 'invicta.search.filter_brand',
                      search_key: 'invicta.search.filter_brands_search',
                      active_values: brand_active_values,
                      inactive_values: brand_inactive_values,
                      default_open: filters_default_open
                  -%}
                {%- endif -%}

                {%- comment -%} ---- PRODUCT TYPE FILTER ---- {%- endcomment -%}
                {%- if has_types -%}
                  {%- render 'invicta-search-checkbox-filter',
                      filter_name: 'filter.p.product_type',
                      group_id: 'type',
                      title_key: 'invicta.search.filter_type',
                      search_key: 'invicta.search.filter_types_search',
                      active_values: type_active_values,
                      inactive_values: type_inactive_values,
                      default_open: filters_default_open
                  -%}
                {%- endif -%}

                {%- comment -%} ---- PRICE RANGE FILTER ---- {%- endcomment -%}
                {%- if show_price_filter -%}
                  {%- render 'invicta-search-price-filter',
                      group_id: 'price',
                      active_price_gte: active_price_gte,
                      active_price_lte: active_price_lte,
                      default_open: filters_default_open,
                      search_filters: search.filters
                  -%}
                {%- endif -%}

                {%- comment -%} ---- AVAILABILITY FILTER ---- {%- endcomment -%}
                {%- if show_availability_filter -%}
                  {%- render 'invicta-search-availability-filter',
                      group_id: 'availability',
                      active_availability: active_availability,
                      default_open: filters_default_open,
                      search_filters: search.filters
                  -%}
                {%- endif -%}

              </div>
            </div>

            {%- comment -%} Sheet footer (Apply) — hidden on desktop via CSS {%- endcomment -%}
            <div class="inv-filter-panel__sheet-foot">
              <button type="button" class="inv-filter-panel__sheet-apply" data-filter-sheet-apply>
                Apply filters
              </button>
            </div>
          </div>

          {%- comment -%} ---- ACTIVE FILTER TAGS ---- {%- endcomment -%}
          {%- render 'invicta-search-active-tags',
              search_filters: search.filters,
              has_active_filters: has_active_filters
          -%}

        </div>
      </div>

      {%- comment -%}
        Mobile-only overlay + floating trigger. Both hidden on desktop
        via CSS. Overlay sits below the panel, clicks-through to close.
      {%- endcomment -%}
      <div class="inv-filter-sheet-overlay" data-filter-sheet-overlay aria-hidden="true"></div>

      <button type="button" class="inv-filter-mobile-trigger" data-filter-mobile-trigger aria-controls="inv-filter-panel" aria-label="Open filters">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true">
          <line x1="4" y1="6" x2="20" y2="6"/>
          <line x1="4" y1="12" x2="16" y2="12"/>
          <line x1="4" y1="18" x2="12" y2="18"/>
        </svg>
        <span class="inv-filter-mobile-trigger__text">{% if total_active > 0 %}Filters ({{ total_active }}){% else %}Filters{% endif %}</span>
        {%- if total_active > 0 -%}
          <span class="inv-filter-mobile-trigger__count">{{ total_active }}</span>
        {%- else -%}
          <span class="inv-filter-mobile-trigger__count" style="display:none">0</span>
        {%- endif -%}
      </button>
    {%- endif -%}

    {%- comment -%} ========== PRODUCT GRID ========== {%- endcomment -%}
    <div class="inv-search__grid" style="position: relative;">
      {%- comment -%} Loading progress bar {%- endcomment -%}
      <div class="inv-search__progress-bar" aria-hidden="true"></div>
      <div class="inv-search__container page-width">

        {%- paginate search.results by products_per_page -%}

          {%- comment -%} Product Type chip bar — quick-access tabs for the top product types in current results {%- endcomment -%}
          {%- if has_types and search.results_count > 0 -%}
            {%- assign chip_count = 0 -%}
            {%- assign chip_max = 6 -%}
            <div class="inv-type-chips" role="group" aria-label="Filter by product type" data-inv-type-chips>
              <button
                type="button"
                class="inv-type-chip{% if active_types_count == 0 %} inv-type-chip--active{% endif %}"
                data-type-chip
                data-type-value=""
                aria-pressed="{% if active_types_count == 0 %}true{% else %}false{% endif %}"
              >
                All types
              </button>
              {%- for value in type_active_values -%}
                {%- if value.count > 0 and chip_count < chip_max -%}
                  <button
                    type="button"
                    class="inv-type-chip inv-type-chip--active"
                    data-type-chip
                    data-type-value="{{ value.label | escape }}"
                    aria-pressed="true"
                  >
                    <span class="inv-type-chip__label">{{ value.label }}</span>
                    <span class="inv-type-chip__count">{{ value.count }}</span>
                  </button>
                  {%- assign chip_count = chip_count | plus: 1 -%}
                {%- endif -%}
              {%- endfor -%}
              {%- for value in type_inactive_values -%}
                {%- if value.count > 0 and chip_count < chip_max -%}
                  <button
                    type="button"
                    class="inv-type-chip"
                    data-type-chip
                    data-type-value="{{ value.label | escape }}"
                    aria-pressed="false"
                  >
                    <span class="inv-type-chip__label">{{ value.label }}</span>
                    <span class="inv-type-chip__count">{{ value.count }}</span>
                  </button>
                  {%- assign chip_count = chip_count | plus: 1 -%}
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- comment -%} Toolbar {%- endcomment -%}
          <div class="inv-grid__toolbar">
            <div class="inv-grid__toolbar-left">
              <p class="inv-grid__count" id="inv-product-count" aria-live="polite">
                {%- if search.results_count == 0 -%}
                  <strong>0</strong> {{ 'invicta.search.products' | t }}
                {%- elsif paginate.pages > 1 -%}
                  {%- assign range_start = paginate.current_offset | plus: 1 -%}
                  {%- assign range_end = paginate.current_offset | plus: paginate.items.size -%}
                  <strong>{{ search.results_count }}</strong> {{ 'invicta.search.products' | t }}
                  <span class="inv-grid__count-range">({{ 'invicta.search.showing_of' | t: start: range_start, end: range_end, total: search.results_count }})</span>
                {%- else -%}
                  <strong>{{ search.results_count }}</strong>
                  {% if search.results_count == 1 %}product{% else %}{{ 'invicta.search.products' | t }}{% endif %}
                {%- endif -%}
              </p>
            </div>

            {%- if show_sort and search.results_count > 0 -%}
              <div class="inv-grid__toolbar-right">
                <div class="inv-grid__sort">
                  <label for="inv-sort-select" class="inv-grid__sort-label">{{ 'invicta.search.sort_label' | t }}:</label>
                  <select id="inv-sort-select" class="inv-grid__sort-select" data-inv-sort-select>
                    {%- for option in search.sort_options -%}
                      <option value="{{ option.value }}" {% if sort_by == option.value %}selected{% endif %}>
                        {{ option.name }}
                      </option>
                    {%- endfor -%}
                  </select>
                </div>
              </div>
            {%- endif -%}
          </div>

          {%- comment -%} Loading overlay {%- endcomment -%}
          <div class="inv-grid__loading-overlay" aria-hidden="true">
            <svg class="inv-grid__spinner" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true">
              <circle cx="12" cy="12" r="10" stroke-opacity="0.2"/>
              <path d="M12 2a10 10 0 0 1 10 10" stroke-linecap="round"/>
            </svg>
            <span class="visually-hidden">Loading search results...</span>
          </div>

          {%- comment -%} Products {%- endcomment -%}
          <ul class="inv-grid__products" id="inv-product-list" role="list">
            {%- for item in search.results -%}
              {%- if item.object_type == 'product' -%}
                {%- assign ga4_index = forloop.index0 | plus: paginate.current_offset -%}
                <li
                  class="inv-grid__item"
                  data-ga4-item-id="{{ item.id }}"
                  data-ga4-item-name="{{ item.title | escape }}"
                  data-ga4-item-brand="{{ item.vendor | default: '' | escape }}"
                  data-ga4-item-category="{{ item.type | default: '' | escape }}"
                  data-ga4-item-price="{{ item.price | money_without_currency | replace: ',', '' }}"
                  data-ga4-item-index="{{ ga4_index }}"
                >
                  {%- render 'invicta-product-card',
                      product: item,
                      section_settings: section.settings,
                      card_index: forloop.index
                  -%}
                </li>
              {%- endif -%}
            {%- else -%}
              <li class="inv-grid__empty">
                <div class="inv-grid__empty-inner">
                  <svg class="inv-grid__empty-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" focusable="false" aria-hidden="true">
                    <circle cx="11" cy="11" r="8"/>
                    <path d="m21 21-4.35-4.35"/>
                  </svg>
                  <p class="inv-grid__empty-message">
                    {{ 'invicta.search.no_results' | t: query: search.terms }}
                  </p>
                  {%- if has_active_filters -%}
                    <p class="inv-grid__empty-hint">{{ 'invicta.search.no_results_filters' | t }}</p>
                    <button type="button" class="inv-grid__empty-link" data-clear-all-filters>
                      {{ 'invicta.search.clear_filters' | t }}
                    </button>
                  {%- else -%}
                    <p class="inv-grid__empty-hint">{{ 'invicta.search.no_results_search' | t }}</p>
                  {%- endif -%}
                  <a href="/collections/all" class="inv-grid__empty-browse">
                    {{ 'invicta.search.browse_all' | t }}
                  </a>
                </div>
              </li>
            {%- endfor -%}
          </ul>

          {%- comment -%} Pagination {%- endcomment -%}
          {%- if paginate.pages > 1 -%}
            <nav class="inv-grid__pagination" aria-label="Search results pagination">
              <div class="inv-pagination">

                {%- if paginate.previous -%}
                  <a href="{{ paginate.previous.url }}" class="inv-pagination__btn inv-pagination__btn--prev" data-inv-page-link aria-label="{{ 'invicta.search.prev_page' | t }}">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
                    <span>{{ 'invicta.search.prev' | t }}</span>
                  </a>
                {%- else -%}
                  <span class="inv-pagination__btn inv-pagination__btn--prev inv-pagination__btn--disabled" aria-disabled="true">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
                    <span>{{ 'invicta.search.prev' | t }}</span>
                  </span>
                {%- endif -%}

                {%- comment -%} Desktop page numbers {%- endcomment -%}
                <div class="inv-pagination__pages">
                  {%- for part in paginate.parts -%}
                    {%- if part.is_link -%}
                      <a href="{{ part.url }}" class="inv-pagination__page" data-inv-page-link aria-label="Page {{ part.title }}">{{ part.title }}</a>
                    {%- else -%}
                      {%- if part.title == paginate.current_page -%}
                        <span class="inv-pagination__page inv-pagination__page--current" aria-current="page">{{ part.title }}</span>
                      {%- else -%}
                        <span class="inv-pagination__page inv-pagination__page--gap" aria-hidden="true">{{ part.title }}</span>
                      {%- endif -%}
                    {%- endif -%}
                  {%- endfor -%}
                </div>

                {%- comment -%} Mobile page indicator {%- endcomment -%}
                <div class="inv-pagination__mobile-info" role="status">
                  Page {{ paginate.current_page }} of {{ paginate.pages }}
                </div>

                {%- if paginate.next -%}
                  <a href="{{ paginate.next.url }}" class="inv-pagination__btn inv-pagination__btn--next" data-inv-page-link aria-label="{{ 'invicta.search.next_page' | t }}">
                    <span>{{ 'invicta.search.next' | t }}</span>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                  </a>
                {%- else -%}
                  <span class="inv-pagination__btn inv-pagination__btn--next inv-pagination__btn--disabled" aria-disabled="true">
                    <span>{{ 'invicta.search.next' | t }}</span>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                  </span>
                {%- endif -%}

              </div>
            </nav>
          {%- endif -%}

        {%- endpaginate -%}

      </div>
    </div>

  {%- else -%}

    {%- comment -%} No search performed yet {%- endcomment -%}
    <div class="inv-search__placeholder">
      <div class="inv-search__container page-width">
        <div class="inv-search__placeholder-inner">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.5" focusable="false" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.35-4.35"/>
          </svg>
          <p>{{ 'invicta.search.enter_term' | t }}</p>
        </div>
      </div>
    </div>

  {%- endif -%}

  <div class="visually-hidden" aria-live="assertive" id="inv-search-announce"></div>

  {%- comment -%} GA4 search context — consumed by invicta-ga4-events.js on load and after AJAX swaps {%- endcomment -%}
  <script type="application/json" data-inv-ga4-search>
    {
      "term": {{ search.terms | default: '' | json }},
      "performed": {{ search.performed | json }},
      "results_count": {{ search.results_count | default: 0 }},
      "sort_by": {{ sort_by | default: '' | json }},
      "active_filters_count": {{ total_active | default: 0 }}
    }
  </script>

</div>

{{ 'section-main-search.css' | asset_url | stylesheet_tag }}
<script src="{{ 'invicta-search-page.js' | asset_url }}" defer></script>

