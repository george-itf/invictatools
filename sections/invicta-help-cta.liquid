{% comment %}
  ============================================================================
  INVICTA HELP CTA v1.0 — Continuity "Need help?" callout
  ============================================================================
  Designed to sit at the foot of policy / info pages (About, Refund,
  Privacy, Terms, Shipping). Reuses the callout visual language from
  invicta-page-content — white card, red left border, on a soft grey
  band — paired with a red primary CTA button. Provides every long-read
  page with a consistent "next step" pointing to Contact.

  Trade 15.4.0 Compatible
  ============================================================================
{% endcomment %}

{%- liquid
  assign cta_link = section.settings.cta_link
  if cta_link == blank
    assign cta_link = '/pages/contact-us'
  endif
  assign max_width = section.settings.max_width | default: 760
-%}

<section class="inv-help-cta" id="help-cta-{{ section.id }}">
  <div class="inv-help-cta__container">
    <div class="inv-help-cta__card">
      <div class="inv-help-cta__text">
        {%- if section.settings.eyebrow != blank -%}
          <span class="inv-help-cta__eyebrow">{{ section.settings.eyebrow | escape }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="inv-help-cta__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          <p class="inv-help-cta__sub">{{ section.settings.text | escape }}</p>
        {%- endif -%}
      </div>
      {%- if section.settings.cta_text != blank -%}
        <a href="{{ cta_link }}" class="inv-help-cta__btn">
          {{ section.settings.cta_text | escape }}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  #help-cta-{{ section.id }} {
    background: {{ section.settings.background_color | default: '#f5f5f6' }};
    padding-top: {{ section.settings.padding_top | default: 24 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 64 }}px;
  }

  #help-cta-{{ section.id }} .inv-help-cta__container {
    max-width: {{ max_width }}px;
    margin: 0 auto;
    padding: 0 var(--inv-page-gutter, 1.5rem);
  }

  #help-cta-{{ section.id }} .inv-help-cta__card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 22px 28px;
    background: var(--inv-bg-elevated);
    border-left: 4px solid var(--inv-accent);
    flex-wrap: wrap;
  }

  #help-cta-{{ section.id }} .inv-help-cta__text {
    flex: 1;
    min-width: 220px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  #help-cta-{{ section.id }} .inv-help-cta__eyebrow {
    font-size: 11px;
    font-weight: 800;
    color: var(--inv-accent);
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }

  #help-cta-{{ section.id }} .inv-help-cta__heading {
    font-size: clamp(18px, 2vw, 22px);
    font-weight: 800;
    color: var(--inv-fg);
    margin: 0;
    line-height: 1.25;
  }

  #help-cta-{{ section.id }} .inv-help-cta__sub {
    font-size: 14px;
    color: var(--inv-fg-muted);
    line-height: 1.55;
    margin: 0;
  }

  #help-cta-{{ section.id }} .inv-help-cta__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 13px 26px;
    background: var(--inv-accent);
    color: var(--inv-bg-elevated);
    font-size: 13px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-decoration: none;
    border-radius: 0;
    flex-shrink: 0;
    transition: background var(--inv-duration-normal) ease;
  }

  #help-cta-{{ section.id }} .inv-help-cta__btn:hover { background: var(--inv-accent-hover); }
  #help-cta-{{ section.id }} .inv-help-cta__btn:focus-visible {
    outline: 2px solid var(--inv-accent);
    outline-offset: 2px;
  }

  #help-cta-{{ section.id }} .inv-help-cta__btn svg {
    transition: transform var(--inv-duration-normal) ease;
  }

  #help-cta-{{ section.id }} .inv-help-cta__btn:hover svg {
    transform: translateX(3px);
  }

  @media (max-width: 749px) {
    #help-cta-{{ section.id }} .inv-help-cta__container {
      padding-left: var(--inv-mobile-gutter);
      padding-right: var(--inv-mobile-gutter);
    }

    #help-cta-{{ section.id }} .inv-help-cta__card {
      padding: 18px 20px;
      flex-direction: column;
      align-items: flex-start;
    }

    #help-cta-{{ section.id }} .inv-help-cta__btn {
      align-self: stretch;
      justify-content: center;
    }
  }
</style>

{% schema %}
{
  "name": "Help CTA",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "header", "content": "Content" },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Need help?"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Got a question we haven't covered?"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Sub text",
      "default": "Drop us a line and we'll get back to you fast."
    },
    { "type": "header", "content": "Call to action" },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "Contact us"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link",
      "info": "Defaults to /pages/contact-us if left blank."
    },
    { "type": "header", "content": "Layout" },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 640,
      "max": 1100,
      "step": 20,
      "unit": "px",
      "default": 760,
      "info": "Match the body content section above for clean alignment."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour",
      "default": "#f5f5f6"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 16,
      "max": 96,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "Help CTA"
    }
  ]
}
{% endschema %}
