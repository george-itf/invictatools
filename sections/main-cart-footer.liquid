{%- comment -%}
  Cart Footer — AJAX data source
  ===============================
  This section is kept in the DOM so cart.js getSectionsToRender()
  can find #main-cart-footer and update .js-contents via AJAX.
  The visual layout is handled by the sidebar in main-cart-items.
  On desktop this is visually hidden. On mobile it provides the
  sticky bottom checkout bar.
{%- endcomment -%}

<div
  class="inv-cart-footer-source gradient color-{{ section.settings.color_scheme }}{% if cart == empty %} is-empty{% endif %}"
  id="main-cart-footer"
  data-id="{{ section.id }}"
>
  <div class="js-contents">
    <div class="page-width">
      <div class="inv-cart-footer-mobile">

        {%- comment -%} Mobile sticky bottom bar: total + checkout {%- endcomment -%}
        <div class="inv-cart-footer-mobile__total">
          <span class="inv-cart-footer-mobile__label">Total</span>
          <span class="inv-cart-footer-mobile__price">{{ cart.total_price | money_with_currency }}</span>
        </div>

        <button
          type="submit"
          class="inv-cart-footer-mobile__checkout-btn"
          name="checkout"
          {% if cart == empty %}disabled{% endif %}
          form="cart"
        >
          {{ 'sections.cart.checkout' | t }}
        </button>

        {%- comment -%} Hidden breakdown for AJAX update source {%- endcomment -%}
        <div class="inv-cart-footer-mobile__breakdown" aria-hidden="true">
          {%- if cart.cart_level_discount_applications.size > 0 -%}
            <ul class="discounts list-unstyled" role="list" aria-label="{{ 'customer.order.discount' | t }}">
              {%- for discount in cart.cart_level_discount_applications -%}
                <li class="discounts__discount discounts__discount--position">
                  {{- 'icon-discount.svg' | inline_asset_content -}}
                  {{ discount.title | escape }}
                  (-{{ discount.total_allocated_amount | money }})
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
          {% render 'cart-breakdown', cart: cart %}
        </div>

      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Cart Footer",
  "class": "cart__footer-wrapper",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Colour scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "subtotal",
      "name": "Subtotal",
      "limit": 1
    },
    {
      "type": "buttons",
      "name": "Checkout buttons",
      "limit": 1
    },
    {
      "type": "@app"
    }
  ]
}
{% endschema %}
