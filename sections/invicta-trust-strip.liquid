{% comment %}
  ============================================================================
  INVICTA TRUST STRIP v1.0 — Red accent USP bar
  ============================================================================
  Red background trust strip with circle icons and dividers.
  Designed for homepage use below the hero.

  Trade 15.4.0 Compatible
  Usage: Add via theme editor or templates/index.json
  ============================================================================
{% endcomment %}

<section class="inv-trust-strip" id="trust-strip-{{ section.id }}">
  <div class="inv-trust-strip__container">
    <ul class="inv-trust-strip__list" role="list">
      {%- for block in section.blocks -%}
        <li class="inv-trust-strip__item" {{ block.shopify_attributes }}>
          {%- if block.settings.icon != 'none' -%}
            <div class="inv-trust-strip__icon" aria-hidden="true">
              {%- case block.settings.icon -%}
                {%- when 'truck' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <rect x="1" y="3" width="15" height="13"/>
                    <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                    <circle cx="5.5" cy="18.5" r="2.5"/>
                    <circle cx="18.5" cy="18.5" r="2.5"/>
                  </svg>
                {%- when 'shield' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    <polyline points="9 12 11 14 15 10"/>
                  </svg>
                {%- when 'location' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                {%- when 'phone' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                  </svg>
                {%- when 'clock' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12 6 12 12 16 14"/>
                  </svg>
                {%- when 'tag' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/>
                    <line x1="7" y1="7" x2="7.01" y2="7"/>
                  </svg>
                {%- when 'check' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                    <polyline points="22 4 12 14.01 9 11.01"/>
                  </svg>
                {%- when 'award' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <circle cx="12" cy="8" r="7"/>
                    <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/>
                  </svg>
                {%- when 'store' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                    <polyline points="9 22 9 12 15 12 15 22"/>
                  </svg>
              {%- endcase -%}
            </div>
          {%- endif -%}

          <div class="inv-trust-strip__text">
            {%- if block.settings.title != blank -%}
              <strong class="inv-trust-strip__title">{{ block.settings.title }}</strong>
            {%- endif -%}
            {%- if block.settings.subtitle != blank -%}
              <span class="inv-trust-strip__subtitle">{{ block.settings.subtitle }}</span>
            {%- endif -%}
          </div>
        </li>
      {%- endfor -%}
    </ul>
  </div>
</section>

<style>
  /* ============================================================================
     INVICTA TRUST STRIP v1.0 — Red accent USP bar
     ============================================================================ */

  #trust-strip-{{ section.id }} {
    background: var(--inv-accent);
    padding-top: {{ section.settings.padding_top | default: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 0 }}px;
  }

  #trust-strip-{{ section.id }} .inv-trust-strip__container {
    max-width: var(--inv-container, 1400px);
    margin: 0 auto;
    padding: 0 var(--inv-space-xl);
  }

  #trust-strip-{{ section.id }} .inv-trust-strip__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
  }

  /* --- Item --- */
  #trust-strip-{{ section.id }} .inv-trust-strip__item {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: var(--inv-space-sm-plus);
    padding: 14px 20px;
    position: relative;
  }

  /* Borders: bottom on mobile */
  #trust-strip-{{ section.id }} .inv-trust-strip__item:not(:last-child) {
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
  }

  /* --- Circle icon --- */
  #trust-strip-{{ section.id }} .inv-trust-strip__icon {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  #trust-strip-{{ section.id }} .inv-trust-strip__icon svg {
    width: 16px;
    height: 16px;
    color: var(--inv-bg-elevated);
  }

  /* --- Text --- */
  #trust-strip-{{ section.id }} .inv-trust-strip__text {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  #trust-strip-{{ section.id }} .inv-trust-strip__title {
    font-size: 13px;
    font-weight: 700;
    color: var(--inv-bg-elevated);
    line-height: 1.2;
  }

  #trust-strip-{{ section.id }} .inv-trust-strip__subtitle {
    font-size: 11px;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.3;
  }

  /* ----------------------------------------
     TABLET (750px+): 2-column grid
     ---------------------------------------- */
  @media (min-width: 750px) {
    #trust-strip-{{ section.id }} .inv-trust-strip__list {
      grid-template-columns: repeat(2, 1fr);
    }

    /* Switch to right border on tablet */
    #trust-strip-{{ section.id }} .inv-trust-strip__item:not(:last-child) {
      border-bottom: none;
    }

    #trust-strip-{{ section.id }} .inv-trust-strip__item:nth-child(odd):not(:last-child) {
      border-right: 1px solid rgba(255, 255, 255, 0.15);
    }

    /* Bottom borders for first row */
    #trust-strip-{{ section.id }} .inv-trust-strip__item:nth-child(1),
    #trust-strip-{{ section.id }} .inv-trust-strip__item:nth-child(2) {
      border-bottom: 1px solid rgba(255, 255, 255, 0.15);
    }
  }

  /* ----------------------------------------
     DESKTOP (990px+): 4-column grid
     ---------------------------------------- */
  @media (min-width: 990px) {
    #trust-strip-{{ section.id }} .inv-trust-strip__list {
      grid-template-columns: repeat(4, 1fr);
    }

    /* Reset tablet borders */
    #trust-strip-{{ section.id }} .inv-trust-strip__item:nth-child(1),
    #trust-strip-{{ section.id }} .inv-trust-strip__item:nth-child(2) {
      border-bottom: none;
    }

    #trust-strip-{{ section.id }} .inv-trust-strip__item:nth-child(odd):not(:last-child) {
      border-right: none;
    }

    /* Right border dividers between items */
    #trust-strip-{{ section.id }} .inv-trust-strip__item:not(:last-child) {
      border-right: 1px solid rgba(255, 255, 255, 0.15);
    }
  }

  /* ----------------------------------------
     REDUCED MOTION
     ---------------------------------------- */
  @media (prefers-reduced-motion: reduce) {
    #trust-strip-{{ section.id }} .inv-trust-strip__item {
      transition: none;
    }
  }
</style>

{% schema %}
{
  "name": "Trust Strip",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "usp",
      "name": "USP",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "truck",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "truck", "label": "Delivery truck" },
            { "value": "shield", "label": "Shield / Warranty" },
            { "value": "location", "label": "Location pin" },
            { "value": "phone", "label": "Phone" },
            { "value": "clock", "label": "Clock" },
            { "value": "tag", "label": "Price tag" },
            { "value": "check", "label": "Checkmark" },
            { "value": "award", "label": "Award" },
            { "value": "store", "label": "Store" }
          ]
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Free Next-Day Delivery"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "On orders over £30"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Strip",
      "blocks": [
        {
          "type": "usp",
          "settings": {
            "icon": "truck",
            "title": "Free Next-Day Delivery",
            "subtitle": "On orders over £30"
          }
        },
        {
          "type": "usp",
          "settings": {
            "icon": "shield",
            "title": "Authorised Dealer",
            "subtitle": "Full manufacturer warranty"
          }
        },
        {
          "type": "usp",
          "settings": {
            "icon": "location",
            "title": "Click & Collect",
            "subtitle": "Ready in 1 hour"
          }
        },
        {
          "type": "usp",
          "settings": {
            "icon": "phone",
            "title": "Hassle-Free Returns",
            "subtitle": "30-day returns policy"
          }
        }
      ]
    }
  ]
}
{% endschema %}
