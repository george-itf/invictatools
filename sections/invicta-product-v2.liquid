              </svg>
              Compare with similar models
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
            </button>
          {%- endif -%}

