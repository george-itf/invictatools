                assign manual_url = product.metafields.custom.manual_url
              -%}
              <div class="inv-pdp__warranty-card-row">
                <span class="inv-pdp__warranty-card-label">Warranty</span>
                <span class="inv-pdp__warranty-card-value">
                  {%- if warranty_period != blank -%}
