{% comment %}
  ============================================
  INVICTA PRODUCT V2 — SECTION TEMPLATE
  Version: 3.0.0 — Full rebuild with fixes
  
  Changelog from 2.4.0:
  - FIXED: VAT toggle data attributes aligned
  - FIXED: Buy Now goes to checkout (not cart)
  - FIXED: Cart drawer opens after add
  - FIXED: Single description with CSS reorder
  - FIXED: Removed inline onclick handlers
  - FIXED: Buy Now disabled when out of stock
  - FIXED: Keyboard navigation for gallery
  - FIXED: aria-live for price announcements
  - ADDED: More schema settings
  - ADDED: Focus-visible states throughout
  - CLEANED: Removed unnecessary code
  
  Uses .inv-pdp__* prefix to avoid conflicts
  ============================================
{% endcomment %}

{%- comment -%}
  Critical CSS inlined for fast FCP. Full styles loaded async below.
{%- endcomment -%}
{% render 'critical-pdp-css' %}
<link rel="stylesheet" href="{{ 'invicta-product-v2.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'section-invicta-product-v2.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'section-invicta-product-mobile.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>
  {{ 'invicta-product-v2.css' | asset_url | stylesheet_tag }}
  {{ 'section-invicta-product-v2.css' | asset_url | stylesheet_tag }}
  {{ 'section-invicta-product-mobile.css' | asset_url | stylesheet_tag }}
</noscript>

{% liquid
  comment
    ============================
    CORE PRODUCT DATA
    ============================
  endcomment
  assign current_variant = product.selected_or_first_available_variant
  assign featured_image = current_variant.featured_image | default: product.featured_image

  comment
    Cache metafield lookups — avoids repeated evaluation
  endcomment
  assign mf_voltage = product.metafields.custom.voltage
  assign mf_max_torque = product.metafields.custom.max_torque
  assign mf_motor_type = product.metafields.custom.motor_type
  assign mf_features = product.metafields.custom.features

  comment
    Additional spec metafields for inline spec strip (Gate 3)
  endcomment
  assign mf_disc_diameter = product.metafields.custom.disc_diameter
  assign mf_no_load_speed = product.metafields.custom.no_load_speed
  assign mf_weight_body = product.metafields.custom.weight_body_only

  comment
    Kit options metafield (Gate 4)
  endcomment
  assign mf_kit_options = product.metafields.custom.kit_options
  assign has_kit_options = false
  if mf_kit_options != blank
    assign has_kit_options = true
  endif

  comment
    Comparison products metafield (Gate 6)
  endcomment
  assign mf_comparison = product.metafields.custom.comparison_products
  assign comparison_count = 0
  if mf_comparison != blank
    assign comp_handles = mf_comparison | replace: '[', '' | replace: ']', '' | replace: '"', '' | split: ','
    for ch in comp_handles
      assign ch_clean = ch | strip
      if ch_clean != blank
        assign comparison_count = comparison_count | plus: 1
      endif
    endfor
  endif

  comment
    Compare price logic
  endcomment
  assign has_compare_price = false
  if current_variant.compare_at_price > current_variant.price
    assign has_compare_price = true
  endif
  
  comment
    Price ex VAT — uses centralised VAT rate from theme settings
    Integer-safe rounding: times: 100 | plus: rounding | divided_by: divisor
  endcomment
  assign inv_vat_divisor = 100 | plus: settings.inv_vat_rate
  assign inv_vat_rounding = inv_vat_divisor | divided_by: 2
  assign price_ex_vat = current_variant.price | times: 100 | plus: inv_vat_rounding | divided_by: inv_vat_divisor
  assign compare_ex_vat = current_variant.compare_at_price | times: 100 | plus: inv_vat_rounding | divided_by: inv_vat_divisor
  
  comment
    Discount percentage
  endcomment
  assign discount_percent = 0
  if has_compare_price
    assign discount_amount = current_variant.compare_at_price | minus: current_variant.price
    assign discount_percent = discount_amount | times: 100.0 | divided_by: current_variant.compare_at_price | round
  endif
  
  comment
    Stock status + low-stock indicator
  endcomment
  assign is_in_stock = current_variant.available
  assign stock_qty = current_variant.inventory_quantity | default: 0
  assign low_stock_threshold = section.settings.low_stock_threshold | default: 5
  assign show_low_stock = false
  if is_in_stock and current_variant.inventory_management == 'shopify' and stock_qty <= low_stock_threshold and stock_qty > 0
    assign show_low_stock = true
  endif

  comment
    Fulfillment source + brand detection — single tag loop
    invicta-stock = held in our warehouse (ships same/next day)
    trend-stock / toolbank-stock / timco-stock / pdp-stock = held by supplier (longer lead)
    brand-* tags = brand detected from tags
    Priority: invicta-stock wins if present (ships faster)
  endcomment
  assign stock_source = 'invicta'
  assign supplier_key = ''
  assign product_brand = ''
  for tag in product.tags
    assign tag_lower = tag | downcase | strip
    if tag_lower == 'invicta-stock'
      assign stock_source = 'invicta'
      assign supplier_key = ''
      break
    elsif tag_lower == 'trend-stock'
      assign stock_source = 'supplier'
      assign supplier_key = 'trend'
    elsif tag_lower == 'toolbank-stock'
      assign stock_source = 'supplier'
      assign supplier_key = 'toolbank'
    elsif tag_lower == 'timco-stock'
      assign stock_source = 'supplier'
      assign supplier_key = 'timco'
    elsif tag_lower == 'pdp-stock'
      assign stock_source = 'supplier'
      assign supplier_key = 'pdp'
    endif
    if tag_lower contains 'brand-'
      assign product_brand = tag_lower | remove: 'brand-'
    endif
  endfor

  comment
    Resolve per-supplier text from section blocks (falls back to generic defaults).
    Each "supplier_config" block carries a supplier_key plus its 3 text fields.
    If no block matches the current supplier_key the defaults below are used.
  endcomment
  assign supplier_banner_text = section.settings.supplier_stock_text | default: 'In Stock with Supplier — Usually Dispatched within 2–3 Working Days'
  assign supplier_dispatch_text = section.settings.supplier_dispatch_text | default: 'This item is sourced from our supplier. Once received, we inspect and dispatch it to you. Estimated delivery: 3–5 working days.'
  assign supplier_delivery_est = section.settings.supplier_delivery_estimate | default: '3–5 working days'

  for block in section.blocks
    if block.type == 'supplier_config' and block.settings.supplier_key == supplier_key
      if block.settings.banner_text != blank
        assign supplier_banner_text = block.settings.banner_text
      endif
      if block.settings.dispatch_text != blank
        assign supplier_dispatch_text = block.settings.dispatch_text
      endif
      if block.settings.delivery_estimate != blank
        assign supplier_delivery_est = block.settings.delivery_estimate
      endif
      break
    endif
  endfor

  comment
    Buy Now price threshold (in pounds, converted to pence)
  endcomment
  assign buy_now_threshold_pence = section.settings.buy_now_price_threshold | default: 500 | times: 100
  assign show_buy_now = section.settings.show_buy_now
  assign show_buy_now_final = false
  if show_buy_now and is_in_stock and current_variant.price <= buy_now_threshold_pence and stock_source == 'invicta'
    assign show_buy_now_final = true
  endif
  
  comment
    Gallery logic
  endcomment
  assign has_multiple_images = false
  if product.images.size > 1
    assign has_multiple_images = true
  endif
  
  comment
    Section settings shortcuts
  endcomment
  assign show_breadcrumb = section.settings.show_breadcrumb
  assign show_sku = section.settings.show_sku
  assign show_trust_badges = section.settings.show_trust_badges
  assign show_key_specs = section.settings.show_key_specs
  assign delivery_title = section.settings.delivery_title
  assign delivery_text = section.settings.delivery_text
%}

<div
  class="inv-pdp"
  data-section-id="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-product-url="{{ product.url }}"
  data-product-handle="{{ product.handle }}"
  data-vat-rate="{{ settings.inv_vat_rate | default: 20 }}"
  data-low-stock-threshold="{{ section.settings.low_stock_threshold | default: 5 }}"
>
  
  {%- comment -%} ========== BREADCRUMB BAR ========== {%- endcomment -%}
  {% if show_breadcrumb %}
    <div class="inv-pdp__breadcrumb-bar">
      <nav class="inv-pdp__breadcrumb" aria-label="Breadcrumb">
        <ol itemscope itemtype="https://schema.org/BreadcrumbList">
          <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a itemprop="item" href="/"><span itemprop="name">{{ 'invicta.breadcrumbs.home' | t }}</span></a>
            <meta itemprop="position" content="1">
          </li>
          <li aria-hidden="true"><span class="inv-pdp__breadcrumb-sep">/</span></li>
          {% if product.collections.size > 0 %}
            {% assign primary_collection = product.collections | first %}
            <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
              <a itemprop="item" href="{{ primary_collection.url }}"><span itemprop="name">{{ primary_collection.title }}</span></a>
              <meta itemprop="position" content="2">
            </li>
            <li aria-hidden="true"><span class="inv-pdp__breadcrumb-sep">/</span></li>
            <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
              <span class="inv-pdp__breadcrumb-current" itemprop="name">{{ product.title | truncate: 50 }}</span>
              <meta itemprop="position" content="3">
            </li>
          {% else %}
            <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
              <span class="inv-pdp__breadcrumb-current" itemprop="name">{{ product.title | truncate: 50 }}</span>
              <meta itemprop="position" content="2">
            </li>
          {% endif %}
        </ol>
      </nav>
      
      {% if show_sku and current_variant.sku != blank and current_variant.sku != product.handle %}
        <span class="inv-pdp__sku" data-sku>
          {{ current_variant.sku }}
        </span>
      {% endif %}
    </div>
  {% endif %}

  {%- comment -%} ========== MAIN GRID ========== {%- endcomment -%}
  <div class="inv-pdp__grid">
    
    {%- comment -%} ========== LEFT COLUMN ========== {%- endcomment -%}
    <div class="inv-pdp__left">
      
      {%- comment -%} GALLERY {%- endcomment -%}
      <div 
        class="inv-pdp__gallery{% unless has_multiple_images %} inv-pdp__gallery--single{% endunless %}"
        data-gallery
      >
        {% if has_multiple_images %}
          <div 
            class="inv-pdp__gallery-thumbs" 
            role="listbox" 
            aria-label="Product images"
            tabindex="0"
            data-gallery-thumbs
          >
            {% for image in product.images %}
              {%- assign thumb_img_150 = image | image_url: width: 150 -%}
              {%- assign thumb_img_800 = image | image_url: width: 800 -%}
              <button
                type="button"
                class="inv-pdp__gallery-thumb{% if forloop.first %} inv-pdp__gallery-thumb--active{% endif %}"
                data-image-id="{{ image.id }}"
                data-image-src="{{ thumb_img_800 }}"
                data-index="{{ forloop.index0 }}"
                aria-label="View image {{ forloop.index }} of {{ product.images.size }}"
                aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                role="option"
              >
                <img
                  src="{{ thumb_img_150 }}"
                  alt="{{ image.alt | escape | default: product.title }}"
                  loading="{% if forloop.index <= 6 %}eager{% else %}lazy{% endif %}"
                  width="64"
                  height="64"
                >
              </button>
            {% endfor %}
          </div>
        {% endif %}
        
        <div class="inv-pdp__gallery-main">
          {% if discount_percent > 0 %}
            <span class="inv-pdp__gallery-badge" aria-label="Save {{ discount_percent }} percent">
              SAVE {{ discount_percent }}%
            </span>
          {% endif %}
          
          {%- comment -%} Image counter pill {%- endcomment -%}
          {% if product.images.size > 1 %}
            <div class="inv-pdp__gallery-counter" aria-live="polite" aria-atomic="true">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="2"></rect>
                <circle cx="8.5" cy="8.5" r="1.5"></circle>
                <polyline points="21 15 16 10 5 21"></polyline>
              </svg>
              <span data-image-counter>1 / {{ product.images.size }}</span>
            </div>
          {% endif %}

          {%- assign main_img_400 = featured_image | image_url: width: 400 -%}
          {%- assign main_img_600 = featured_image | image_url: width: 600 -%}
          {%- assign main_img_800 = featured_image | image_url: width: 800 -%}
          {%- assign main_img_1200 = featured_image | image_url: width: 1200 -%}
          <div class="inv-pdp__gallery-image-wrap">
            <img
              id="inv-pdp-main-image-{{ section.id }}"
              class="inv-pdp__gallery-image"
              src="{{ main_img_800 }}"
              srcset="{{ main_img_400 }} 400w,
                      {{ main_img_600 }} 600w,
                      {{ main_img_800 }} 800w,
                      {{ main_img_1200 }} 1200w"
              sizes="(max-width: 749px) 100vw, 50vw"
              alt="{{ featured_image.alt | escape | default: product.title }}"
              width="{{ featured_image.width | default: 800 }}"
              height="{{ featured_image.height | default: 800 }}"
              loading="eager"
              fetchpriority="high"
              data-main-image
            >
          </div>
          
          <button 
            type="button" 
            class="inv-pdp__gallery-zoom" 
            aria-label="Zoom image"
            data-zoom-trigger
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true">
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.35-4.35"></path>
              <path d="M11 8v6M8 11h6"></path>
            </svg>
            Zoom
          </button>
        </div>
      </div>
      
      {%- comment -%} KEY SPECS CHIPS {%- endcomment -%}
      {% if show_key_specs %}
        {% liquid
          assign has_key_specs = false
          if mf_voltage != blank or mf_max_torque != blank or mf_motor_type != blank
            assign has_key_specs = true
          endif
        %}
        {% if has_key_specs %}
          <div class="inv-pdp__key-specs" role="list" aria-label="Key specifications">
            {% if mf_voltage != blank %}
              <span class="inv-pdp__key-spec" role="listitem">
                <svg class="inv-pdp__key-spec-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true">
                  <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
                </svg>
                {{ mf_voltage }}
              </span>
            {% endif %}
            {% if mf_max_torque != blank %}
              <span class="inv-pdp__key-spec" role="listitem">
                <svg class="inv-pdp__key-spec-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true">
                  <circle cx="12" cy="12" r="10"/>
                  <path d="M12 6v6l4 2"/>
                </svg>
                {{ mf_max_torque }}
              </span>
            {% endif %}
            {% if mf_motor_type != blank %}
              <span class="inv-pdp__key-spec" role="listitem">
                <svg class="inv-pdp__key-spec-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true">
                  <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
                </svg>
                {{ mf_motor_type }}
              </span>
            {% endif %}
          </div>
        {% endif %}
      {% endif %}
      
      {%- comment -%} FEATURE CHIPS {%- endcomment -%}
      {% if mf_features != blank %}
        <div class="inv-pdp__features" role="list" aria-label="Product features">
          {% assign features = mf_features | split: ',' %}
          {% for feature in features limit: 5 %}
            <span class="inv-pdp__feature-chip" role="listitem">
              <span class="inv-pdp__feature-chip-icon" aria-hidden="true">✓</span>
              {{ feature | strip }}
            </span>
          {% endfor %}
        </div>
      {% endif %}

      {%- comment -%} COMPATIBLE PRODUCTS (Battery Ecosystem) {%- endcomment -%}
      {%- liquid
        assign compat_json = product.metafields.custom.compatible_products
        assign compat_products = blank
        if compat_json != blank
          assign compat_handles = compat_json | replace: '[', '' | replace: ']', '' | replace: '"', '' | split: ','
          assign compat_count = 0
          for h in compat_handles
            assign h_clean = h | strip
            if h_clean != blank
              assign compat_count = compat_count | plus: 1
            endif
          endfor
        endif
      -%}
      {%- if compat_count > 0 -%}
        {%- liquid
          assign is_bare_unit = false
          assign title_lower = product.title | downcase
          if title_lower contains 'bare' or title_lower contains 'body only'
            assign is_bare_unit = true
          else
            for tag in product.tags
              assign tag_check = tag | downcase | strip
              if tag_check == 'bare' or tag_check == 'bare-unit' or tag_check == 'body-only'
                assign is_bare_unit = true
                break
              endif
            endfor
          endif
        -%}
        <div class="inv-pdp__compat">
          <h2 class="inv-pdp__compat-heading">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true">
              <path d="M6 7h11a4 4 0 0 1 0 8h-1"/>
              <path d="m6.5 12 3.5 3.5L6.5 19"/>
              <line x1="2" y1="12" x2="10" y2="12"/>
            </svg>
            Works With This Tool
          </h2>
          {%- if is_bare_unit -%}
            <p class="inv-pdp__compat-bare-notice">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
              This is a bare unit — battery and charger sold separately
            </p>
          {%- endif -%}
          <div class="inv-pdp__compat-row">
            {%- for h in compat_handles -%}
              {%- assign h_clean = h | strip -%}
              {%- if h_clean == blank -%}{%- continue -%}{%- endif -%}
              {%- assign compat_product = all_products[h_clean] -%}
              {%- if compat_product == blank or compat_product.title == blank -%}{%- continue -%}{%- endif -%}

              {%- assign cp_variant = compat_product.selected_or_first_available_variant -%}
              {%- assign cp_available = cp_variant.available -%}
              {%- assign cp_price = cp_variant.price -%}
              {%- assign cp_price_ex = cp_price | times: 100 | plus: inv_vat_rounding | divided_by: inv_vat_divisor -%}
              {%- assign cp_image = compat_product.featured_image -%}

              <div class="inv-pdp__compat-card">
                <a href="{{ compat_product.url }}" class="inv-pdp__compat-card-img">
                  {%- if cp_image -%}
                    <img
                      src="{{ cp_image | image_url: width: 160 }}"
                      alt="{{ cp_image.alt | escape | default: compat_product.title }}"
                      width="80"
                      height="80"
                      loading="lazy"
                    >
                  {%- endif -%}
                </a>
                <div class="inv-pdp__compat-card-body">
                  <a href="{{ compat_product.url }}" class="inv-pdp__compat-card-title">
                    {{ compat_product.title | truncate: 50 }}
                  </a>
                  <div class="inv-pdp__compat-card-price">
                    <span data-price-inc>{{ cp_price | money }}</span>
                    <span class="inv-vat--hidden" data-price-ex>{{ cp_price_ex | money }}</span>
                  </div>
                  <span class="inv-pdp__compat-card-stock inv-pdp__compat-card-stock--{{ cp_available | default: false }}">
                    {%- if cp_available -%}In Stock{%- else -%}Out of Stock{%- endif -%}
                  </span>
                </div>
                {%- if cp_available and compat_product.has_only_default_variant -%}
                  <button
                    type="button"
                    class="inv-pdp__compat-card-add"
                    data-add-to-cart
                    data-variant-id="{{ cp_variant.id }}"
                    data-quantity="1"
                    aria-label="Add {{ compat_product.title | escape }} to cart"
                  >
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true">
                      <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                    </svg>
                    Add
                  </button>
                {%- elsif cp_available -%}
                  <a href="{{ compat_product.url }}" class="inv-pdp__compat-card-add">
                    View
                  </a>
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}

      {%- comment -%} PRODUCT INFO — Accordion Sections {%- endcomment -%}
      <div class="inv-pdp__info" data-product-info>

        {%- comment -%} Brand + SKU always visible (not collapsible) {%- endcomment -%}
        {% if product.vendor != blank %}
          <div class="inv-pdp__info-meta">
            <span class="inv-pdp__info-meta-item">
              <span class="inv-pdp__info-meta-label">Brand</span>
              <span class="inv-pdp__info-meta-value">{{ product.vendor }}</span>
            </span>
            {% if show_sku and current_variant.sku != blank and current_variant.sku != product.handle %}
              <span class="inv-pdp__info-meta-item">
                <span class="inv-pdp__info-meta-label">Part No.</span>
                <span class="inv-pdp__info-meta-value" data-sku-display>{{ current_variant.sku }}</span>
              </span>
            {% endif %}
          </div>
        {% endif %}

        {%- comment -%} Hidden source for JS description parser {%- endcomment -%}
        {% if product.description != blank %}
          <div class="inv-pdp__info-row inv-pdp__info-row--hidden" data-description-source>
            {{ product.description }}
          </div>
        {% endif %}

        {%- comment -%} Accordion sections — JS populates content, then removes inv-pdp--hidden {%- endcomment -%}
        <div class="inv-pdp__info-section inv-pdp__info-section--open inv-pdp--hidden" data-row="description">
          <button class="inv-pdp__info-toggle" type="button" aria-expanded="true" data-accordion-toggle>
            <span>Description</span>
            <svg class="inv-pdp__info-toggle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="inv-pdp__info-content" data-content></div>
        </div>

        <div class="inv-pdp__info-section inv-pdp--hidden" data-row="why-buy">
          <button class="inv-pdp__info-toggle" type="button" aria-expanded="false" data-accordion-toggle>
            <span>Key Features</span>
            <svg class="inv-pdp__info-toggle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="inv-pdp__info-content">
            <ul class="inv-pdp__info-list" data-content></ul>
          </div>
        </div>

        <div class="inv-pdp__info-section inv-pdp--hidden" data-row="used-for">
          <button class="inv-pdp__info-toggle" type="button" aria-expanded="false" data-accordion-toggle>
            <span>Ideal For</span>
            <svg class="inv-pdp__info-toggle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="inv-pdp__info-content">
            <ul class="inv-pdp__info-list" data-content></ul>
          </div>
        </div>

        <div class="inv-pdp__info-section inv-pdp--hidden" data-row="specifications">
          <button class="inv-pdp__info-toggle" type="button" aria-expanded="false" data-accordion-toggle>
            <span>Specifications</span>
            <svg class="inv-pdp__info-toggle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="inv-pdp__info-content">
            <div class="inv-pdp__info-specs" data-content></div>
          </div>
        </div>

        <div class="inv-pdp__info-section inv-pdp--hidden" data-row="whats-included">
          <button class="inv-pdp__info-toggle" type="button" aria-expanded="false" data-accordion-toggle>
            <span>What's in the Box</span>
            <svg class="inv-pdp__info-toggle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="inv-pdp__info-content">
            <ul class="inv-pdp__info-list inv-pdp__info-list--included" data-content></ul>
          </div>
        </div>

        {%- comment -%} Fallback if JS fails {%- endcomment -%}
        <noscript>
          <div class="inv-pdp__info-section inv-pdp__info-section--open">
            <div class="inv-pdp__info-content">{{ product.description }}</div>
          </div>
        </noscript>
      </div>
      
    </div>
    
    {%- comment -%} ========== RIGHT COLUMN — BUY BOX ========== {%- endcomment -%}
    <div class="inv-pdp__right">
      <div class="inv-pdp__buybox" data-trade-threshold="{{ section.settings.trade_mode_threshold | default: 3 }}">
        
        {%- comment -%} STOCK BANNER {%- endcomment -%}
        <div
          class="inv-pdp__stock-banner
            {%- if is_in_stock and stock_source == 'supplier' %} inv-pdp__stock-banner--supplier-stock
            {%- elsif is_in_stock and show_low_stock %} inv-pdp__stock-banner--low-stock
            {%- elsif is_in_stock %} inv-pdp__stock-banner--in-stock
            {%- else %} inv-pdp__stock-banner--out-of-stock
            {%- endif -%}"
          role="status"
          aria-live="polite"
          data-stock-banner
          data-stock-source="{{ stock_source }}"
          data-supplier-banner-text="{{ supplier_banner_text | escape }}"
        >
          <span class="inv-pdp__stock-dot" aria-hidden="true"></span>
          <div class="inv-pdp__stock-banner-content">
            <span data-stock-text>
              {%- if is_in_stock == false -%}
                {{ section.settings.oos_text | default: 'Out of Stock' }}
              {%- elsif stock_source == 'supplier' -%}
                {{ supplier_banner_text }}
              {%- elsif show_low_stock -%}
                Only {{ stock_qty }} left in stock — order soon
              {%- else -%}
                {{ section.settings.in_stock_text | default: 'In Stock — Ready to Ship' }}
              {%- endif -%}
            </span>
            {%- if is_in_stock and stock_source == 'invicta' and show_low_stock == false -%}
              <span class="inv-pdp__stock-origin">{{ section.settings.invicta_origin_text | default: 'Ships from our warehouse' }}</span>
            {%- endif -%}
            {%- if is_in_stock and stock_source == 'supplier' -%}
              <span class="inv-pdp__stock-dispatch" data-dispatch-text>
                {{ supplier_dispatch_text }}
              </span>
              <details class="inv-pdp__stock-info-details">
                <summary class="inv-pdp__stock-info-trigger">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                  How does this work?
                </summary>
                <p class="inv-pdp__stock-info-body">{{ section.settings.supplier_info_text | default: 'This item is sourced from our supplier network. Once received at our warehouse, we inspect and dispatch to you.' }}</p>
              </details>
            {%- else -%}
              <span class="inv-pdp__stock-dispatch inv-pdp--hidden" data-dispatch-text></span>
            {%- endif -%}
          </div>
        </div>
        {%- comment -%} BRANCH COLLECTION TEASER (Invicta stock only) {%- endcomment -%}
        {%- if is_in_stock and stock_source == 'invicta' and section.settings.show_click_collect -%}
          <div class="inv-pdp__branch-teaser">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            <span>Also available for collection — <a href="#inv-pdp-collect">Canterbury &amp; Ramsgate</a></span>
          </div>
        {%- endif -%}

        <div class="inv-pdp__buybox-body">

          {%- comment -%} PRODUCT TITLE — in buy box so title+price are scanned together {%- endcomment -%}
          <h1 class="inv-pdp__title">{{ product.title | escape }}</h1>

          {%- comment -%} DEALER BADGE + BRAND PILL {%- endcomment -%}
          {%- comment -%}
            Dealer brand colours (#00a0aa Makita, #febd17 DeWalt, #006b3f HiKOKI,
            #db0032 Milwaukee, #111111 DeWalt text) — exempt from token system.
          {%- endcomment -%}
          {% liquid
            assign dealer_vendor = product.vendor | downcase
            assign dealer_bg = '#2d2d2d'
            assign dealer_text = '#ffffff'

            if dealer_vendor contains 'makita'
              assign dealer_bg = '#00a0aa'
              assign dealer_text = '#ffffff'
            elsif dealer_vendor contains 'dewalt'
              assign dealer_bg = '#febd17'
              assign dealer_text = '#111111'
            elsif dealer_vendor contains 'hikoki'
              assign dealer_bg = '#006b3f'
              assign dealer_text = '#ffffff'
            elsif dealer_vendor contains 'milwaukee'
              assign dealer_bg = '#db0032'
              assign dealer_text = '#ffffff'
            endif
          %}
          <div class="inv-pdp__dealer-row">
            <div class="inv-pdp__dealer-badge" style="--dealer-bg: {{ dealer_bg }}; --dealer-text: {{ dealer_text }};">
              <svg class="inv-pdp__dealer-badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                <path d="m9 12 2 2 4-4"/>
              </svg>
              <span class="inv-pdp__dealer-badge-text">Authorised Dealer</span>
            </div>
            {% render 'invicta-brand-pill', product: product %}
          </div>
          
          {%- comment -%}
            PRICE BLOCK — Single price controlled by VAT toggle
            Shows either ex VAT or inc VAT based on header toggle selection.
            Uses data-price-ex / data-price-inc for invicta-vat-toggle.js control.
          {%- endcomment -%}
          <div
            class="inv-pdp__price"
            data-price-wrapper
            aria-live="polite"
            aria-atomic="true"
          >
            <div class="inv-pdp__price-inline">
              <div class="inv-pdp__price-line inv-vat--hidden" data-price-ex>
                <span class="inv-pdp__price-current" data-price-ex-value>{{ price_ex_vat | money }}</span>
                <span class="inv-pdp__price-label">ex VAT</span>
                {% if has_compare_price %}
                  <span class="inv-pdp__price-was" data-compare-ex>{{ compare_ex_vat | money }}</span>
                {% endif %}
              </div>
              <div class="inv-pdp__price-line" data-price-inc>
                <span class="inv-pdp__price-current" data-price-inc-value>{{ current_variant.price | money }}</span>
                <span class="inv-pdp__price-label">inc VAT</span>
                {% if has_compare_price %}
                  <span class="inv-pdp__price-was" data-compare-inc>{{ current_variant.compare_at_price | money }}</span>
                {% endif %}
              </div>
            </div>

            {%- comment -%} SAVINGS {%- endcomment -%}
            {% if has_compare_price %}
              <div class="inv-pdp__price-savings" data-savings-wrap>
                <span class="inv-pdp__price-save" data-savings>
                  You save {{ current_variant.compare_at_price | minus: current_variant.price | money }} ({{ discount_percent }}% off)
                </span>
              </div>
            {% endif %}
          </div>
          
          {%- comment -%} VARIANTS {%- endcomment -%}
          {% if product.has_only_default_variant == false %}
            <div class="inv-pdp__variants">
              {% for option in product.options_with_values %}
                <div class="inv-pdp__variant-group">
                  <label 
                    class="inv-pdp__variant-group-label" 
                    for="inv-pdp-option-{{ section.id }}-{{ forloop.index0 }}"
                  >
                    {{ option.name }}
                  </label>
                  <select 
                    id="inv-pdp-option-{{ section.id }}-{{ forloop.index0 }}"
                    class="inv-pdp__variant-select"
                    data-option-index="{{ forloop.index0 }}"
                  >
                    {% for value in option.values %}
                      <option 
                        value="{{ value | escape }}"
                        {% if option.selected_value == value %}selected{% endif %}
                      >
                        {{ value }}
                      </option>
                    {% endfor %}
                  </select>
                </div>
              {% endfor %}
            </div>
          {% endif %}
          
          {%- comment -%} CX v1.1: VOLUME / TIERED PRICING TABLE {%- endcomment -%}
          {%- if current_variant.quantity_price_breaks.size > 0 -%}
            <div class="invicta-tiered-pricing" data-tiered-pricing>
              <h3 class="invicta-tiered-pricing__title">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
                Buy More, Save More
              </h3>
              <div class="invicta-tiered-pricing__table" role="table" aria-label="Volume pricing tiers">
                <div class="invicta-tiered-pricing__header" role="row">
                  <span role="columnheader">Quantity</span>
                  <span role="columnheader">Price Each</span>
                  <span role="columnheader">Savings</span>
                </div>
                {%- assign base_price = current_variant.price -%}
                {%- assign sorted_breaks = current_variant.quantity_price_breaks | sort: 'minimum_quantity' -%}
                {%- for price_break in sorted_breaks -%}
                  {%- assign saving_pence = base_price | minus: price_break.price | times: price_break.minimum_quantity -%}
                  {%- assign saving_percent = base_price | minus: price_break.price | times: 100 | divided_by: base_price -%}
                  <div class="invicta-tiered-pricing__row" role="row" data-tier-qty="{{ price_break.minimum_quantity }}">
                    <span class="invicta-tiered-pricing__qty" role="cell">{{ price_break.minimum_quantity }}+</span>
                    <span class="invicta-tiered-pricing__price" role="cell">{{ price_break.price | money }}</span>
                    <span role="cell">
                      {%- if saving_percent > 0 -%}
                        <span class="invicta-tiered-pricing__badge">Save {{ saving_percent }}%</span>
                      {%- endif -%}
                    </span>
                  </div>
                {%- endfor -%}
              </div>
              <p class="invicta-tiered-pricing__note">Prices update automatically based on quantity</p>
            </div>
            {{ 'component-tiered-pricing.css' | asset_url | stylesheet_tag }}
            <script src="{{ 'component-tiered-pricing.js' | asset_url }}" defer></script>
          {%- endif -%}

          {%- comment -%} INLINE SPEC STRIP (Gate 3) — quick-reference data bar {%- endcomment -%}
          {%- if section.settings.show_spec_strip -%}
            {%- liquid
              assign spec_strip_count = 0
              if mf_voltage != blank
                assign spec_strip_count = spec_strip_count | plus: 1
              endif
              if mf_no_load_speed != blank
                assign spec_strip_count = spec_strip_count | plus: 1
              endif
              if mf_disc_diameter != blank
                assign spec_strip_count = spec_strip_count | plus: 1
              endif
              if mf_weight_body != blank
                assign spec_strip_count = spec_strip_count | plus: 1
              endif
              if mf_max_torque != blank
                assign spec_strip_count = spec_strip_count | plus: 1
              endif
              if mf_motor_type != blank
                assign spec_strip_count = spec_strip_count | plus: 1
              endif
            -%}
            {%- if spec_strip_count > 0 -%}
              <div class="inv-pdp__spec-strip" aria-label="Key specifications">
                {%- if mf_voltage != blank -%}
                  <div class="inv-pdp__spec-chip">
                    <svg class="inv-pdp__spec-chip-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                    <span class="inv-pdp__spec-chip-label">Voltage</span>
                    <span class="inv-pdp__spec-chip-value">{{ mf_voltage }}</span>
                  </div>
                {%- endif -%}
                {%- if mf_no_load_speed != blank -%}
                  <div class="inv-pdp__spec-chip">
                    <svg class="inv-pdp__spec-chip-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                    <span class="inv-pdp__spec-chip-label">RPM</span>
                    <span class="inv-pdp__spec-chip-value">{{ mf_no_load_speed }}</span>
                  </div>
                {%- endif -%}
                {%- if mf_disc_diameter != blank -%}
                  <div class="inv-pdp__spec-chip">
                    <svg class="inv-pdp__spec-chip-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true"><circle cx="12" cy="12" r="10"/></svg>
                    <span class="inv-pdp__spec-chip-label">Disc</span>
                    <span class="inv-pdp__spec-chip-value">{{ mf_disc_diameter }}</span>
                  </div>
                {%- endif -%}
                {%- if mf_max_torque != blank -%}
                  <div class="inv-pdp__spec-chip">
                    <svg class="inv-pdp__spec-chip-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                    <span class="inv-pdp__spec-chip-label">Torque</span>
                    <span class="inv-pdp__spec-chip-value">{{ mf_max_torque }}</span>
                  </div>
                {%- endif -%}
                {%- if mf_weight_body != blank -%}
                  <div class="inv-pdp__spec-chip">
                    <svg class="inv-pdp__spec-chip-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true"><path d="M20.91 8.84L8.56 21.18a1 1 0 01-1.41 0L3.82 17.85a1 1 0 010-1.41L16.16 4.09a3 3 0 014.24 0l.51.51a3 3 0 010 4.24z"/></svg>
                    <span class="inv-pdp__spec-chip-label">Weight</span>
                    <span class="inv-pdp__spec-chip-value">{{ mf_weight_body }}</span>
                  </div>
                {%- endif -%}
                {%- if mf_motor_type != blank -%}
                  <div class="inv-pdp__spec-chip">
                    <svg class="inv-pdp__spec-chip-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
                    <span class="inv-pdp__spec-chip-label">Motor</span>
                    <span class="inv-pdp__spec-chip-value">{{ mf_motor_type }}</span>
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endif -%}

          {%- comment -%} DELIVERY ESTIMATE (reusable snippet) {%- endcomment -%}
          {% render 'invicta-delivery-estimate', stock_source: stock_source, supplier_delivery_est: supplier_delivery_est %}

          {%- comment -%} ADD TO CART FORM {%- endcomment -%}
          <form
            class="inv-pdp__form"
            action="/cart/add"
            method="post"
            novalidate
            data-product-form
            id="inv-pdp-form-{{ section.id }}"
          >
            <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id>
            
            <div class="inv-pdp__atc-row">
              <div class="inv-pdp__qty">
                <button 
                  type="button" 
                  class="inv-pdp__qty-btn" 
                  data-qty-decrease 
                  aria-label="Decrease quantity"
                >
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                  </svg>
                </button>
                <input
                  type="number"
                  name="quantity"
                  class="inv-pdp__qty-input"
                  value="{{ current_variant.quantity_rule.min | default: 1 }}"
                  min="{{ current_variant.quantity_rule.min | default: 1 }}"
                  {% if current_variant.quantity_rule.max %}max="{{ current_variant.quantity_rule.max }}"{% else %}max="9999"{% endif %}
                  {% if current_variant.quantity_rule.increment > 1 %}step="{{ current_variant.quantity_rule.increment }}"{% endif %}
                  aria-label="Quantity"
                  data-qty-input
                >
                <button 
                  type="button" 
                  class="inv-pdp__qty-btn" 
                  data-qty-increase 
                  aria-label="Increase quantity"
                >
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true">
                    <line x1="12" y1="5" x2="12" y2="19"></line>
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                  </svg>
                </button>
              </div>
              
              <button 
                type="submit" 
                class="inv-pdp__atc-btn"
                data-atc-btn
                {% unless is_in_stock %}disabled{% endunless %}
              >
                <span class="inv-pdp__atc-text" data-atc-text>
                  {% if is_in_stock %}{{ section.settings.atc_text | default: 'Add to Cart' }}{% else %}{{ section.settings.oos_text | default: 'Out of Stock' }}{% endif %}
                </span>
                <span class="inv-pdp__atc-loading" aria-hidden="true">
                  <svg focusable="false" aria-hidden="true" class="inv-pdp__spinner" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10" stroke-dasharray="32" stroke-dashoffset="12"></circle>
                  </svg>
                  Adding...
                </span>
                <span class="inv-pdp__atc-success" aria-hidden="true">
                  <svg focusable="false" aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 6L9 17l-5-5"></path>
                  </svg>
                  Added!
                </span>
              </button>
            </div>
            
            {%- comment -%} TRADE MODE: PO Reference field (Gate 5) — hidden until qty >= threshold {%- endcomment -%}
            {%- if section.settings.show_po_field -%}
              <div class="inv-pdp__trade-po inv-pdp--hidden" data-trade-po>
                <label class="inv-pdp__trade-po-label" for="inv-pdp-po-{{ section.id }}">PO / Job Reference (optional)</label>
                <input
                  type="text"
                  id="inv-pdp-po-{{ section.id }}"
                  name="properties[_po_reference]"
                  class="inv-pdp__trade-po-input"
                  placeholder="PO / Job Reference (optional)"
                  data-po-input
                >
              </div>
            {%- endif -%}

            {%- comment -%} CART ERROR FEEDBACK {%- endcomment -%}
            <div class="inv-pdp__atc-error inv-pdp--hidden" role="alert" aria-live="assertive" data-atc-error data-error-text="{{ section.settings.cart_error_text | escape }}"></div>
          </form>

          {%- comment -%} TRADE MODE: Bulk messaging (Gate 5) — hidden until qty >= threshold {%- endcomment -%}
          {%- if section.settings.show_po_field -%}
          <div class="inv-pdp__trade-bulk inv-pdp--hidden" data-trade-bulk>
            <p class="inv-pdp__trade-bulk-msg">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              {{ section.settings.bulk_message | default: 'Need 10+? Call us on 01843 210 459 for trade pricing' }}
            </p>
          </div>
          {%- endif -%}

          {%- comment -%}
            CX v1.1: BACK-IN-STOCK NOTIFICATION
            IMPORTANT: This MUST be outside the ATC form. HTML forbids nested forms.
            A nested <form> tag is ignored by the parser, which causes the inner
            form's <input type="email" required> to become part of the outer ATC form.
            The hidden required field then silently blocks form submission.
          {%- endcomment -%}
          <div class="inv-pdp__notify{% if is_in_stock %} inv-pdp--hidden{% endif %}" data-notify-wrap>
            <div class="inv-pdp__notify-inner">
              <p class="inv-pdp__notify-heading">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                Notify me when back in stock
              </p>
              <form class="inv-pdp__notify-form" data-notify-form data-product-title="{{ product.title | escape }}" data-product-handle="{{ product.handle }}">
                <div class="inv-pdp__notify-field">
                  <input
                    type="email"
                    name="email"
                    class="inv-pdp__notify-input"
                    placeholder="Enter your email address"
                    aria-label="Email address for back-in-stock notification"
                    required
                    data-notify-email
                  >
                  <button type="submit" class="inv-pdp__notify-btn" data-notify-submit>
                    <span data-notify-btn-text>Notify Me</span>
                    <span class="inv-pdp__notify-spinner inv-pdp--hidden" data-notify-spinner aria-hidden="true">
                      <svg focusable="false" aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" stroke-dasharray="32" stroke-dashoffset="12"/></svg>
                    </span>
                  </button>
                </div>
                <p class="inv-pdp__notify-success inv-pdp--hidden" data-notify-success role="status">
                  <svg focusable="false" aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                  We'll email you when this item is available again.
                </p>
                <p class="inv-pdp__notify-error inv-pdp--hidden" data-notify-error role="alert"></p>
                <p class="inv-pdp__notify-privacy">We'll only use your email for this notification.</p>
              </form>
            </div>
          </div>

          {%- comment -%} KIT BUILDER (Gate 4) — opens drawer with tiered kit options {%- endcomment -%}
          {%- if has_kit_options and is_in_stock -%}
            <div class="inv-pdp__kit-builder-trigger">
