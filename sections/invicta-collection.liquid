{%- comment -%}
  ============================================================================
  INVICTA COLLECTION v9.0
  ============================================================================
  
  Complete rebuild with app-style mobile experience
  
  Features:
  - Compact centered hero
  - Sticky toolbar
  - 2-column mobile grid
  - Bottom sheet filter drawer
  - Floating filter button
  - Back to top pill
  
  ============================================================================
{%- endcomment -%}

{%- liquid
  assign products_per_page = section.settings.products_per_page | default: 24
  assign show_sort = section.settings.show_sort

  # Filters to hide from customers (labels, case-insensitive check via downcase)
  assign hidden_filter_labels = 'product rating count'

  assign has_active_filters = false
  assign active_filter_count = 0
  for filter in collection.filters
    if filter.active_values.size > 0
      assign has_active_filters = true
      assign active_filter_count = active_filter_count | plus: filter.active_values.size
    endif
    if filter.type == 'price_range'
      if filter.min_value.value != blank or filter.max_value.value != blank
        assign has_active_filters = true
        assign active_filter_count = active_filter_count | plus: 1
      endif
    endif
  endfor

  assign current_sort = collection.sort_by | default: collection.default_sort_by
-%}

{%- comment -%} ===== STYLES ===== {%- endcomment -%}
{{ 'section-invicta-collection.css' | asset_url | stylesheet_tag }}

{%- if settings.inv_ga4_measurement_id != blank -%}
  <script type="application/json" data-inv-ga4-list>
    {
      "id": {{ collection.handle | json }},
      "name": {{ collection.title | json }},
      "items": [
        {%- for product in collection.products limit: products_per_page -%}
          {
            "item_id": {{ product.id | json }},
            "item_name": {{ product.title | json }},
            "item_brand": {{ product.vendor | json }},
            "item_category": {{ product.type | json }},
            "price": {{ product.price | divided_by: 100.0 }},
            "index": {{ forloop.index0 }}
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    }
  </script>
{%- endif -%}

<div class="inv-collection" data-section-id="{{ section.id }}" data-inv-collection-section="{{ section.id }}">

  {%- comment -%} ================================================================
     1. HERO SECTION — CX v1.2 Redesigned
  ================================================================ {%- endcomment -%}
  <section class="inv-hero{% if collection.image %} inv-hero--has-image{% endif %}">
    {%- if collection.image -%}
      {%- assign hero_img_600 = collection.image | image_url: width: 600 -%}
      {%- assign hero_img_900 = collection.image | image_url: width: 900 -%}
      {%- assign hero_img_1200 = collection.image | image_url: width: 1200 -%}
      {%- assign hero_img_1920 = collection.image | image_url: width: 1920 -%}
      <div class="inv-hero__image-wrap">
        <img
          src="{{ hero_img_1200 }}"
          srcset="{{ hero_img_600 }} 600w,
                  {{ hero_img_900 }} 900w,
                  {{ hero_img_1200 }} 1200w,
                  {{ hero_img_1920 }} 1920w"
          sizes="100vw"
          alt="{{ collection.title | escape }}"
          width="{{ collection.image.width | default: 1920 }}"
          height="{{ collection.image.height | default: 400 }}"
          loading="eager"
          fetchpriority="high"
          class="inv-hero__image"
        >
      </div>
    {%- endif -%}
    <div class="inv-hero__overlay"></div>
    <div class="inv-hero__content page-width">

      {%- comment -%} Breadcrumb {%- endcomment -%}
      <nav class="inv-hero__breadcrumb" aria-label="Breadcrumb">
        <ol>
          <li><a href="{{ routes.root_url }}">Home</a></li>
          <li aria-current="page">{{ collection.title }}</li>
        </ol>
      </nav>

      {%- comment -%} Title {%- endcomment -%}
      <h1 class="inv-hero__title">{{ collection.title | escape }}</h1>

      {%- comment -%} Subheading / Collection description {%- endcomment -%}
      {%- assign hero_sub = section.settings.hero_subheading -%}
      {%- if hero_sub != blank or collection.description != blank -%}
        <p class="inv-hero__description">
          {%- if collection.description != blank -%}
            {{ collection.description | strip_html | truncate: 160 }}
          {%- else -%}
            {{ hero_sub }}
          {%- endif -%}
        </p>
      {%- endif -%}

    </div>
  </section>
  
  
  {%- comment -%} ================================================================
     4. ACTIVE FILTER CHIPS
  ================================================================ {%- endcomment -%}
  {%- if has_active_filters -%}
    <div class="inv-active-filters">
      <div class="page-width">
        <div class="inv-active-filters__inner">
          {%- for filter in collection.filters -%}
            {%- for value in filter.active_values -%}
              <a href="{{ value.url_to_remove }}" rel="nofollow" class="inv-filter-chip" data-inv-filter-remove>
                <span>{{ value.label }}</span>
                <svg focusable="false" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 6L6 18M6 6l12 12"/>
                </svg>
              </a>
            {%- endfor -%}
            {%- if filter.type == 'price_range' -%}
              {%- if filter.min_value.value != blank or filter.max_value.value != blank -%}
                <a href="{{ filter.url_to_remove }}" rel="nofollow" class="inv-filter-chip" data-inv-filter-remove>
                  <span>
                    {%- if filter.min_value.value != blank -%}{{ filter.min_value.value | money_without_trailing_zeros }}{%- else -%}£0{%- endif -%}
                    –
                    {%- if filter.max_value.value != blank -%}{{ filter.max_value.value | money_without_trailing_zeros }}{%- else -%}{{ filter.range_max | money_without_trailing_zeros }}{%- endif -%}
                  </span>
                  <svg focusable="false" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M18 6L6 18M6 6l12 12"/>
                  </svg>
                </a>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
          <a href="{{ collection.url }}" rel="nofollow" class="inv-clear-all" data-inv-filter-remove>{{ 'products.facets.clear_all' | t }}</a>
        </div>
      </div>
    </div>
  {%- endif -%}


  {%- comment -%} ================================================================
     5. MAIN LAYOUT
  ================================================================ {%- endcomment -%}
  <div class="inv-layout">
    <div class="page-width">
      <div class="inv-layout__inner">
        
        {%- comment -%} ===== SIDEBAR (Desktop only) ===== {%- endcomment -%}
        <aside class="inv-sidebar" id="InvSidebar">
          <form id="InvFilterForm" class="inv-filter-form" data-inv-filter-sidebar>
            <div class="inv-sidebar__header">
              <span class="inv-sidebar__title">Filters</span>
              {%- if has_active_filters -%}
                <a href="{{ collection.url }}" class="inv-sidebar__clear">{{ 'products.facets.clear_all' | t }}</a>
              {%- endif -%}
            </div>
            
            {%- for filter in collection.filters -%}
              {%- liquid
                assign _fl = filter.label | downcase
                if hidden_filter_labels contains _fl
                  continue
                endif
              -%}
              <details class="inv-facet" open>
                <summary class="inv-facet__header">
                  <span class="inv-facet__name">{{ filter.label }}</span>
                  <svg focusable="false" aria-hidden="true" class="inv-facet__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="m6 9 6 6 6-6"/>
                  </svg>
                </summary>
                <div class="inv-facet__body">

                  {%- case filter.type -%}
                    {%- when 'list' or 'boolean' -%}
                      <ul class="inv-facet__list">
                        {%- for value in filter.values -%}
                          <li class="inv-facet__item">
                            <label class="inv-facet__label-wrap">
                              <input
                                type="checkbox"
                                name="{{ value.param_name }}"
                                value="{{ value.value }}"
                                class="inv-facet__checkbox"
                                {% if value.active %}checked{% endif %}
                                {% if value.count == 0 and value.active == false %}disabled{% endif %}
                              >
                              <span class="inv-facet__label">{{ value.label }}</span>
                              <span class="inv-facet__count">({{ value.count }})</span>
                            </label>
                          </li>
                        {%- endfor -%}
                      </ul>

                    {%- when 'price_range' -%}
                      <div class="inv-facet__price-row">
                        <div class="inv-facet__price-field">
                          <span class="inv-facet__price-symbol">£</span>
                          <input
                            type="number"
                            name="{{ filter.min_value.param_name }}"
                            class="inv-facet__price-input"
                            placeholder="Min"
                            min="0"
                            max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                            {% if filter.min_value.value %}value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"{% endif %}
                          >
                        </div>
                        <span class="inv-facet__price-sep">–</span>
                        <div class="inv-facet__price-field">
                          <span class="inv-facet__price-symbol">£</span>
                          <input
                            type="number"
                            name="{{ filter.max_value.param_name }}"
                            class="inv-facet__price-input"
                            placeholder="Max"
                            min="0"
                            max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                            {% if filter.max_value.value %}value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"{% endif %}
                          >
                        </div>
                      </div>
                  {%- endcase -%}

                </div>
              </details>
            {%- endfor -%}

            <button type="submit" class="inv-sidebar__apply">
              {{ section.settings.apply_text | default: 'Apply Filters' }}
            </button>
          </form>
        </aside>
        
        
        {%- comment -%} ===== MAIN CONTENT ===== {%- endcomment -%}
        <main class="inv-main" id="InvMain">
          
          {%- paginate collection.products by products_per_page -%}
            
            {%- if collection.products.size > 0 -%}

              {%- comment -%} Type chips + Sort — combined toolrow {%- endcomment -%}
              <div class="inv-toolrow">
                <div class="inv-toolrow__chips">
                  {% render 'invicta-type-chips', collection: collection %}
                </div>
                <div class="inv-toolrow__actions">
                  <button type="button" class="inv-toolrow__filters" id="InvFilterToggle" aria-expanded="false">
                    <svg focusable="false" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <line x1="4" x2="4" y1="21" y2="14"/>
                      <line x1="4" x2="4" y1="10" y2="3"/>
                      <line x1="12" x2="12" y1="21" y2="12"/>
                      <line x1="12" x2="12" y1="8" y2="3"/>
                      <line x1="20" x2="20" y1="21" y2="16"/>
                      <line x1="20" x2="20" y1="12" y2="3"/>
                      <line x1="1" x2="7" y1="14" y2="14"/>
                      <line x1="9" x2="15" y1="8" y2="8"/>
                      <line x1="17" x2="23" y1="16" y2="16"/>
                    </svg>
                    <span>Filters</span>
                    {%- if has_active_filters -%}
                      <span class="inv-toolrow__filters-badge">{{ active_filter_count }}</span>
                    {%- endif -%}
                  </button>
                  {%- if show_sort -%}
                    <div class="inv-toolrow__sort">
                      <label for="InvSortSelect" class="inv-toolrow__sort-label">Sort:</label>
                      <select id="InvSortSelect" class="inv-toolrow__sort-select" data-inv-sort-select aria-label="Sort products">
                        <option value="manual" {% if current_sort == 'manual' %}selected{% endif %}>Featured</option>
                        <option value="best-selling" {% if current_sort == 'best-selling' %}selected{% endif %}>Best Selling</option>
                        <option value="title-ascending" {% if current_sort == 'title-ascending' %}selected{% endif %}>A–Z</option>
                        <option value="title-descending" {% if current_sort == 'title-descending' %}selected{% endif %}>Z–A</option>
                        <option value="price-ascending" {% if current_sort == 'price-ascending' %}selected{% endif %}>Price: Low–High</option>
                        <option value="price-descending" {% if current_sort == 'price-descending' %}selected{% endif %}>Price: High–Low</option>
                        <option value="created-ascending" {% if current_sort == 'created-ascending' %}selected{% endif %}>Oldest</option>
                        <option value="created-descending" {% if current_sort == 'created-descending' %}selected{% endif %}>Newest</option>
                      </select>
                    </div>
                  {%- endif -%}
                </div>
              </div>

              {%- comment -%} Product Grid {%- endcomment -%}
              <div class="inv-product-grid" id="InvProductGrid">
                {%- for product in collection.products -%}
                  <div class="inv-product-card">
                    {%- render 'invicta-product-card',
                      product: product,
                      card_index: forloop.index
                    -%}
                  </div>
                {%- endfor -%}
              </div>
              
              {%- comment -%} Pagination {%- endcomment -%}
              {%- if paginate.pages > 1 -%}
                <nav class="inv-pagination" aria-label="Pagination">
                  {%- if paginate.previous -%}
                    <a href="{{ paginate.previous.url }}" class="inv-pagination__item inv-pagination__item--arrow" data-inv-page-link aria-label="Previous page">
                      <svg focusable="false" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="m15 18-6-6 6-6"/>
                      </svg>
                    </a>
                  {%- endif -%}
                  
                  {%- for part in paginate.parts -%}
                    {%- if part.is_link -%}
                      <a href="{{ part.url }}" class="inv-pagination__item" data-inv-page-link>{{ part.title }}</a>
                    {%- elsif part.title == paginate.current_page -%}
                      <span class="inv-pagination__item inv-pagination__item--current" aria-current="page">{{ part.title }}</span>
                    {%- else -%}
                      <span class="inv-pagination__item inv-pagination__item--ellipsis">{{ part.title }}</span>
                    {%- endif -%}
                  {%- endfor -%}
                  
                  {%- if paginate.next -%}
                    <a href="{{ paginate.next.url }}" class="inv-pagination__item inv-pagination__item--arrow" data-inv-page-link aria-label="Next page">
                      <svg focusable="false" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="m9 18 6-6-6-6"/>
                      </svg>
                    </a>
                  {%- endif -%}
                </nav>
              {%- endif -%}
              
            {%- else -%}

              {%- comment -%} Empty State {%- endcomment -%}
              <div class="inv-empty">
                <svg focusable="false" class="inv-empty__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <circle cx="11" cy="11" r="8"/>
                  <path d="m21 21-4.35-4.35"/>
                </svg>

                {%- if has_active_filters -%}
                  <h2 class="inv-empty__title">{{ 'invicta.collection.no_products_match' | t }}</h2>
                  <p class="inv-empty__text">{{ 'invicta.collection.remove_filters_hint' | t }}</p>

                  <div class="inv-empty__active-filters">
                    {%- for filter in collection.filters -%}
                      {%- for value in filter.active_values -%}
                        <a href="{{ value.url_to_remove }}" rel="nofollow" class="inv-empty__filter-tag" data-inv-filter-remove>
                          {{ value.label }}
                          <span aria-hidden="true">&times;</span>
                        </a>
                      {%- endfor -%}
                      {%- if filter.type == 'price_range' -%}
                        {%- if filter.min_value.value != blank or filter.max_value.value != blank -%}
                          <a href="{{ filter.url_to_remove }}" rel="nofollow" class="inv-empty__filter-tag" data-inv-filter-remove>
                            {%- if filter.min_value.value != blank -%}{{ filter.min_value.value | money_without_trailing_zeros }}{%- else -%}£0{%- endif -%}
                            –
                            {%- if filter.max_value.value != blank -%}{{ filter.max_value.value | money_without_trailing_zeros }}{%- else -%}{{ filter.range_max | money_without_trailing_zeros }}{%- endif -%}
                            <span aria-hidden="true">&times;</span>
                          </a>
                        {%- endif -%}
                      {%- endif -%}
                    {%- endfor -%}
                  </div>

                  <a href="{{ collection.url }}" class="inv-empty__clear-all">{{ 'invicta.collection.clear_all_filters' | t }}</a>
                {%- else -%}
                  <h2 class="inv-empty__title">{{ 'invicta.collection.no_products_found' | t }}</h2>
                  <p class="inv-empty__text">{{ 'invicta.collection.adjust_filters_hint' | t }}</p>
                  <a href="{{ collection.url }}" class="inv-empty__btn">{{ 'invicta.collection.clear_filters' | t }}</a>
                {%- endif -%}
              </div>
              
            {%- endif -%}
            
          {%- endpaginate -%}
          
        </main>
        
      </div>
    </div>
  </div>


  {%- comment -%} ================================================================
     6. MOBILE FILTER DRAWER
  ================================================================ {%- endcomment -%}
  <div class="inv-drawer-overlay" id="InvDrawerOverlay"></div>
  
  <div class="inv-drawer" id="InvDrawer" role="dialog" aria-modal="true" aria-label="Filter products" aria-hidden="true">
    <div class="inv-drawer__drag-handle" id="InvDrawerHandle" aria-hidden="true">
      <span class="inv-drawer__drag-bar"></span>
    </div>
    <div class="inv-drawer__header">
      <span class="inv-drawer__title">Filters</span>
      <button type="button" class="inv-drawer__close" id="InvDrawerClose" data-inv-filter-drawer-close aria-label="Close filters">
        <svg focusable="false" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 6L6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>
    
    <div class="inv-drawer__body" id="InvDrawerBody">
      {%- comment -%} Filters rendered inline {%- endcomment -%}
      <form id="InvDrawerForm" class="inv-drawer-form" data-inv-filter-drawer-form>
        {%- for filter in collection.filters -%}
          {%- liquid
            assign _fl = filter.label | downcase
            if hidden_filter_labels contains _fl
              continue
            endif
          -%}
          <details class="inv-facet" open>
            <summary class="inv-facet__header">
              <span class="inv-facet__name">{{ filter.label }}</span>
              <svg focusable="false" aria-hidden="true" class="inv-facet__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </summary>
            <div class="inv-facet__body">
              
              {%- case filter.type -%}
                {%- when 'list' or 'boolean' -%}
                  <ul class="inv-facet__list">
                    {%- for value in filter.values -%}
                      <li class="inv-facet__item">
                        <label class="inv-facet__label-wrap">
                          <input 
                            type="checkbox" 
                            name="{{ value.param_name }}" 
                            value="{{ value.value }}"
                            class="inv-facet__checkbox"
                            {% if value.active %}checked{% endif %}
                            {% if value.count == 0 and value.active == false %}disabled{% endif %}
                          >
                          <span class="inv-facet__label">{{ value.label }}</span>
                          <span class="inv-facet__count">({{ value.count }})</span>
                        </label>
                      </li>
                    {%- endfor -%}
                  </ul>
                  
                {%- when 'price_range' -%}
                  <div class="inv-facet__price-row">
                    <div class="inv-facet__price-field">
                      <span class="inv-facet__price-symbol">£</span>
                      <input 
                        type="number" 
                        name="{{ filter.min_value.param_name }}" 
                        class="inv-facet__price-input"
                        placeholder="Min"
                        min="0"
                        max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                        {% if filter.min_value.value %}value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"{% endif %}
                      >
                    </div>
                    <span class="inv-facet__price-sep">–</span>
                    <div class="inv-facet__price-field">
                      <span class="inv-facet__price-symbol">£</span>
                      <input 
                        type="number" 
                        name="{{ filter.max_value.param_name }}" 
                        class="inv-facet__price-input"
                        placeholder="Max"
                        min="0"
                        max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                        {% if filter.max_value.value %}value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"{% endif %}
                      >
                    </div>
                  </div>
              {%- endcase -%}
              
            </div>
          </details>
        {%- endfor -%}
      </form>
    </div>
    
    <div class="inv-drawer__footer">
      <a href="{{ collection.url }}" class="inv-drawer__reset">{{ 'products.facets.clear_all' | t }}</a>
      <button type="button" class="inv-drawer__apply" id="InvDrawerApply" data-inv-filter-drawer-apply>Apply Filters</button>
    </div>
  </div>


  {%- comment -%} ================================================================
     7. FLOATING FILTER BUTTON (Mobile)
  ================================================================ {%- endcomment -%}
  <button type="button" class="inv-floating-filter" id="InvFloatingFilter" aria-label="Open filters">
    <svg focusable="false" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <line x1="4" x2="4" y1="21" y2="14"/>
      <line x1="4" x2="4" y1="10" y2="3"/>
      <line x1="12" x2="12" y1="21" y2="12"/>
      <line x1="12" x2="12" y1="8" y2="3"/>
      <line x1="20" x2="20" y1="21" y2="16"/>
      <line x1="20" x2="20" y1="12" y2="3"/>
      <line x1="1" x2="7" y1="14" y2="14"/>
      <line x1="9" x2="15" y1="8" y2="8"/>
      <line x1="17" x2="23" y1="16" y2="16"/>
    </svg>
    <span>Filters</span>
    {%- if has_active_filters -%}
      <span class="inv-floating-filter__badge">{{ active_filter_count }}</span>
    {%- endif -%}
  </button>


  {%- comment -%} ================================================================
     8. SCROLL TO TOP
  ================================================================ {%- endcomment -%}
  <button type="button" class="inv-scroll-top" id="InvScrollTop" aria-label="Back to top">
    <svg focusable="false" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="m18 15-6-6-6 6"/>
    </svg>
    <span>Top</span>
  </button>

</div>


{%- comment -%} ================================================================
   JAVASCRIPT — drawer/scroll in invicta-collection.js, AJAX in invicta-collection-ajax.js
================================================================ {%- endcomment -%}
<script src="{{ 'invicta-collection.js' | asset_url }}" defer></script>
<script src="{{ 'invicta-collection-ajax.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Invicta Collection v9.2",

  "tag": "section",
  "class": "section-invicta-collection",
  "settings": [
    {
      "type": "header",
      "content": "Hero Section"
    },
    {
      "type": "text",
      "id": "hero_subheading",
      "label": "Subheading",
      "default": "Power tools, fixings and accessories for professionals."
    },
    {
      "type": "header",
      "content": "Product Grid"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 12,
      "max": 72,
      "step": 12,
      "default": 24
    },
    {
      "type": "checkbox",
      "id": "show_sort",
      "label": "Show sort dropdown",
      "default": true
    },
    {
      "type": "header",
      "content": "Sidebar"
    },
    {
      "type": "text",
      "id": "apply_text",
      "label": "Apply button text",
      "default": "Apply Filters"
    }
  ],
  "presets": [
    {
      "name": "Invicta Collection v9.2"
    }
  ]
}
{% endschema %}
