{% comment %}
  ============================================
  INVICTA PROMO BANNERS v9.0 (Dark gradient cards with overlay text)
  ============================================
  Two dark gradient cards with text overlay, tag badges,
  and optional background images.

  Updates in v9.0:
  - Dark gradient card backgrounds (configurable)
  - Text overlay: tag badge, title, subtitle
  - Background images as card backgrounds with gradient overlay
  - Barlow Condensed heading font

  Supports:
  • Banner images via image_picker (now used as card backgrounds)
  • Date-windowed visibility per banner
  • Configurable gradient colours
  • Fully responsive (stacks on mobile)

  Trade 15.4.0 Compatible
  ============================================
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800&display=swap" rel="stylesheet">

{%- liquid
  assign now_ts = 'now' | date: '%s' | plus: 0

  assign show_banner_1 = true
  if section.settings.banner_1_start != blank
    assign b1_start_ts = section.settings.banner_1_start | append: ' 00:00' | date: '%s' | plus: 0
    if b1_start_ts > 0 and now_ts < b1_start_ts
      assign show_banner_1 = false
    endif
  endif
  if section.settings.banner_1_end != blank
    assign b1_end_ts = section.settings.banner_1_end | append: ' 23:59' | date: '%s' | plus: 0
    if b1_end_ts > 0 and now_ts > b1_end_ts
      assign show_banner_1 = false
    endif
  endif

  assign show_banner_2 = true
  if section.settings.banner_2_start != blank
    assign b2_start_ts = section.settings.banner_2_start | append: ' 00:00' | date: '%s' | plus: 0
    if b2_start_ts > 0 and now_ts < b2_start_ts
      assign show_banner_2 = false
    endif
  endif
  if section.settings.banner_2_end != blank
    assign b2_end_ts = section.settings.banner_2_end | append: ' 23:59' | date: '%s' | plus: 0
    if b2_end_ts > 0 and now_ts > b2_end_ts
      assign show_banner_2 = false
    endif
  endif
-%}

{%- if show_banner_1 or show_banner_2 -%}
<section class="inv-promos" id="promos-{{ section.id }}">
  <div class="inv-promos__container">
    <div class="inv-promos__grid{% unless show_banner_1 and show_banner_2 %} inv-promos__grid--single{% endunless %}">

      {%- if show_banner_1 -%}
      <a
        href="{{ section.settings.banner_1_link | default: '/collections/all' }}"
        class="inv-promos__card inv-promos__card--1"
        aria-label="{{ section.settings.banner_1_tag | escape }} — {{ section.settings.banner_1_title | escape }}"
      >
        {%- if section.settings.banner_1_image -%}
          <img
            src="{{ section.settings.banner_1_image | image_url: width: 800 }}"
            srcset="{{ section.settings.banner_1_image | image_url: width: 400 }} 400w,
                    {{ section.settings.banner_1_image | image_url: width: 600 }} 600w,
                    {{ section.settings.banner_1_image | image_url: width: 800 }} 800w"
            sizes="(max-width: 749px) 100vw, 50vw"
            alt="{{ section.settings.banner_1_image.alt | escape }}"
            loading="lazy"
            width="{{ section.settings.banner_1_image.width }}"
            height="{{ section.settings.banner_1_image.height }}"
            class="inv-promos__bg"
          >
        {%- endif -%}
        <div class="inv-promos__content">
          {%- if section.settings.banner_1_tag != blank -%}
            <span class="inv-promos__tag">{{ section.settings.banner_1_tag }}</span>
          {%- endif -%}
          {%- if section.settings.banner_1_title != blank -%}
            <span class="inv-promos__title">{{ section.settings.banner_1_title }}</span>
          {%- endif -%}
          {%- if section.settings.banner_1_subtitle != blank -%}
            <span class="inv-promos__subtitle">{{ section.settings.banner_1_subtitle }}</span>
          {%- endif -%}
        </div>
      </a>
      {%- endif -%}

      {%- if show_banner_2 -%}
      <a
        href="{{ section.settings.banner_2_link | default: '/collections/all' }}"
        class="inv-promos__card inv-promos__card--2"
        aria-label="{{ section.settings.banner_2_tag | escape }} — {{ section.settings.banner_2_title | escape }}"
      >
        {%- if section.settings.banner_2_image -%}
          <img
            src="{{ section.settings.banner_2_image | image_url: width: 800 }}"
            srcset="{{ section.settings.banner_2_image | image_url: width: 400 }} 400w,
                    {{ section.settings.banner_2_image | image_url: width: 600 }} 600w,
                    {{ section.settings.banner_2_image | image_url: width: 800 }} 800w"
            sizes="(max-width: 749px) 100vw, 50vw"
            alt="{{ section.settings.banner_2_image.alt | escape }}"
            loading="lazy"
            width="{{ section.settings.banner_2_image.width }}"
            height="{{ section.settings.banner_2_image.height }}"
            class="inv-promos__bg"
          >
        {%- endif -%}
        <div class="inv-promos__content">
          {%- if section.settings.banner_2_tag != blank -%}
            <span class="inv-promos__tag">{{ section.settings.banner_2_tag }}</span>
          {%- endif -%}
          {%- if section.settings.banner_2_title != blank -%}
            <span class="inv-promos__title">{{ section.settings.banner_2_title }}</span>
          {%- endif -%}
          {%- if section.settings.banner_2_subtitle != blank -%}
            <span class="inv-promos__subtitle">{{ section.settings.banner_2_subtitle }}</span>
          {%- endif -%}
        </div>
      </a>
      {%- endif -%}

    </div>
  </div>
</section>
{%- endif -%}

<style>
  /* ============================================
     INVICTA PROMO BANNERS v9.0
     Dark gradient cards with overlay text
     ============================================ */

  #promos-{{ section.id }} {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.section_bg }};
  }

  #promos-{{ section.id }} .inv-promos__container {
    max-width: var(--inv-container, 1400px);
    margin: 0 auto;
    padding: var(--inv-space-lg) var(--inv-space-xl) var(--inv-space-sm-plus);
  }

  #promos-{{ section.id }} .inv-promos__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--inv-space-md);
  }

  #promos-{{ section.id }} .inv-promos__grid--single {
    grid-template-columns: 1fr;
  }

  /* --- Card --- */
  #promos-{{ section.id }} .inv-promos__card {
    display: flex;
    align-items: flex-end;
    position: relative;
    overflow: hidden;
    height: 200px;
    padding: var(--inv-space-lg);
    text-decoration: none;
    transition: transform var(--inv-duration-moderate) ease;
  }

  /* Gradient backgrounds */
  #promos-{{ section.id }} .inv-promos__card--1 {
    background: linear-gradient(135deg, {{ section.settings.banner_1_gradient_start | default: '#1a1a2e' }}, {{ section.settings.banner_1_gradient_end | default: '#2d2d2d' }});
  }

  #promos-{{ section.id }} .inv-promos__card--2 {
    background: linear-gradient(135deg, {{ section.settings.banner_2_gradient_start | default: '#004d40' }}, {{ section.settings.banner_2_gradient_end | default: '#00695c' }});
  }

  /* Background image */
  #promos-{{ section.id }} .inv-promos__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Gradient overlay on top of image */
  #promos-{{ section.id }} .inv-promos__card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.6) 0%, transparent 100%);
    z-index: 1;
    pointer-events: none;
  }

  #promos-{{ section.id }} .inv-promos__card:hover {
    transform: scale(1.005);
  }

  #promos-{{ section.id }} .inv-promos__card:focus-visible {
    outline: var(--inv-focus-ring-width) solid var(--inv-accent);
    outline-offset: var(--inv-focus-ring-offset);
  }

  /* --- Content overlay --- */
  #promos-{{ section.id }} .inv-promos__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  #promos-{{ section.id }} .inv-promos__tag {
    display: inline-block;
    align-self: flex-start;
    background: var(--inv-accent);
    color: var(--inv-bg-elevated);
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 3px 8px;
    margin-bottom: 4px;
    line-height: 1.3;
  }

  #promos-{{ section.id }} .inv-promos__title {
    font-family: 'Barlow Condensed', Impact, 'Arial Narrow', sans-serif;
    font-size: 26px;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--inv-bg-elevated);
    line-height: 1.1;
  }

  #promos-{{ section.id }} .inv-promos__subtitle {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.4;
  }

  /* --- Responsive --- */
  @media (min-width: 990px) {
    #promos-{{ section.id }} .inv-promos__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 749px) {
    #promos-{{ section.id }} .inv-promos__container {
      padding: var(--inv-space-md) var(--inv-space-md) var(--inv-space-sm-plus);
    }

    #promos-{{ section.id }} .inv-promos__card {
      padding: var(--inv-space-md);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #promos-{{ section.id }} .inv-promos__card {
      transition: none;
    }

    #promos-{{ section.id }} .inv-promos__card:hover {
      transform: none;
    }
  }
</style>

{% schema %}
{
  "name": "Invicta Promo Banners",
  "settings": [
    {
      "type": "header",
      "content": "Section"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section background",
      "default": "#f5f5f5"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Banner 1"
    },
    {
      "type": "image_picker",
      "id": "banner_1_image",
      "label": "Banner image",
      "info": "Used as the card background. The gradient overlay sits on top."
    },
    {
      "type": "url",
      "id": "banner_1_link",
      "label": "Link"
    },
    {
      "type": "text",
      "id": "banner_1_tag",
      "label": "Tag badge",
      "default": "New Range"
    },
    {
      "type": "text",
      "id": "banner_1_title",
      "label": "Title",
      "default": "Viper Fuel Cell Nails"
    },
    {
      "type": "text",
      "id": "banner_1_subtitle",
      "label": "Subtitle",
      "default": "Premium gas nailer consumables"
    },
    {
      "type": "color",
      "id": "banner_1_gradient_start",
      "label": "Gradient start",
      "default": "#1a1a2e"
    },
    {
      "type": "color",
      "id": "banner_1_gradient_end",
      "label": "Gradient end",
      "default": "#2d2d2d"
    },
    {
      "type": "text",
      "id": "banner_1_start",
      "label": "Start date (YYYY-MM-DD)",
      "info": "Leave blank to always show."
    },
    {
      "type": "text",
      "id": "banner_1_end",
      "label": "End date (YYYY-MM-DD)",
      "info": "Leave blank for no end date."
    },
    {
      "type": "header",
      "content": "Banner 2"
    },
    {
      "type": "image_picker",
      "id": "banner_2_image",
      "label": "Banner image",
      "info": "Used as the card background. The gradient overlay sits on top."
    },
    {
      "type": "url",
      "id": "banner_2_link",
      "label": "Link"
    },
    {
      "type": "text",
      "id": "banner_2_tag",
      "label": "Tag badge",
      "default": "Just Landed"
    },
    {
      "type": "text",
      "id": "banner_2_title",
      "label": "Title",
      "default": "Makita RM350D Robotic Mower"
    },
    {
      "type": "text",
      "id": "banner_2_subtitle",
      "label": "Subtitle",
      "default": "Cordless, GPS-guided lawn care"
    },
    {
      "type": "color",
      "id": "banner_2_gradient_start",
      "label": "Gradient start",
      "default": "#004d40"
    },
    {
      "type": "color",
      "id": "banner_2_gradient_end",
      "label": "Gradient end",
      "default": "#00695c"
    },
    {
      "type": "text",
      "id": "banner_2_start",
      "label": "Start date (YYYY-MM-DD)",
      "info": "Leave blank to always show."
    },
    {
      "type": "text",
      "id": "banner_2_end",
      "label": "End date (YYYY-MM-DD)",
      "info": "Leave blank for no end date."
    }
  ],
  "presets": [
    {
      "name": "Invicta Promo Banners"
    }
  ]
}
{% endschema %}
