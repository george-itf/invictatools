{% comment %}
  ============================================================================
  INVICTA TRADE CTA v2.0.1 — Full-width red trade account banner
  ============================================================================
  Two-column section on a red (--inv-accent) background. Left: eyebrow,
  heading, description, white CTA button. Right: list of benefit blocks
  with white circle checkmarks. Designed to break the page rhythm and be
  impossible to scroll past.

  Replaces the deprecated v1 stub.

  Trade 15.4.0 Compatible
  ============================================================================
{% endcomment %}

{%- liquid
  assign bg_color = section.settings.background_color | default: '#e11d26'
  assign benefit_blocks = section.blocks | where: 'type', 'benefit'
-%}

<section class="inv-trade" id="trade-{{ section.id }}" aria-label="{{ section.settings.heading | escape }}">
  <div class="inv-trade__container">
    <div class="inv-trade__layout">

      {%- comment -%} ====================================
          LEFT COLUMN: Content
          ==================================== {%- endcomment -%}
      <div class="inv-trade__content">
        {%- if section.settings.eyebrow_text != blank -%}
          <span class="inv-trade__eyebrow">{{ section.settings.eyebrow_text | escape }}</span>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="inv-trade__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <p class="inv-trade__desc">{{ section.settings.description | escape }}</p>
        {%- endif -%}

        {%- if section.settings.button_text != blank -%}
          <a
            href="{{ section.settings.button_link | default: '#' }}"
            class="inv-trade__btn"
          >
            {{ section.settings.button_text | escape }}
          </a>
        {%- endif -%}
      </div>

      {%- comment -%} ====================================
          RIGHT COLUMN: Benefit list
          ==================================== {%- endcomment -%}
      {%- if benefit_blocks.size > 0 -%}
        <ul class="inv-trade__benefits" role="list">
          {%- for block in benefit_blocks -%}
            {%- if block.settings.text != blank -%}
              <li class="inv-trade__benefit" {{ block.shopify_attributes }}>
                <span class="inv-trade__check" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </span>
                <span class="inv-trade__benefit-text">{{ block.settings.text | escape }}</span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}

    </div>
  </div>
</section>

<style>
  /* ============================================================================
     INVICTA TRADE CTA v2.0 — Full-width red trade banner
     ============================================================================ */

  #trade-{{ section.id }} {
    position: relative;
    background: {{ bg_color }};
    padding-top: {{ section.settings.padding_top | default: 64 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 64 }}px;
    overflow: hidden;
    color: var(--inv-bg-elevated);
  }

  /* Decorative circle, top-right */
  #trade-{{ section.id }}::after {
    content: '';
    position: absolute;
    top: -60px;
    right: -60px;
    width: 180px;
    height: 180px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.08);
    pointer-events: none;
    z-index: 0;
  }

  #trade-{{ section.id }} .inv-trade__container {
    position: relative;
    z-index: 1;
    max-width: var(--inv-container, 1400px);
    margin: 0 auto;
    padding: 0 var(--inv-page-gutter, 1.5rem);
  }

  #trade-{{ section.id }} .inv-trade__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--inv-space-xl);
    align-items: center;
  }

  /* ----------------------------------------
     LEFT COLUMN — content
     ---------------------------------------- */
  #trade-{{ section.id }} .inv-trade__content {
    display: flex;
    flex-direction: column;
    gap: var(--inv-space-md);
    align-items: flex-start;
  }

  #trade-{{ section.id }} .inv-trade__eyebrow {
    display: inline-block;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.2;
  }

  #trade-{{ section.id }} .inv-trade__heading {
    font-family: var(--inv-font-display);
    font-size: var(--inv-text-xl);
    font-weight: 900;
    text-transform: uppercase;
    color: var(--inv-bg-elevated);
    line-height: 1.05;
    letter-spacing: -0.5px;
    margin: 0;
    max-width: 520px;
  }

  #trade-{{ section.id }} .inv-trade__desc {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.55;
    max-width: 520px;
    margin: 0;
  }

  #trade-{{ section.id }} .inv-trade__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 52px;
    padding: 0 32px;
    background: var(--inv-bg-elevated);
    color: var(--inv-accent);
    font-size: 14px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-decoration: none;
    transition: background var(--inv-duration-normal) ease,
                color var(--inv-duration-normal) ease;
    margin-top: var(--inv-space-sm);
  }

  #trade-{{ section.id }} .inv-trade__btn:hover {
    background: var(--inv-dark-deep);
    color: var(--inv-bg-elevated);
  }

  #trade-{{ section.id }} .inv-trade__btn:focus-visible {
    outline: 2px solid var(--inv-bg-elevated);
    outline-offset: 3px;
  }

  /* ----------------------------------------
     RIGHT COLUMN — benefit list
     ---------------------------------------- */
  #trade-{{ section.id }} .inv-trade__benefits {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--inv-space-md);
  }

  #trade-{{ section.id }} .inv-trade__benefit {
    display: flex;
    align-items: center;
    gap: var(--inv-space-sm-plus);
    color: var(--inv-bg-elevated);
    font-size: 15px;
    font-weight: 600;
    line-height: 1.4;
  }

  #trade-{{ section.id }} .inv-trade__check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--inv-bg-elevated);
    color: var(--inv-accent);
    flex-shrink: 0;
  }

  #trade-{{ section.id }} .inv-trade__check svg {
    width: 14px;
    height: 14px;
    display: block;
  }

  #trade-{{ section.id }} .inv-trade__benefit-text {
    flex: 1 1 auto;
  }

  /* ----------------------------------------
     DESKTOP (990px+) — two-column layout
     ---------------------------------------- */
  @media (min-width: 990px) {
    #trade-{{ section.id }} .inv-trade__layout {
      grid-template-columns: 1fr 1fr;
      gap: var(--inv-space-3xl);
    }

    #trade-{{ section.id }}::after {
      width: 280px;
      height: 280px;
      top: -80px;
      right: -80px;
    }
  }

  /* ----------------------------------------
     MOBILE (<750px)
     ---------------------------------------- */
  @media (max-width: 749px) {
    #trade-{{ section.id }} .inv-trade__container {
      padding: 0 var(--inv-mobile-gutter);
    }

    #trade-{{ section.id }}::after {
      width: 120px;
      height: 120px;
      top: -40px;
      right: -40px;
    }

    #trade-{{ section.id }} .inv-trade__benefit {
      font-size: 14px;
    }
  }

  /* ----------------------------------------
     REDUCED MOTION
     ---------------------------------------- */
  @media (prefers-reduced-motion: reduce) {
    #trade-{{ section.id }} .inv-trade__btn {
      transition: none;
    }
  }
</style>

{% schema %}
{
  "name": "Trade Account CTA",
  "tag": "section",
  "class": "section-trade-cta",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow text",
      "default": "For Tradespeople"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Open a Trade Account"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Volume discounts, credit terms, a dedicated account manager, and priority on new stock. Takes 2 minutes to apply."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Apply for Trade Account →"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour",
      "default": "#e11d26"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 64,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 64,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Benefit text",
          "default": "Volume pricing on 15,000+ products"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trade Account CTA",
      "settings": {
        "eyebrow_text": "For Tradespeople",
        "heading": "Open a Trade Account",
        "description": "Volume discounts, credit terms, a dedicated account manager, and priority on new stock. Takes 2 minutes to apply.",
        "button_text": "Apply for Trade Account →"
      },
      "blocks": [
        { "type": "benefit", "settings": { "text": "Volume pricing on 15,000+ products" } },
        { "type": "benefit", "settings": { "text": "30-day credit terms" } },
        { "type": "benefit", "settings": { "text": "Dedicated account manager" } },
        { "type": "benefit", "settings": { "text": "Priority access to new stock" } },
        { "type": "benefit", "settings": { "text": "Free next-day on all orders" } }
      ]
    }
  ]
}
{% endschema %}
