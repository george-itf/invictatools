{% comment %}
  ============================================
  INVICTA TRUST & REVIEWS v5.0
  ============================================
  Unified section. Not SaaS. Not AI-generated.
  Feels like a real trade tool shop.

  Layout:
  1. Hero row: heading + text + stats left, rating badges right
  2. Branch strip: wide images with overlay text
  3. Reviews: scrolling ticker, tight to the section

  Trade 15.4.0 Compatible
  ============================================
{% endcomment %}

{%- liquid
  assign stat_blocks = section.blocks | where: 'type', 'stat'
  assign point_blocks = section.blocks | where: 'type', 'point'
  assign rating_blocks = section.blocks | where: 'type', 'rating'
-%}

<section class="inv-tr5" id="inv-tr5-{{ section.id }}">

  {%- comment -%} ═══ PART 1: Hero content ═══ {%- endcomment -%}
  <div class="inv-tr5__hero">
    <div class="inv-tr5__wrap">
      <div class="inv-tr5__hero-grid">

        <div class="inv-tr5__content">
          {%- if section.settings.eyebrow != blank -%}
            <span class="inv-tr5__eyebrow">{{ section.settings.eyebrow }}</span>
          {%- endif -%}

          {%- if section.settings.heading != blank -%}
            <h2 class="inv-tr5__heading">{{ section.settings.heading }}</h2>
          {%- endif -%}

          {%- if section.settings.text != blank -%}
            <div class="inv-tr5__text">{{ section.settings.text }}</div>
          {%- endif -%}

          {%- if point_blocks.size > 0 -%}
            <ul class="inv-tr5__points">
              {%- for block in point_blocks -%}
                {%- if block.settings.text != blank -%}
                  <li class="inv-tr5__point" {{ block.shopify_attributes }}>
                    <svg class="inv-tr5__point-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <circle cx="12" cy="12" r="12" fill="#16a34a"/>
                      <path d="M7 12.5l3 3 7-7" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span>{{ block.settings.text }}</span>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          {%- endif -%}

          {%- if stat_blocks.size > 0 -%}
            <div class="inv-tr5__stats">
              {%- for block in stat_blocks -%}
                <div class="inv-tr5__stat" {{ block.shopify_attributes }}>
                  <span class="inv-tr5__stat-num" data-itr5-counter="{{ block.settings.number }}">{{ block.settings.number }}</span>
                  <span class="inv-tr5__stat-label">{{ block.settings.label }}</span>
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- if section.settings.cta_text != blank and section.settings.cta_link != blank -%}
            <a href="{{ section.settings.cta_link }}" class="inv-tr5__cta">
              {{ section.settings.cta_text }}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          {%- endif -%}
        </div>

        {%- comment -%} Right: compact rating badges {%- endcomment -%}
        {%- if rating_blocks.size > 0 -%}
          <div class="inv-tr5__ratings">
            {%- for block in rating_blocks -%}
              <a
                href="{{ block.settings.url }}"
                target="_blank"
                rel="noopener noreferrer"
                class="inv-tr5__rating inv-tr5__rating--{{ block.settings.platform }}"
                aria-label="{{ block.settings.text }} - opens in new tab"
                {{ block.shopify_attributes }}
              >
                <span class="inv-tr5__rating-icon">
                  {%- case block.settings.platform -%}
                    {%- when 'google' -%}
                      <svg width="22" height="22" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                      </svg>
                    {%- when 'facebook' -%}
                      <svg width="22" height="22" viewBox="0 0 24 24" fill="#1877F2" aria-hidden="true">
                        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                      </svg>
                    {%- when 'trustpilot' -%}
                      <svg width="22" height="22" viewBox="0 0 24 24" fill="#00b67a" aria-hidden="true">
                        <path d="M12 0l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 0z"/>
                      </svg>
                  {%- endcase -%}
                </span>
                <span class="inv-tr5__rating-score">{{ block.settings.text | split: ' ' | first }}</span>
                <span class="inv-tr5__rating-stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9734;</span>
                <span class="inv-tr5__rating-name">{{ block.settings.platform | capitalize }}&nbsp;&rarr;</span>
              </a>
            {%- endfor -%}
          </div>
        {%- endif -%}

      </div>
    </div>
  </div>

  {%- comment -%} ═══ PART 2: Branch images strip ═══ {%- endcomment -%}
  {%- if section.settings.image_1 != blank or section.settings.image_2 != blank -%}
    <div class="inv-tr5__branches">
      <div class="inv-tr5__wrap">
        <div class="inv-tr5__branches-grid">
          {%- if section.settings.image_1 != blank -%}
            <div class="inv-tr5__branch">
              <img
                src="{{ section.settings.image_1 | image_url: width: 720 }}"
                srcset="{{ section.settings.image_1 | image_url: width: 480 }} 480w,
                        {{ section.settings.image_1 | image_url: width: 720 }} 720w"
                sizes="(max-width: 680px) 100vw, 50vw"
                alt="{{ section.settings.image_1.alt | default: section.settings.image_1_caption }}"
                loading="lazy"
                width="{{ section.settings.image_1.width }}"
                height="{{ section.settings.image_1.height }}"
                class="inv-tr5__branch-img"
              >
              <div class="inv-tr5__branch-overlay">
                {%- if section.settings.image_1_caption != blank -%}
                  <span class="inv-tr5__branch-name">{{ section.settings.image_1_caption }}</span>
                {%- endif -%}
                {%- if section.settings.badge_text != blank -%}
                  <span class="inv-tr5__branch-badge">{{ section.settings.badge_text }}</span>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}

          {%- if section.settings.image_2 != blank -%}
            <div class="inv-tr5__branch">
              <img
                src="{{ section.settings.image_2 | image_url: width: 720 }}"
                srcset="{{ section.settings.image_2 | image_url: width: 480 }} 480w,
                        {{ section.settings.image_2 | image_url: width: 720 }} 720w"
                sizes="(max-width: 680px) 100vw, 50vw"
                alt="{{ section.settings.image_2.alt | default: section.settings.image_2_caption }}"
                loading="lazy"
                width="{{ section.settings.image_2.width }}"
                height="{{ section.settings.image_2.height }}"
                class="inv-tr5__branch-img"
              >
              <div class="inv-tr5__branch-overlay">
                {%- if section.settings.image_2_caption != blank -%}
                  <span class="inv-tr5__branch-name">{{ section.settings.image_2_caption }}</span>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ═══ PART 3: Review ticker ═══ {%- endcomment -%}
  {%- assign has_reviews = false -%}
  {%- for i in (1..10) -%}
    {%- assign enabled_key = 'review_' | append: i | append: '_enabled' -%}
    {%- assign text_key = 'review_' | append: i | append: '_text' -%}
    {%- if section.settings[enabled_key] and section.settings[text_key] != blank -%}
      {%- assign has_reviews = true -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}

  {%- if has_reviews -%}
    <div class="inv-tr5__reviews" aria-label="Customer reviews">
      <div class="inv-tr5__wrap">
        <div class="inv-tr5__reviews-header">
          {%- if section.settings.review_heading != blank -%}
            <span class="inv-tr5__reviews-label">{{ section.settings.review_heading }}</span>
          {%- endif -%}
        </div>
        <div class="inv-tr5__reviews-overflow">
          <div class="inv-tr5__reviews-track" data-itr5-ticker>
        {%- for pass in (1..2) -%}
          {%- for i in (1..10) -%}
            {%- assign enabled_key = 'review_' | append: i | append: '_enabled' -%}
            {%- assign text_key = 'review_' | append: i | append: '_text' -%}
            {%- assign author_key = 'review_' | append: i | append: '_author' -%}
            {%- assign source_key = 'review_' | append: i | append: '_source' -%}
            {%- if section.settings[enabled_key] and section.settings[text_key] != blank -%}
              {%- assign review_author = section.settings[author_key] -%}
              {%- assign review_source = section.settings[source_key] -%}
              {%- assign name_parts = review_author | split: ' ' -%}
              {%- assign initials = '' -%}
              {%- if name_parts.size > 1 -%}
                {%- assign first_initial = name_parts[0] | slice: 0 -%}
                {%- assign last_initial = name_parts[1] | slice: 0 -%}
                {%- assign initials = first_initial | append: last_initial -%}
              {%- elsif name_parts.size == 1 -%}
                {%- assign initials = name_parts[0] | slice: 0 -%}
              {%- endif -%}
              <div class="inv-tr5__review" aria-hidden="{% if pass == 2 %}true{% else %}false{% endif %}">
                <div class="inv-tr5__review-stars" aria-label="5 out of 5 stars">
                  {%- for s in (1..5) -%}
                    <span class="inv-tr5__star--filled">&#9733;</span>
                  {%- endfor -%}
                </div>
                <p class="inv-tr5__review-text">&ldquo;{{ section.settings[text_key] }}&rdquo;</p>
                <div class="inv-tr5__review-footer">
                  <span class="inv-tr5__review-initials">{{ initials }}</span>
                  <span class="inv-tr5__review-author">{{ review_author }}</span>
                  {%- if review_source != blank -%}
                    <span class="inv-tr5__review-source inv-tr5__review-source--{{ review_source }}">{{ review_source }}</span>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        {%- endfor -%}
          </div>
        </div>
      </div>
    </div>
  {%- endif -%}

</section>

<style>
  /* ============================================
     INVICTA TRUST & REVIEWS v5.0
     Trade shop feel. Not SaaS. Not generic.
     ============================================ */

  #inv-tr5-{{ section.id }} {
    --itr5-accent: var(--inv-accent, #e11d26);
    --itr5-dark: #1e2125;
    --itr5-fg: #fff;
    --itr5-fg-muted: rgba(255, 255, 255, 0.6);
    --itr5-border: rgba(255, 255, 255, 0.1);
  }

  .inv-tr5 {
    background: var(--itr5-dark);
    border-top: 4px solid var(--itr5-accent);
  }

  .inv-tr5__wrap {
    max-width: var(--inv-container, 1280px);
    margin: 0 auto;
    padding: 0 var(--inv-gutter, 24px);
  }

  /* ----------------------------------------
     PART 1: HERO
     ---------------------------------------- */
  .inv-tr5__hero {
    padding: {{ section.settings.padding_top | default: 36 }}px 0 0;
  }

  .inv-tr5__hero-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 24px;
    align-items: start;
  }

  .inv-tr5__content {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .inv-tr5__eyebrow {
    font-size: 11px;
    font-weight: 700;
    color: var(--itr5-accent);
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  .inv-tr5__heading {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(26px, 3.5vw, 36px);
    font-weight: 900;
    color: var(--itr5-fg);
    line-height: 1.1;
    margin: 0;
  }

  .inv-tr5__text {
    font-size: 15px;
    color: var(--itr5-fg-muted);
    line-height: 1.6;
    max-width: 520px;
  }

  .inv-tr5__text p { margin: 0; }

  .inv-tr5__points {
    list-style: none;
    margin: 2px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .inv-tr5__point {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    font-weight: 600;
    color: var(--itr5-fg);
  }

  .inv-tr5__point-icon { flex-shrink: 0; }

  /* Stats */
  .inv-tr5__stats {
    display: flex;
    gap: 0;
    margin-top: 4px;
    padding-top: 14px;
    border-top: 1px solid var(--itr5-border);
  }

  .inv-tr5__stat {
    padding-right: 28px;
    margin-right: 28px;
    border-right: 1px solid var(--itr5-border);
  }

  .inv-tr5__stat:last-child {
    border-right: none;
    margin-right: 0;
    padding-right: 0;
  }

  .inv-tr5__stat-num {
    display: block;
    font-family: 'DM Sans', sans-serif;
    font-size: 26px;
    font-weight: 900;
    color: var(--itr5-accent);
    line-height: 1;
  }

  .inv-tr5__stat-label {
    display: block;
    font-size: 10px;
    font-weight: 700;
    color: var(--itr5-fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: 4px;
  }

  /* CTA */
  .inv-tr5__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 13px 28px;
    background: var(--itr5-accent);
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-decoration: none;
    border-radius: 0;
    transition: background 0.15s ease;
    align-self: flex-start;
  }

  .inv-tr5__cta:hover { background: #c4161f; }
  .inv-tr5__cta:focus-visible { outline: 2px solid var(--itr5-accent); outline-offset: 2px; }

  /* ---- Rating badges (right side, stacked) ---- */
  .inv-tr5__ratings {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-top: 4px;
  }

  .inv-tr5__rating {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--itr5-border);
    border-radius: 4px;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s ease, border-color 0.15s ease;
    min-width: 190px;
  }

  .inv-tr5__rating:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .inv-tr5__rating:focus-visible {
    outline: 2px solid var(--itr5-accent);
    outline-offset: 2px;
  }

  .inv-tr5__rating-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .inv-tr5__rating-score {
    font-family: 'DM Sans', sans-serif;
    font-size: 22px;
    font-weight: 900;
    color: var(--itr5-fg);
    line-height: 1;
  }

  .inv-tr5__rating-stars {
    color: #fbbf24;
    font-size: 14px;
    letter-spacing: 1px;
  }

  .inv-tr5__rating-name {
    font-size: 11px;
    font-weight: 600;
    color: var(--itr5-fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-left: auto;
  }

  /* ----------------------------------------
     PART 2: BRANCH IMAGES
     ---------------------------------------- */
  .inv-tr5__branches {
    padding: 24px 0 20px;
  }

  .inv-tr5__branches-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .inv-tr5__branch {
    position: relative;
    overflow: hidden;
    border-radius: 4px;
    aspect-ratio: 16 / 7;
  }

  .inv-tr5__branch-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .inv-tr5__branch-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0) 50%);
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding: 14px 16px;
  }

  .inv-tr5__branch-name {
    font-size: 14px;
    font-weight: 800;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .inv-tr5__branch-badge {
    font-size: 10px;
    font-weight: 700;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: var(--itr5-accent);
    padding: 4px 10px;
    border-radius: 2px;
  }

  /* ----------------------------------------
     PART 3: REVIEWS
     ---------------------------------------- */
  .inv-tr5__reviews {
    padding: 0 0 {{ section.settings.padding_bottom | default: 36 }}px;
  }

  .inv-tr5__reviews-header {
    margin-bottom: 16px;
  }

  .inv-tr5__reviews-label {
    font-size: 13px;
    font-weight: 700;
    color: var(--itr5-fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .inv-tr5__reviews-overflow {
    overflow: hidden;
  }

  .inv-tr5__reviews-track {
    display: flex;
    gap: 14px;
    animation: inv-tr5-scroll 45s linear infinite;
    width: max-content;
  }

  .inv-tr5__reviews-track:hover {
    animation-play-state: paused;
  }

  @keyframes inv-tr5-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(calc(-50% - 7px)); }
  }

  .inv-tr5__review {
    flex-shrink: 0;
    width: 260px;
    padding: 14px 16px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--itr5-border);
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .inv-tr5__review-stars {
    font-size: 14px;
    letter-spacing: 1px;
    line-height: 1;
  }

  .inv-tr5__star--filled { color: #fbbf24; }

  .inv-tr5__review-text {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.5;
    margin: 0;
    font-style: italic;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .inv-tr5__review-footer {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: auto;
  }

  .inv-tr5__review-initials {
    width: 28px;
    height: 28px;
    min-width: 28px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    font-weight: 700;
    color: var(--itr5-fg-muted);
    text-transform: uppercase;
  }

  .inv-tr5__review-author {
    font-size: 12px;
    font-weight: 700;
    color: var(--itr5-fg);
  }

  .inv-tr5__review-source {
    font-size: 9px;
    font-weight: 600;
    padding: 2px 6px;
    border-radius: 2px;
    text-transform: uppercase;
    color: #fff;
    margin-left: auto;
  }

  .inv-tr5__review-source--google { background: #5f6368; }
  .inv-tr5__review-source--facebook { background: #1877F2; }
  .inv-tr5__review-source--trustpilot { background: #00b67a; }
  .inv-tr5__review-source--judgeme { background: #444; }

  /* ----------------------------------------
     RESPONSIVE
     ---------------------------------------- */
  @media (max-width: 960px) {
    .inv-tr5__hero-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .inv-tr5__ratings {
      flex-direction: row;
      flex-wrap: wrap;
      padding-top: 0;
    }

    .inv-tr5__rating {
      min-width: 0;
      flex: 1 1 auto;
    }
  }

  @media (max-width: 680px) {
    .inv-tr5__hero {
      padding-top: 28px;
    }

    .inv-tr5__branches {
      padding: 18px 0 16px;
    }

    .inv-tr5__branches-grid {
      grid-template-columns: 1fr;
      gap: 10px;
    }

    .inv-tr5__branch {
      aspect-ratio: 16 / 8;
    }

    .inv-tr5__stats {
      flex-wrap: wrap;
      gap: 14px 0;
    }

    .inv-tr5__stat {
      flex: 0 0 auto;
    }

    .inv-tr5__cta {
      width: 100%;
      justify-content: center;
    }

    .inv-tr5__ratings {
      flex-direction: column;
    }

    .inv-tr5__reviews {
      padding-bottom: 28px;
    }
  }

  @media (max-width: 420px) {
    .inv-tr5__stat {
      border-right: none;
      margin-right: 16px;
      padding-right: 0;
    }

    .inv-tr5__heading {
      font-size: 22px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .inv-tr5__reviews-track { animation: none; }
    .inv-tr5__cta, .inv-tr5__rating { transition: none; }
  }
</style>

<script>
(function() {
  var section = document.getElementById('inv-tr5-{{ section.id }}');
  if (!section) return;

  /* =========================================
     COUNTER ANIMATION
     ========================================= */
  var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function easeOutQuart(t) { return 1 - Math.pow(1 - t, 4); }

  function parseStatNumber(raw) {
    var match = raw.match(/^([\d,]+\.?\d*)\s*(.*)$/);
    if (!match) return null;
    var numStr = match[1].replace(/,/g, '');
    var num = parseFloat(numStr);
    var suffix = match[2] || '';
    var hasDecimal = numStr.indexOf('.') !== -1;
    var decimals = hasDecimal ? (numStr.split('.')[1] || '').length : 0;
    var isLarge = num >= 1000;
    return { target: num, suffix: suffix, decimals: decimals, isLarge: isLarge };
  }

  function formatNumber(val, parsed) {
    if (parsed.decimals > 0) return val.toFixed(parsed.decimals);
    var rounded = Math.round(val);
    return parsed.isLarge ? rounded.toLocaleString() : rounded.toString();
  }

  function animateCounter(el) {
    if (el.dataset.animated) return;
    el.dataset.animated = 'true';
    var raw = el.dataset.itr5Counter;
    var parsed = parseStatNumber(raw);
    if (!parsed) return;
    if (reducedMotion) { el.textContent = formatNumber(parsed.target, parsed) + parsed.suffix; return; }
    var duration = 2000;
    var start = null;
    function step(ts) {
      if (!start) start = ts;
      var elapsed = ts - start;
      var progress = Math.min(elapsed / duration, 1);
      var current = easeOutQuart(progress) * parsed.target;
      el.textContent = formatNumber(current, parsed) + parsed.suffix;
      if (progress < 1) requestAnimationFrame(step);
    }
    el.textContent = '0' + parsed.suffix;
    requestAnimationFrame(step);
  }

  var statsWrap = section.querySelector('.inv-tr5__stats');
  if (statsWrap) {
    var counters = statsWrap.querySelectorAll('[data-itr5-counter]');
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          counters.forEach(function(el) { animateCounter(el); });
          obs.disconnect();
        }
      });
    }, { threshold: 0.5 });
    obs.observe(statsWrap);
  }

  /* =========================================
     JUDGE.ME REVIEW FETCH
     ========================================= */
  function getJudgeMeToken() {
    if (window.jdgm && window.jdgm.publicToken) return window.jdgm.publicToken;
    var scripts = document.querySelectorAll('script[src*="judge.me"]');
    for (var i = 0; i < scripts.length; i++) {
      var src = scripts[i].getAttribute('src') || '';
      var tokenMatch = src.match(/api_token=([^&]+)/);
      if (tokenMatch) return tokenMatch[1];
    }
    return null;
  }

  function getInitials(name) {
    if (!name) return '?';
    var parts = name.trim().split(/\s+/);
    var initials = parts[0].charAt(0);
    if (parts.length > 1) initials += parts[parts.length - 1].charAt(0);
    return initials.toUpperCase();
  }

  function getSourceClass(source) {
    if (!source) return 'judgeme';
    var s = source.toLowerCase();
    if (s.indexOf('google') !== -1) return 'google';
    if (s.indexOf('facebook') !== -1) return 'facebook';
    if (s.indexOf('trustpilot') !== -1) return 'trustpilot';
    return 'judgeme';
  }

  function renderStars(rating) {
    var html = '';
    for (var i = 1; i <= 5; i++) {
      html += '<span class="inv-tr5__star--' + (i <= rating ? 'filled' : 'empty') + '">&#9733;</span>';
    }
    return html;
  }

  function buildReviewCard(review, ariaHidden) {
    var name = (review.reviewer && review.reviewer.name) ? review.reviewer.name : (review.author || 'Customer');
    var rating = review.rating || 5;
    var text = review.body || review.text || '';
    var source = review.source || 'Judge.me';
    var srcClass = getSourceClass(source);
    var srcLabel = srcClass === 'judgeme' ? 'Judge.me' : source;

    return '<div class="inv-tr5__review" aria-hidden="' + (ariaHidden ? 'true' : 'false') + '">' +
      '<div class="inv-tr5__review-stars" aria-label="' + rating + ' out of 5 stars">' + renderStars(rating) + '</div>' +
      '<p class="inv-tr5__review-text">&ldquo;' + text.replace(/</g, '&lt;').replace(/>/g, '&gt;') + '&rdquo;</p>' +
      '<div class="inv-tr5__review-footer">' +
        '<span class="inv-tr5__review-initials">' + getInitials(name) + '</span>' +
        '<span class="inv-tr5__review-author">' + name.replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</span>' +
        '<span class="inv-tr5__review-source inv-tr5__review-source--' + srcClass + '">' + srcLabel + '</span>' +
      '</div>' +
    '</div>';
  }

  function replaceTickerWithLiveReviews(reviews) {
    var ticker = section.querySelector('[data-itr5-ticker]');
    if (!ticker || reviews.length === 0) return;
    var html = '';
    reviews.forEach(function(r) { html += buildReviewCard(r, false); });
    reviews.forEach(function(r) { html += buildReviewCard(r, true); });
    ticker.innerHTML = html;
    ticker.style.animation = 'none';
    ticker.offsetHeight;
    ticker.style.animation = '';
  }

  function fetchJudgeMeReviews() {
    var token = getJudgeMeToken();
    if (!token) return;
    var shopDomain = (window.Shopify && window.Shopify.shop) ? window.Shopify.shop : 'invictatools.co.uk';
    var url = 'https://judge.me/api/v1/reviews?shop_domain=' + encodeURIComponent(shopDomain) +
              '&api_token=' + encodeURIComponent(token) + '&per_page=15&sort_by=most_helpful';
    fetch(url)
      .then(function(res) { if (!res.ok) throw new Error('HTTP ' + res.status); return res.json(); })
      .then(function(data) {
        var reviews = data.reviews || data.data || [];
        if (reviews.length > 0) replaceTickerWithLiveReviews(reviews);
      })
      .catch(function() { /* keep hardcoded fallbacks */ });
  }

  fetchJudgeMeReviews();

  /* =========================================
     SHOPIFY EDITOR EVENTS
     ========================================= */
  document.addEventListener('shopify:section:load', function(e) {
    if (e.detail && e.detail.sectionId === '{{ section.id }}') {
      var els = section.querySelectorAll('[data-itr5-counter]');
      els.forEach(function(el) { el.dataset.animated = ''; animateCounter(el); });
    }
  });

  document.addEventListener('shopify:section:select', function(e) {
    if (e.detail && e.detail.sectionId === '{{ section.id }}') {
      var ticker = section.querySelector('[data-itr5-ticker]');
      if (ticker) ticker.style.animationPlayState = 'paused';
    }
  });
})();
</script>

