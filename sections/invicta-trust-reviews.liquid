{% comment %}
  ============================================
  INVICTA TRUST & REVIEWS v8.0
  ============================================
  Static review section — no carousel, no gradients.

  Layout:
  1. Hero row: heading + text left, rating badges right
  2. Stats row: full-width below hero grid, CTA pushed right
  3. Branch strip: wide images with solid label pills (no overlay gradient)
  4. Reviews: static 4-card grid with "Read all reviews" CTA beneath

  v8.0 changes:
  - Replaced animated ticker with a static 4-up grid
  - Removed mask-image / linear-gradient on the review block and branch overlay
  - Swapped ★ Unicode glyphs for SVG stars (consistent rendering, no emoji risk)
  - Dropped ticker duplication JS and Judge.me live-fetch

  Trade 15.4.0 Compatible
  ============================================
{% endcomment %}

{%- liquid
  assign stat_blocks = section.blocks | where: 'type', 'stat'
  assign point_blocks = section.blocks | where: 'type', 'point'
  assign rating_blocks = section.blocks | where: 'type', 'rating'
-%}

<section class="inv-tr5" id="inv-tr5-{{ section.id }}">

  {%- comment -%} ═══ PART 1: Hero content ═══ {%- endcomment -%}
  <div class="inv-tr5__hero">
    <div class="inv-tr5__wrap">
      <div class="inv-tr5__hero-grid">

        <div class="inv-tr5__content">
          {%- if section.settings.eyebrow != blank -%}
            <span class="inv-tr5__eyebrow">{{ section.settings.eyebrow }}</span>
          {%- endif -%}

          {%- if section.settings.heading != blank -%}
            <h2 class="inv-tr5__heading">{{ section.settings.heading }}</h2>
          {%- endif -%}

          {%- if section.settings.text != blank -%}
            <div class="inv-tr5__text">{{ section.settings.text }}</div>
          {%- endif -%}

          {%- if point_blocks.size > 0 -%}
            <ul class="inv-tr5__points">
              {%- for block in point_blocks -%}
                {%- if block.settings.text != blank -%}
                  <li class="inv-tr5__point" {{ block.shopify_attributes }}>
                    <svg class="inv-tr5__point-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" focusable="false" aria-hidden="true">
                      <circle cx="12" cy="12" r="12" fill="#15803d"/>
                      <path d="M7 12.5l3 3 7-7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span>{{ block.settings.text }}</span>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>

        {%- comment -%} Right: compact rating badges {%- endcomment -%}
        {%- if rating_blocks.size > 0 -%}
          <div class="inv-tr5__ratings">
            {%- for block in rating_blocks -%}
              <a
                href="{{ block.settings.url }}"
                target="_blank"
                rel="noopener noreferrer"
                class="inv-tr5__rating inv-tr5__rating--{{ block.settings.platform }}"
                aria-label="{{ block.settings.text }} - opens in new tab"
                {{ block.shopify_attributes }}
              >
                <span class="inv-tr5__rating-icon">
                  {%- case block.settings.platform -%}
                    {%- when 'google' -%}
                      <svg width="22" height="22" viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                      </svg>
                    {%- when 'facebook' -%}
                      <svg width="22" height="22" viewBox="0 0 24 24" fill="#1877F2" focusable="false" aria-hidden="true">
                        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                      </svg>
                    {%- when 'trustpilot' -%}
                      <svg width="22" height="22" viewBox="0 0 24 24" fill="#00b67a" focusable="false" aria-hidden="true">
                        <path d="M12 0l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 0z"/>
                      </svg>
                  {%- endcase -%}
                </span>
                <span class="inv-tr5__rating-score">{{ block.settings.text | split: ' ' | first }}</span>
                <span class="inv-tr5__rating-stars" aria-hidden="true">
                  {%- for s in (1..5) -%}
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" focusable="false" aria-hidden="true">
                      <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8 5.8 21.3l2.4-7.4L2 9.4h7.6z"/>
                    </svg>
                  {%- endfor -%}
                </span>
                <span class="inv-tr5__rating-name">{{ block.settings.platform | capitalize }}&nbsp;&rarr;</span>
              </a>
            {%- endfor -%}
          </div>
        {%- endif -%}

      </div>

      {%- comment -%} Stats row: full-width, below the hero grid {%- endcomment -%}
      {%- if stat_blocks.size > 0 or section.settings.cta_text != blank -%}
        <div class="inv-tr5__stats-row">
          {%- if stat_blocks.size > 0 -%}
            <div class="inv-tr5__stats">
              {%- for block in stat_blocks -%}
                <div class="inv-tr5__stat" {{ block.shopify_attributes }}>
                  <span class="inv-tr5__stat-num" data-itr5-counter="{{ block.settings.number }}">{{ block.settings.number }}</span>
                  <span class="inv-tr5__stat-label">{{ block.settings.label }}</span>
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- if section.settings.cta_text != blank and section.settings.cta_link != blank -%}
            <a href="{{ section.settings.cta_link }}" class="inv-tr5__cta">
              {{ section.settings.cta_text }}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

    </div>
  </div>

  {%- comment -%} ═══ PART 2: Branch images strip ═══ {%- endcomment -%}
  {%- if section.settings.image_1 != blank or section.settings.image_2 != blank -%}
    <div class="inv-tr5__branches">
      <div class="inv-tr5__wrap">
        <div class="inv-tr5__branches-grid">
          {%- if section.settings.image_1 != blank -%}
            <div class="inv-tr5__branch">
              <img
                src="{{ section.settings.image_1 | image_url: width: 720, format: 'webp' }}"
                srcset="{{ section.settings.image_1 | image_url: width: 480, format: 'webp' }} 480w,
                        {{ section.settings.image_1 | image_url: width: 720, format: 'webp' }} 720w"
                sizes="(max-width: 680px) 100vw, 50vw"
                alt="{{ section.settings.image_1.alt | default: section.settings.image_1_caption }}"
                loading="lazy"
                decoding="async"
                width="{{ section.settings.image_1.width }}"
                height="{{ section.settings.image_1.height }}"
                class="inv-tr5__branch-img"
              >
              <div class="inv-tr5__branch-overlay">
                {%- if section.settings.image_1_caption != blank -%}
                  <span class="inv-tr5__branch-name">{{ section.settings.image_1_caption }}</span>
                {%- endif -%}
                {%- if section.settings.badge_text != blank -%}
                  <span class="inv-tr5__branch-badge">{{ section.settings.badge_text }}</span>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}

          {%- if section.settings.image_2 != blank -%}
            <div class="inv-tr5__branch">
              <img
                src="{{ section.settings.image_2 | image_url: width: 720, format: 'webp' }}"
                srcset="{{ section.settings.image_2 | image_url: width: 480, format: 'webp' }} 480w,
                        {{ section.settings.image_2 | image_url: width: 720, format: 'webp' }} 720w"
                sizes="(max-width: 680px) 100vw, 50vw"
                alt="{{ section.settings.image_2.alt | default: section.settings.image_2_caption }}"
                loading="lazy"
                decoding="async"
                width="{{ section.settings.image_2.width }}"
                height="{{ section.settings.image_2.height }}"
                class="inv-tr5__branch-img"
              >
              <div class="inv-tr5__branch-overlay">
                {%- if section.settings.image_2_caption != blank -%}
                  <span class="inv-tr5__branch-name">{{ section.settings.image_2_caption }}</span>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ═══ PART 3: Reviews — static 4-card grid on light background ═══ {%- endcomment -%}
  {%- assign has_reviews = false -%}
  {%- for i in (1..10) -%}
    {%- assign enabled_key = 'review_' | append: i | append: '_enabled' -%}
    {%- assign text_key = 'review_' | append: i | append: '_text' -%}
    {%- if section.settings[enabled_key] and section.settings[text_key] != blank -%}
      {%- assign has_reviews = true -%}
    {%- endif -%}
  {%- endfor -%}

  {%- if has_reviews -%}
    <div class="inv-tr5__reviews" aria-label="Customer reviews">
      <div class="inv-tr5__wrap">
        {%- if section.settings.review_heading != blank -%}
          <div class="inv-tr5__reviews-header">
            <span class="inv-tr5__reviews-label">{{ section.settings.review_heading }}</span>
          </div>
        {%- endif -%}

        <div class="inv-tr5__reviews-grid">
          {%- assign rendered_reviews = 0 -%}
          {%- for i in (1..10) -%}
            {%- if rendered_reviews >= 4 -%}{%- break -%}{%- endif -%}
            {%- assign enabled_key = 'review_' | append: i | append: '_enabled' -%}
            {%- assign text_key = 'review_' | append: i | append: '_text' -%}
            {%- assign author_key = 'review_' | append: i | append: '_author' -%}
            {%- assign source_key = 'review_' | append: i | append: '_source' -%}
            {%- if section.settings[enabled_key] and section.settings[text_key] != blank -%}
              {%- assign review_author = section.settings[author_key] -%}
              {%- assign review_source = section.settings[source_key] -%}
              <div class="inv-tr5__review" aria-label="Review by {{ review_author }}">
                <div class="inv-tr5__review-stars" aria-label="5 out of 5 stars">
                  {%- for s in (1..5) -%}
                    <svg class="inv-tr5__star" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" focusable="false" aria-hidden="true">
                      <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8 5.8 21.3l2.4-7.4L2 9.4h7.6z"/>
                    </svg>
                  {%- endfor -%}
                </div>
                <p class="inv-tr5__review-text">&ldquo;{{ section.settings[text_key] }}&rdquo;</p>
                <div class="inv-tr5__review-footer">
                  <span class="inv-tr5__review-author">{{ review_author }}</span>
                  <span class="inv-tr5__review-source">
                    {%- case review_source -%}
                      {%- when 'google' -%}
                        <svg width="14" height="14" viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                        </svg>
                      {%- when 'facebook' -%}
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="#1877F2" focusable="false" aria-hidden="true">
                          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                        </svg>
                      {%- when 'trustpilot' -%}
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="#00b67a" focusable="false" aria-hidden="true">
                          <path d="M12 0l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 0z"/>
                        </svg>
                    {%- endcase -%}
                    {{ review_source | capitalize }}
                  </span>
                </div>
              </div>
              {%- assign rendered_reviews = rendered_reviews | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if section.settings.review_link != blank -%}
          <div class="inv-tr5__reviews-cta">
            <a href="{{ section.settings.review_link }}" class="inv-tr5__reviews-btn">
              Read all reviews
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}

</section>

<style>
  /* ============================================
     INVICTA TRUST & REVIEWS v8.0
     Trade shop feel. Sharp corners, clean, structural.
     Static review grid on light background.
     ============================================ */

  #inv-tr5-{{ section.id }} {
    --itr5-accent: var(--inv-accent, #e11d26);
    --itr5-accent-hover: var(--inv-accent-hover, #b91c1c);
    --itr5-bg: #f5f5f5;
    --itr5-fg: var(--inv-fg, #0f172a);
    --itr5-fg-muted: var(--inv-fg-muted, #6b7280);
    --itr5-border: var(--inv-border, #e5e7eb);
    --itr5-card-bg: var(--inv-bg-soft);
    --itr5-reviews-bg: #f5f5f5;
  }

  .inv-tr5 {
    background: var(--itr5-bg);
    border-top: 4px solid var(--itr5-accent);
  }

  .inv-tr5__wrap {
    max-width: var(--inv-container, 1400px);
    margin: 0 auto;
    padding: 0 var(--inv-gutter, 24px);
  }

  /* ----------------------------------------
     PART 1: HERO
     ---------------------------------------- */
  .inv-tr5__hero {
    padding: {{ section.settings.padding_top | default: 48 }}px 0 0;
  }

  .inv-tr5__hero-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 24px;
    align-items: start;
  }

  .inv-tr5__content {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .inv-tr5__eyebrow {
    font-size: 11px;
    font-weight: 700;
    color: var(--itr5-accent);
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  .inv-tr5__heading {
    font-family: var(--inv-font-body);
    font-size: clamp(26px, 3.5vw, 36px);
    font-weight: 900;
    color: var(--itr5-fg);
    line-height: 1.1;
    margin: 0;
  }

  .inv-tr5__text {
    font-size: 15px;
    color: var(--itr5-fg-muted);
    line-height: 1.6;
  }

  .inv-tr5__text p { margin: 0; }

  .inv-tr5__points {
    list-style: none;
    margin: 2px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .inv-tr5__point {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    font-weight: 600;
    color: var(--itr5-fg);
  }

  .inv-tr5__point-icon { flex-shrink: 0; }

  /* ----------------------------------------
     Stats + CTA row — full width below hero grid
     ---------------------------------------- */
  .inv-tr5__stats-row {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-top: 28px;
    padding-top: 20px;
    border-top: 1px solid var(--itr5-border);
  }

  .inv-tr5__stats {
    display: flex;
    gap: 0;
  }

  .inv-tr5__stat {
    padding-right: 36px;
    margin-right: 36px;
    border-right: 1px solid var(--itr5-border);
  }

  .inv-tr5__stat:last-child {
    border-right: none;
    margin-right: 0;
    padding-right: 0;
  }

  .inv-tr5__stat-num {
    display: block;
    font-family: var(--inv-font-body);
    font-size: clamp(28px, 3vw, 36px);
    font-weight: 900;
    color: var(--itr5-accent);
    line-height: 1;
  }

  .inv-tr5__stat-label {
    display: block;
    font-size: 11px;
    font-weight: 700;
    color: var(--itr5-fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: 4px;
  }

  /* CTA */
  .inv-tr5__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 13px 28px;
    background: var(--itr5-accent);
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-decoration: none;
    border-radius: 0;
    transition: background 0.15s ease;
    margin-left: auto;
    flex-shrink: 0;
  }

  .inv-tr5__cta:hover { background: var(--itr5-accent-hover); }
  .inv-tr5__cta:focus-visible { outline: 2px solid var(--itr5-accent); outline-offset: 2px; }

  /* ---- Rating badges (right side, stacked) ---- */
  .inv-tr5__ratings {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-top: 4px;
  }

  .inv-tr5__rating {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    background: var(--itr5-card-bg);
    border: 1px solid var(--itr5-border);
    border-radius: 0;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
    min-width: 190px;
  }

  .inv-tr5__rating:hover {
    border-color: #d1d5db;
    box-shadow: 0 2px 6px rgba(0,0,0,0.08);
  }

  .inv-tr5__rating:focus-visible {
    outline: 2px solid var(--itr5-accent);
    outline-offset: 2px;
  }

  .inv-tr5__rating-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .inv-tr5__rating-score {
    font-family: var(--inv-font-body);
    font-size: 22px;
    font-weight: 900;
    color: var(--itr5-fg);
    line-height: 1;
  }

  .inv-tr5__rating-stars {
    color: #fbbf24;
    font-size: 14px;
    letter-spacing: 1px;
  }

  .inv-tr5__rating-name {
    font-size: 11px;
    font-weight: 600;
    color: var(--itr5-fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-left: auto;
  }

  /* ----------------------------------------
     PART 2: BRANCH IMAGES
     ---------------------------------------- */
  .inv-tr5__branches {
    padding: 24px 0 20px;
  }

  .inv-tr5__branches-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .inv-tr5__branch {
    position: relative;
    overflow: hidden;
    border-radius: 0;
    aspect-ratio: 16 / 7;
  }

  .inv-tr5__branch-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .inv-tr5__branch-overlay {
    position: absolute;
    inset: 0;
    background: transparent;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding: 14px 16px;
  }

  .inv-tr5__branch-name {
    display: inline-block;
    font-size: 14px;
    font-weight: 800;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: var(--inv-dark-deep);
    padding: 6px 14px;
  }

  .inv-tr5__branch-badge {
    font-size: 10px;
    font-weight: 700;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: var(--itr5-accent);
    padding: 4px 10px;
    border-radius: 0;
  }

  /* ----------------------------------------
     PART 3: REVIEWS — static 4-card grid on light
     ---------------------------------------- */
  .inv-tr5__reviews {
    background: var(--itr5-reviews-bg);
    padding: 32px 0 {{ section.settings.padding_bottom | default: 48 }}px;
  }

  .inv-tr5__reviews-header {
    margin-bottom: 24px;
  }

  .inv-tr5__reviews-label {
    font-size: 13px;
    font-weight: 700;
    color: var(--itr5-fg);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* Static grid: four equal cards on desktop */
  .inv-tr5__reviews-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  /* Review cards */
  .inv-tr5__review {
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-left: 3px solid var(--itr5-accent);
    border-radius: 0;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .inv-tr5__review-stars {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    line-height: 1;
    color: #fbbf24;
  }

  .inv-tr5__star {
    display: block;
    flex-shrink: 0;
  }

  /* CTA below the grid */
  .inv-tr5__reviews-cta {
    display: flex;
    justify-content: center;
    margin-top: 28px;
  }

  .inv-tr5__reviews-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 13px 32px;
    background: var(--itr5-accent);
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-decoration: none;
    border-radius: 0;
    transition: background 0.15s ease;
  }

  .inv-tr5__reviews-btn:hover { background: var(--itr5-accent-hover); }
  .inv-tr5__reviews-btn:focus-visible { outline: 2px solid var(--itr5-accent); outline-offset: 2px; }

  .inv-tr5__reviews-btn svg {
    transition: transform 0.15s ease;
  }

  .inv-tr5__reviews-btn:hover svg {
    transform: translateX(3px);
  }

  .inv-tr5__review-text {
    font-size: 14px;
    color: var(--itr5-fg-muted);
    line-height: 1.6;
    margin: 0;
    font-style: italic;
    flex: 1;
  }

  .inv-tr5__review-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 12px;
    border-top: 1px solid #e5e7eb;
    margin-top: auto;
  }

  .inv-tr5__review-author {
    font-size: 13px;
    font-weight: 700;
    color: var(--itr5-fg);
  }

  .inv-tr5__review-source {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 12px;
    font-weight: 500;
    color: var(--itr5-fg-muted);
  }

  .inv-tr5__review-source svg {
    flex-shrink: 0;
  }

  /* ----------------------------------------
     RESPONSIVE
     ---------------------------------------- */
  @media (max-width: 989px) {
    .inv-tr5__hero-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .inv-tr5__ratings {
      flex-direction: row;
      flex-wrap: wrap;
      padding-top: 0;
    }

    .inv-tr5__rating {
      min-width: 0;
      flex: 1 1 auto;
    }

    .inv-tr5__reviews-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 749px) {
    .inv-tr5__branches-grid {
      grid-template-columns: 1fr;
      gap: 10px;
    }

    .inv-tr5__reviews-grid {
      grid-template-columns: 1fr;
    }

    .inv-tr5__branch {
      aspect-ratio: 16 / 8;
    }

    .inv-tr5__stats-row {
      flex-wrap: wrap;
    }

    .inv-tr5__stats {
      flex-wrap: wrap;
      gap: 14px 0;
      width: 100%;
    }

    .inv-tr5__stat {
      flex: 0 0 auto;
    }

    .inv-tr5__cta {
      width: 100%;
      justify-content: center;
      margin-left: 0;
    }

    .inv-tr5__ratings {
      flex-direction: column;
    }

    .inv-tr5__hero {
      padding-top: 28px;
    }

    .inv-tr5__branches {
      padding: 18px 0 16px;
    }

    .inv-tr5__review {
      padding: 20px;
    }

    .inv-tr5__reviews-btn {
      width: 100%;
      justify-content: center;
    }
  }

  /* small-phone override */
  @media (max-width: 420px) {
    .inv-tr5__stat {
      border-right: none;
      margin-right: 16px;
      padding-right: 0;
    }

    .inv-tr5__heading {
      font-size: 22px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .inv-tr5__cta,
    .inv-tr5__rating,
    .inv-tr5__reviews-btn,
    .inv-tr5__reviews-btn svg { transition: none; }
    .inv-tr5__reviews-btn:hover svg { transform: none; }
  }
</style>

<script>
(function() {
  var section = document.getElementById('inv-tr5-{{ section.id }}');
  if (!section) return;

  /* =========================================
     COUNTER ANIMATION
     ========================================= */
  var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function easeOutQuart(t) { return 1 - Math.pow(1 - t, 4); }

  function parseStatNumber(raw) {
    var match = raw.match(/^([\d,]+\.?\d*)\s*(.*)$/);
    if (!match) return null;
    var numStr = match[1].replace(/,/g, '');
    var num = parseFloat(numStr);
    var suffix = match[2] || '';
    var hasDecimal = numStr.indexOf('.') !== -1;
    var decimals = hasDecimal ? (numStr.split('.')[1] || '').length : 0;
    var isLarge = num >= 1000;
    return { target: num, suffix: suffix, decimals: decimals, isLarge: isLarge };
  }

  function formatNumber(val, parsed) {
    if (parsed.decimals > 0) return val.toFixed(parsed.decimals);
    var rounded = Math.round(val);
    return parsed.isLarge ? rounded.toLocaleString() : rounded.toString();
  }

  function animateCounter(el) {
    if (el.dataset.animated) return;
    el.dataset.animated = 'true';
    var raw = el.dataset.itr5Counter;
    var parsed = parseStatNumber(raw);
    if (!parsed) return;
    if (reducedMotion) { el.textContent = formatNumber(parsed.target, parsed) + parsed.suffix; return; }
    var duration = 2000;
    var start = null;
    function step(ts) {
      if (!start) start = ts;
      var elapsed = ts - start;
      var progress = Math.min(elapsed / duration, 1);
      var current = easeOutQuart(progress) * parsed.target;
      el.textContent = formatNumber(current, parsed) + parsed.suffix;
      if (progress < 1) requestAnimationFrame(step);
    }
    el.textContent = '0' + parsed.suffix;
    requestAnimationFrame(step);
  }

  var statsWrap = section.querySelector('.inv-tr5__stats');
  if (statsWrap) {
    var counters = statsWrap.querySelectorAll('[data-itr5-counter]');
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          counters.forEach(function(el) { animateCounter(el); });
          obs.disconnect();
        }
      });
    }, { threshold: 0.5 });
    obs.observe(statsWrap);
  }

  /* =========================================
     SHOPIFY EDITOR EVENTS
     ========================================= */
  document.addEventListener('shopify:section:load', function(e) {
    if (e.detail && e.detail.sectionId === '{{ section.id }}') {
      var els = section.querySelectorAll('[data-itr5-counter]');
      els.forEach(function(el) { el.dataset.animated = ''; animateCounter(el); });
    }
  });
})();
</script>

