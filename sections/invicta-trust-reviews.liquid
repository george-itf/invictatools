      font-size: 22px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .inv-tr4__reviews-track { animation: none; }
    .inv-tr4__card, .inv-tr4__cta, .inv-tr4__card-arr { transition: none; }
  }
