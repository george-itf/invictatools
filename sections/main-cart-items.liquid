{{ 'component-cart.css' | asset_url | stylesheet_tag }}
{{ 'component-cart-items.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'quantity-popover.css' | asset_url | stylesheet_tag }}
{{ 'invicta-cart.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- unless settings.cart_type == 'drawer' -%}
  <script src="{{ 'invicta-cart-core.js' | asset_url }}" defer="defer"></script>
{%- endunless -%}

<script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>

<cart-items class="gradient color-{{ section.settings.color_scheme }} isolate{% if cart == empty %} is-empty{% else %} section-{{ section.id }}-padding{% endif %}">
  <div class="page-width">

    {%- comment -%} Progress indicator: Shop > Cart > Checkout {%- endcomment -%}
    {%- if cart != empty -%}
      <nav class="inv-cart-progress" aria-label="Checkout progress">
        <ol class="inv-cart-progress__inner" role="list">
          <li class="inv-cart-progress__step inv-cart-progress__step--complete">
            <span class="inv-cart-progress__circle" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </span>
            <span class="inv-cart-progress__label">Shop</span>
          </li>
          <li class="inv-cart-progress__line inv-cart-progress__line--complete" aria-hidden="true"></li>
          <li class="inv-cart-progress__step inv-cart-progress__step--active" aria-current="step">
            <span class="inv-cart-progress__circle" aria-hidden="true">2</span>
            <span class="inv-cart-progress__label">Cart</span>
          </li>
          <li class="inv-cart-progress__line" aria-hidden="true"></li>
          <li class="inv-cart-progress__step">
            <span class="inv-cart-progress__circle" aria-hidden="true">3</span>
            <span class="inv-cart-progress__label">Checkout</span>
          </li>
        </ol>
      </nav>
    {%- endif -%}

    {%- comment -%} Cart header bar {%- endcomment -%}
    <div class="inv-cart-header">
      <div class="inv-cart-header__left">
        <h1 class="inv-cart-header__title">{{ 'sections.cart.title' | t }}</h1>
        {%- if cart != empty -%}
          <span class="inv-cart-header__count">
            ({{ cart.item_count }}
            {%- if cart.item_count == 1 %} item{% else %} items{% endif -%})
          </span>
        {%- endif -%}
      </div>
      <a href="{{ routes.all_products_collection_url }}" class="inv-cart-header__continue">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        {{- 'general.continue_shopping' | t -}}
      </a>
    </div>

    {%- if cart == empty -%}
      <div class="inv-cart-empty">
        <div class="inv-cart-empty__hero">
          <svg class="inv-cart-empty__icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="9" cy="21" r="1"/>
            <circle cx="20" cy="21" r="1"/>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
          </svg>
          <h1 class="inv-cart-empty__title">Your cart is empty</h1>
          <p class="inv-cart-empty__text">Looks like you haven't added anything yet. Browse our range to find what you need.</p>
          <a href="{{ routes.all_products_collection_url }}" class="inv-cart-empty__cta">
            Continue Shopping
          </a>
        </div>

        <div class="inv-cart-empty__recent" data-empty-recent style="display: none;">
          <h2 class="inv-cart-empty__recent-title">Recently Viewed</h2>
          <div class="inv-cart-empty__recent-grid" data-empty-recent-grid></div>
        </div>
      </div>

      <script>
        (function() {
          'use strict';
          var STORAGE_KEY = 'invicta_recently_viewed_v3';
          var container = document.querySelector('[data-empty-recent]');
          var grid = document.querySelector('[data-empty-recent-grid]');
          if (!container || !grid) return;

          var raw = localStorage.getItem(STORAGE_KEY);
          if (!raw) return;

          var handles;
          try { handles = JSON.parse(raw); } catch(e) { return; }
          if (!Array.isArray(handles) || handles.length === 0) return;

          handles = handles.slice(0, 6);

          var moneyFormat = {{ shop.money_format | json }};
          var vatRate = {{ settings.inv_vat_rate | default: 20 }};

          function formatMoney(pence) {
            return moneyFormat.replace('{{amount}}', (pence / 100).toFixed(2))
                              .replace('{{amount_no_decimals}}', Math.round(pence / 100).toString())
                              .replace('{{amount_with_comma_separator}}', (pence / 100).toFixed(2).replace('.', ','));
          }

          function calcExVat(pence) {
            var divisor = 100 + vatRate;
            return Math.round((pence * 100 + Math.floor(divisor / 2)) / divisor);
          }

          var fetched = 0;
          var products = [];

          handles.forEach(function(handle) {
            fetch('/products/' + encodeURIComponent(handle) + '.js')
              .then(function(r) { return r.ok ? r.json() : Promise.reject(); })
              .then(function(product) { products.push(product); })
              .catch(function() { /* skip unavailable products */ })
              .finally(function() {
                fetched++;
                if (fetched === handles.length) renderProducts();
              });
          });

          function renderProducts() {
            if (products.length === 0) return;
            container.style.display = '';

            var ordered = [];
            handles.forEach(function(h) {
              var p = products.find(function(pr) { return pr.handle === h; });
              if (p) ordered.push(p);
            });

            ordered.forEach(function(product) {
              var variant = product.variants[0];
              if (!variant) return;
              var price = variant.price;
              var exVat = calcExVat(price);
              var imgUrl = product.featured_image || '';
              if (imgUrl && imgUrl.indexOf('cdn.shopify.com') > -1) {
                imgUrl = imgUrl.replace(/\.([a-z]+)(\?|$)/, '_400x400.$1$2');
              }

              var card = document.createElement('a');
              card.href = product.url || '/products/' + product.handle;
              card.className = 'inv-cart-empty__recent-card';
              card.innerHTML =
                '<div class="inv-cart-empty__recent-card-img">' +
                  (imgUrl ? '<img src="' + imgUrl + '" alt="' + (product.title || '').replace(/"/g, '&quot;') + '" loading="lazy" width="200" height="200">' : '') +
                '</div>' +
                '<div class="inv-cart-empty__recent-card-body">' +
                  '<span class="inv-cart-empty__recent-card-title">' + product.title + '</span>' +
                  '<span class="inv-cart-empty__recent-card-price" data-price-inc>' + formatMoney(price) + '</span>' +
                  '<span class="inv-cart-empty__recent-card-price inv-vat--hidden" data-price-ex>' + formatMoney(exVat) + ' ex VAT</span>' +
                '</div>';
              grid.appendChild(card);
            });
          }
        })();
      </script>
    {%- endif -%}

    {%- comment -%} Info strip — visible on mobile, hidden on desktop (sidebar has it) {%- endcomment -%}
    {%- if cart != empty and section.settings.show_free_shipping_bar -%}
      <div class="inv-cart-info-strip inv-cart-info-strip--mobile-only">
        {% render 'invicta-free-delivery-bar' %}
      </div>
    {%- endif -%}

    <form action="{{ routes.cart_url }}" class="cart__contents critical-hidden" method="post" id="cart">

      <div class="cart__items" id="main-cart-items" data-id="{{ section.id }}">
        <div class="js-contents">
          {%- if cart != empty -%}

            <div class="inv-cart-grid">

              {%- comment -%} ═══ Left column: line item cards + urgency bar ═══ {%- endcomment -%}
              <div class="inv-cart-grid__items">

                {%- assign item_vat_divisor = 100 | plus: settings.inv_vat_rate -%}
                {%- assign item_vat_rounding = item_vat_divisor | divided_by: 2 -%}

                <ul class="inv-cart-lines" role="list">
                  {%- for item in cart.items -%}
                    {%- liquid
                      assign item_stock_source = 'invicta'
                      assign warranty_years = ''
                      for tag in item.product.tags
                        assign tag_lower = tag | downcase | strip
                        if tag_lower == 'invicta-stock'
                          assign item_stock_source = 'invicta'
                        elsif tag_lower == 'trend-stock' or tag_lower == 'toolbank-stock' or tag_lower == 'timco-stock' or tag_lower == 'pdp-stock'
                          assign item_stock_source = 'supplier'
                        endif
                        if tag_lower contains 'warranty-'
                          assign warranty_years = tag_lower | remove: 'warranty-' | strip
                        endif
                      endfor

                      assign line_index = item.index | plus: 1

                      assign item_price_for_vat = item.final_price | times: 100 | plus: item_vat_rounding
                      assign item_ex_vat = item_price_for_vat | divided_by: item_vat_divisor

                      assign line_price_for_vat = item.final_line_price | times: 100 | plus: item_vat_rounding
                      assign line_ex_vat = line_price_for_vat | divided_by: item_vat_divisor

                      assign sold_count_meta = item.product.metafields.invicta.sold_this_week
                    -%}

                    <li class="inv-cart-line cart-item" id="CartItem-{{ line_index }}">
                      {%- render 'loading-spinner' -%}

                      <div class="inv-cart-line__body">
                        <a href="{{ item.url }}" class="inv-cart-line__media" aria-label="{{ item.product.title | escape }}">
                          {% if item.image %}
                            <img
                              src="{{ item.image | image_url: width: 400 }}"
                              class="inv-cart-line__image"
                              alt="{{ item.image.alt | default: item.product.title | escape }}"
                              loading="lazy"
                              width="200"
                              height="{{ 200 | divided_by: item.image.aspect_ratio | ceil }}"
                            >
                          {% endif %}
                        </a>

                        <div class="inv-cart-line__details">
                          {%- if item.product.vendor != blank -%}
                            <span class="inv-cart-line__brand">{{ item.product.vendor }}</span>
                          {%- endif -%}

                          <a href="{{ item.url }}" class="inv-cart-line__title">{{ item.product.title | escape }}</a>

                          <ul class="inv-cart-line__tags" role="list">
                            <li>
                              <span class="inv-cart-line__tag inv-cart-line__tag--stock">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                                {%- if item_stock_source == 'invicta' -%}
                                  In stock
                                {%- else -%}
                                  Supplier stock
                                {%- endif -%}
                              </span>
                            </li>
                            {%- if item_stock_source == 'invicta' -%}
                              <li>
                                <span class="inv-cart-line__tag inv-cart-line__tag--delivery">
                                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true"><path d="M1 3h15v13H1z"/><path d="M16 8h4l3 4v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                                  Next-day eligible
                                </span>
                              </li>
                            {%- endif -%}
                            {%- if warranty_years != blank -%}
                              <li>
                                <span class="inv-cart-line__tag inv-cart-line__tag--warranty">
                                  {{ warranty_years }}-year warranty
                                </span>
                              </li>
                            {%- endif -%}
                          </ul>

                          {%- if sold_count_meta != blank and sold_count_meta != nil -%}
                            <span class="inv-cart-line__social">
                              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                              {{ sold_count_meta }} bought this week
                            </span>
                          {%- endif -%}

                          {%- if item.product.has_only_default_variant == false or item.properties.size != 0 or item.selling_plan_allocation != null -%}
                            <dl class="inv-cart-line__options">
                              {%- if item.product.has_only_default_variant == false -%}
                                {%- for option in item.options_with_values -%}
                                  <div class="product-option">
                                    <dt>{{ option.name }}:</dt>
                                    <dd>{{ option.value }}</dd>
                                  </div>
                                {%- endfor -%}
                              {%- endif -%}

                              {%- for property in item.properties -%}
                                {%- assign property_first_char = property.first | slice: 0 -%}
                                {%- if property.last != blank and property_first_char != '_' -%}
                                  <div class="product-option">
                                    <dt>{{ property.first }}:</dt>
                                    <dd>
                                      {%- if property.last contains '/uploads/' -%}
                                        <a href="{{ property.last }}" class="link" target="_blank">{{ property.last | split: '/' | last }}</a>
                                      {%- else -%}
                                        {{ property.last }}
                                      {%- endif -%}
                                    </dd>
                                  </div>
                                {%- endif -%}
                              {%- endfor -%}
                              {%- if item.selling_plan_allocation.selling_plan.name -%}
                                <div class="product-option"><dd>{{ item.selling_plan_allocation.selling_plan.name }}</dd></div>
                              {%- endif -%}
                            </dl>
                          {%- endif -%}

                          <ul class="discounts inv-cart-line__discounts list-unstyled" role="list" aria-label="{{ 'customer.order.discount' | t }}">
                            {%- for discount in item.line_level_discount_allocations -%}
                              <li class="discounts__discount">
                                {{- 'icon-discount.svg' | inline_asset_content -}}
                                {{ discount.discount_application.title | escape }}
                              </li>
                            {%- endfor -%}
                          </ul>
                        </div>
                      </div>

                      <div class="inv-cart-line__footer">
                        <div class="inv-cart-line__qty-group">
                          <label class="visually-hidden" for="Quantity-{{ line_index }}">
                            {{ 'products.product.quantity.label' | t }}
                          </label>
                          <quantity-input class="inv-cart-qty cart-quantity">
                            {% assign can_update_quantity = item.instructions.can_update_quantity | default: true %}
                            <button class="inv-cart-qty__button quantity__button no-js-hidden" name="minus" type="button" {% if can_update_quantity == false %}disabled{% endif %}>
                              <span class="visually-hidden">{{- 'products.product.quantity.decrease' | t: product: item.product.title | escape -}}</span>
                              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/></svg>
                            </button>
                            <input
                              class="inv-cart-qty__input quantity__input"
                              data-quantity-variant-id="{{ item.variant.id }}"
                              type="number"
                              name="updates[]"
                              value="{{ item.quantity }}"
                              {% # theme-check-disable %}
                              data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                              min="0"
                              data-min="{{ item.variant.quantity_rule.min }}"
                              {% if item.variant.quantity_rule.max != null %}
                                max="{{ item.variant.quantity_rule.max }}"
                              {% endif %}
                              step="{{ item.variant.quantity_rule.increment }}"
                              {% # theme-check-enable %}
                              aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
                              id="Quantity-{{ line_index }}"
                              data-index="{{ line_index }}"
                              {% if can_update_quantity == false %}disabled{% endif %}
                            >
                            <button class="inv-cart-qty__button quantity__button no-js-hidden" name="plus" type="button" {% if can_update_quantity == false %}disabled{% endif %}>
                              <span class="visually-hidden">{{- 'products.product.quantity.increase' | t: product: item.product.title | escape -}}</span>
                              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                            </button>
                          </quantity-input>
                          <cart-remove-button
                            id="Remove-{{ line_index }}"
                            data-index="{{ line_index }}"
                          >
                            <button
                              type="button"
                              class="inv-cart-line__remove"
                              aria-label="{{ 'sections.cart.remove_title' | t: title: item.title | escape }}"
                            >
                              Remove
                            </button>
                          </cart-remove-button>
                        </div>

                        <div class="inv-cart-line__price">
                          {%- if item.original_line_price != item.final_line_price -%}
                            <span class="inv-cart-line__price-was">{{ item.original_line_price | money }}</span>
                          {%- endif -%}
                          <span class="inv-cart-line__price-inc">
                            <span class="inv-cart-line__price-amount">{{ item.final_line_price | money }}</span>
                            <span class="inv-cart-line__price-tag">inc VAT</span>
                          </span>
                          <span class="inv-cart-line__price-ex">
                            <span class="inv-cart-line__price-amount">{{ line_ex_vat | money }}</span>
                            <span class="inv-cart-line__price-tag">ex VAT</span>
                          </span>
                        </div>
                      </div>

                      <div class="inv-cart-line__error" id="Line-item-error-{{ line_index }}" role="alert">
                        <small class="cart-item__error-text"></small>
                      </div>
                    </li>
                  {%- endfor -%}
                </ul>

                {%- comment -%} Delivery urgency bar — between products and cross-sells {%- endcomment -%}
                {%- if section.settings.show_delivery_estimate -%}
                  <div class="inv-cart-urgency" data-inv-delivery-estimate data-stock-source="invicta">
                    <div class="inv-cart-urgency__message">
                      <span class="inv-cart-urgency__dot" aria-hidden="true"></span>
                      <span class="inv-cart-urgency__text">
                        <span data-inv-del-order-text>{{ 'invicta.delivery.order_now' | t }}</span>
                        <span class="inv-cart-urgency__inline-time" data-inv-del-countdown style="display:none"></span>
                        <span data-inv-del-for-text>{{ 'invicta.delivery.for_delivery_on' | t }}</span>
                        <strong data-inv-del-day>Monday</strong>
                      </span>
                    </div>
                    <div class="inv-cart-urgency__countdown" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                      <strong class="inv-cart-urgency__time" data-inv-del-countdown>--:--:--</strong>
                    </div>
                  </div>
                  {{ 'component-delivery-estimate.css' | asset_url | stylesheet_tag }}
                  <script src="{{ 'component-delivery-estimate.js' | asset_url }}" defer></script>
                {%- endif -%}
              </div>

              {%- comment -%} ═══ Right column: sticky order summary sidebar ═══ {%- endcomment -%}
              <aside class="inv-cart-grid__sidebar" aria-label="Order summary">
                <section class="inv-cart-summary">
                  <h2 class="inv-cart-summary__header">Order Summary</h2>
                  <div class="inv-cart-summary__body">

                    {% render 'cart-breakdown', cart: cart %}

                    <div class="inv-cart-summary__po">
                      <label class="inv-cart-summary__po-label" for="CartPoReference">
                        PO / Reference Number
                        <span class="inv-cart-summary__po-optional">(optional)</span>
                      </label>
                      <cart-note>
                        <input
                          type="text"
                          id="CartPoReference"
                          class="inv-cart-summary__po-input"
                          name="note"
                          form="cart"
                          value="{{ cart.note | escape }}"
                          placeholder="For your records"
                          autocomplete="off"
                        >
                      </cart-note>
                    </div>

                    <button
                      type="submit"
                      id="checkout"
                      class="inv-cart-summary__checkout"
                      name="checkout"
                      {% if cart == empty %}disabled{% endif %}
                      form="cart"
                    >
                      Secure Checkout
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </button>

                    {%- if additional_checkout_buttons -%}
                      <div class="inv-cart-summary__express-divider" aria-hidden="true">or express checkout</div>
                      <div class="inv-cart-summary__express">
                        <div class="cart__dynamic-checkout-buttons additional-checkout-buttons">
                          {{ content_for_additional_checkout_buttons }}
                        </div>
                      </div>
                    {%- endif -%}

                  </div>
                </section>

                <div class="inv-cart-trust" role="list" aria-label="Trust signals">
                  <div class="inv-cart-trust__item" role="listitem">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    <span>Secure Checkout</span>
                  </div>
                  <div class="inv-cart-trust__item" role="listitem">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true"><path d="M1 3h15v13H1z"/><path d="M16 8h4l3 4v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                    <span>Free Over {{ settings.inv_free_shipping_pence | divided_by: 100 | prepend: '£' }}</span>
                  </div>
                  <div class="inv-cart-trust__item" role="listitem">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
                    <span>30-Day Returns</span>
                  </div>
                  <div class="inv-cart-trust__item" role="listitem">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    <span>4.7/5 Trustpilot</span>
                  </div>
                </div>

                <div id="cart-errors" role="alert"></div>
              </aside>

            </div>{%- comment -%} /.inv-cart-grid {%- endcomment -%}

          {%- endif -%}
        </div>{%- comment -%} /.js-contents {%- endcomment -%}
      </div>{%- comment -%} /.cart__items {%- endcomment -%}

      <p class="visually-hidden" id="cart-live-region-text" aria-live="polite" role="status"></p>
      <p class="visually-hidden" id="shopping-cart-line-item-status" aria-live="polite" aria-hidden="true" role="status">
        {{ 'accessibility.loading' | t }}
      </p>
    </form>
  </div>
</cart-items>

{% schema %}
{
  "name": "Cart Items",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Colour scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Free Shipping Bar"
    },
    {
      "type": "checkbox",
      "id": "show_free_shipping_bar",
      "label": "Show free shipping progress bar",
      "default": true
    },
    {
      "type": "number",
      "id": "free_shipping_threshold",
      "label": "Free shipping threshold (pence)",
      "default": 9999,
      "info": "Enter amount in pence. E.g. 9999 = £99.99"
    },
    {
      "type": "header",
      "content": "Delivery Estimate"
    },
    {
      "type": "checkbox",
      "id": "show_delivery_estimate",
      "label": "Show delivery countdown",
      "default": true
    },
    {
      "type": "number",
      "id": "cutoff_hour",
      "label": "Order cutoff hour (24hr)",
      "default": 14,
      "info": "Orders before this time qualify for next-day delivery. E.g. 14 = 2pm"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ]
}
{% endschema %}
