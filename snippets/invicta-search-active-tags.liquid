{%- comment -%}
  Active filter tags bar for search page.
  Renders a tag for each active filter with a remove button.
  Flattened from 7-level nesting to 3 by using if/elsif chain instead of nested for+if.

  Parameters:
    search_filters     - The search.filters array
    has_active_filters - Boolean, whether any filters are active
{%- endcomment -%}

{%- if has_active_filters -%}
  <div class="inv-filters__active-bar" id="inv-active-filters">
    <div class="inv-filters__active-content">
      <div class="inv-filters__active-left">
        <span class="inv-filters__active-label">{{ 'invicta.search.filters_active' | t }}:</span>
        <div class="inv-filters__active-tags">

          {%- for filter in search_filters -%}
            {%- if filter.param_name == 'filter.p.vendor' or filter.param_name == 'filter.p.product_type' -%}
              {%- if filter.param_name == 'filter.p.vendor' -%}
                {%- assign tag_modifier = 'brand' -%}
              {%- else -%}
                {%- assign tag_modifier = 'type' -%}
              {%- endif -%}
              {%- for value in filter.active_values -%}
                <span class="inv-filters__tag inv-filters__tag--{{ tag_modifier }}" data-filter-param="{{ filter.param_name }}" data-filter-value="{{ value.label | escape }}">
                  <span class="inv-filters__tag-text">{{ value.label }}</span>
                  <button type="button" class="inv-filters__tag-remove" aria-label="Remove {{ value.label }}">
                    <svg width="10" height="10" viewBox="0 0 10 10" focusable="false" aria-hidden="true"><path d="M1 1l8 8M9 1l-8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  </button>
                </span>
              {%- endfor -%}

            {%- elsif filter.param_name == 'filter.v.price' -%}
              {%- if filter.min_value.value != nil or filter.max_value.value != nil -%}
                <span class="inv-filters__tag inv-filters__tag--price" data-filter-param="filter.v.price.gte" data-filter-value="">
                  <span class="inv-filters__tag-text">
                    {%- if filter.min_value.value != nil and filter.max_value.value != nil -%}
                      &pound;{{ filter.min_value.value | money_without_currency }} &ndash; &pound;{{ filter.max_value.value | money_without_currency }}
                    {%- elsif filter.min_value.value != nil -%}
                      &pound;{{ filter.min_value.value | money_without_currency }}+
                    {%- elsif filter.max_value.value != nil -%}
                      Up to &pound;{{ filter.max_value.value | money_without_currency }}
                    {%- endif -%}
                  </span>
                  <button type="button" class="inv-filters__tag-remove" aria-label="Remove price filter">
                    <svg width="10" height="10" viewBox="0 0 10 10" focusable="false" aria-hidden="true"><path d="M1 1l8 8M9 1l-8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  </button>
                </span>
              {%- endif -%}

            {%- elsif filter.param_name == 'filter.v.availability' -%}
              {%- for value in filter.active_values -%}
                {%- if value.value == '1' -%}
                  <span class="inv-filters__tag inv-filters__tag--availability" data-filter-param="filter.v.availability" data-filter-value="1">
                    <span class="inv-filters__tag-text">{{ 'invicta.search.filter_in_stock' | t }}</span>
                    <button type="button" class="inv-filters__tag-remove" aria-label="Remove availability filter">
                      <svg width="10" height="10" viewBox="0 0 10 10" focusable="false" aria-hidden="true"><path d="M1 1l8 8M9 1l-8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                    </button>
                  </span>
                {%- endif -%}
              {%- endfor -%}
            {%- endif -%}
          {%- endfor -%}

        </div>
      </div>
      <button type="button" class="inv-filters__clear-all" data-clear-all-filters>{{ 'invicta.search.clear_filters' | t }}</button>
    </div>
  </div>
{%- endif -%}
