{% comment %}
  Invicta Star Rating v1.0
  Renders star rating from metafield or passed value.

  Usage: {% render 'invicta-star-rating', rating: 4.5, count: 23 %}
  Or:    {% render 'invicta-star-rating', product: product %}
         (reads product.metafields.judgeme.badge data if available)
{% endcomment %}

{%- liquid
  assign star_rating = rating | default: 0
  assign star_count = count | default: 0

  if product and star_rating == 0
    if product.metafields.reviews.rating.value != blank
      assign star_rating = product.metafields.reviews.rating.value.rating | default: 0
      assign star_count = product.metafields.reviews.rating_count | default: 0
    elsif product.metafields.judgeme.badge != blank
      assign star_rating = product.metafields.judgeme.average_rating | default: 0
      assign star_count = product.metafields.judgeme.review_count | default: 0
    endif
  endif
-%}

{%- if star_rating > 0 and star_count > 0 -%}
  <div class="inv-stars" aria-label="{{ star_rating }} out of 5 stars, {{ star_count }} reviews">
    <div class="inv-stars__icons" aria-hidden="true">
      {%- for i in (1..5) -%}
        {%- if star_rating >= i -%}
          <svg class="inv-stars__icon inv-stars__icon--full" viewBox="0 0 20 20" width="14" height="14"><polygon points="10,1 12.5,7 19,7.5 14,12 15.5,19 10,15.5 4.5,19 6,12 1,7.5 7.5,7" fill="currentColor"/></svg>
        {%- elsif star_rating >= i | minus: 0.5 -%}
          <svg class="inv-stars__icon inv-stars__icon--half" viewBox="0 0 20 20" width="14" height="14">
            <defs><clipPath id="half-{{ i }}"><rect x="0" y="0" width="10" height="20"/></clipPath></defs>
            <polygon points="10,1 12.5,7 19,7.5 14,12 15.5,19 10,15.5 4.5,19 6,12 1,7.5 7.5,7" fill="none" stroke="currentColor" stroke-width="1"/>
            <polygon points="10,1 12.5,7 19,7.5 14,12 15.5,19 10,15.5 4.5,19 6,12 1,7.5 7.5,7" fill="currentColor" clip-path="url(#half-{{ i }})"/>
          </svg>
        {%- else -%}
          <svg class="inv-stars__icon inv-stars__icon--empty" viewBox="0 0 20 20" width="14" height="14"><polygon points="10,1 12.5,7 19,7.5 14,12 15.5,19 10,15.5 4.5,19 6,12 1,7.5 7.5,7" fill="none" stroke="currentColor" stroke-width="1"/></svg>
        {%- endif -%}
      {%- endfor -%}
    </div>
    <span class="inv-stars__count">({{ star_count }})</span>
  </div>

  <style>
    .inv-stars {
      display: inline-flex;
      align-items: center;
      gap: 4px;
    }
    .inv-stars__icons {
      display: flex;
      gap: 1px;
      color: #f59e0b;
    }
    .inv-stars__icon--empty {
      color: var(--inv-border-dark, #d1d5db);
    }
    .inv-stars__count {
      font-size: var(--inv-text-xs, 11px);
      color: var(--inv-fg-muted, #6b7280);
    }
  </style>
{%- endif -%}
