{% comment %}
  Invicta GA4 — Consent Mode v2

  TBT optimisation: the gtag.js library (~80KB, ~250ms execution) was
  the biggest single contributor to main-thread blocking on the homepage.
  We now defer-load it after the main load event finishes (via
  requestIdleCallback where available) so it stays off the critical path.

  Consent defaults still run inline so any product/page events fired
  before the library loads are queued in dataLayer and replayed when
  gtag.js initialises.
{% endcomment %}

{%- if settings.inv_ga4_measurement_id != blank -%}
<script>
  /* Consent Mode v2 — deny everything by default. Lightweight inline. */
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('consent', 'default', {
    'analytics_storage': 'denied',
    'ad_storage': 'denied',
    'ad_user_data': 'denied',
    'ad_personalization': 'denied',
    'wait_for_update': 500
  });
  gtag('js', new Date());
  gtag('config', '{{ settings.inv_ga4_measurement_id }}'{%- if settings.inv_ga4_debug -%}, { 'debug_mode': true }{%- endif -%});

  /* If consent was already given (returning visitor), grant immediately
     so the queued events fire with full storage when gtag.js arrives. */
  try {
    var ha = localStorage.getItem('invicta-consent-analytics') === '1';
    var hm = localStorage.getItem('invicta-consent-marketing') === '1';
    if (ha || hm) {
      gtag('consent', 'update', {
        'analytics_storage': ha ? 'granted' : 'denied',
        'ad_storage': hm ? 'granted' : 'denied',
        'ad_user_data': hm ? 'granted' : 'denied',
        'ad_personalization': hm ? 'granted' : 'denied'
      });
    }
  } catch (e) {}

  /* Update consent when cookie banner decision is made (event may fire
     before gtag.js loads — dataLayer.push queues it for replay). */
  document.addEventListener('invicta:consent:updated', function(e) {
    var d = e.detail || {};
    gtag('consent', 'update', {
      'analytics_storage': d.analytics ? 'granted' : 'denied',
      'ad_storage': d.marketing ? 'granted' : 'denied',
      'ad_user_data': d.marketing ? 'granted' : 'denied',
      'ad_personalization': d.marketing ? 'granted' : 'denied'
    });
  });

  /* Lazy-load gtag.js off the critical path. */
  (function(){
    var src = 'https://www.googletagmanager.com/gtag/js?id={{ settings.inv_ga4_measurement_id }}';
    var loaded = false;
    function load() {
      if (loaded) return;
      loaded = true;
      var s = document.createElement('script');
      s.async = true;
      s.src = src;
      document.head.appendChild(s);
    }
    function schedule() {
      if ('requestIdleCallback' in window) {
        requestIdleCallback(load, { timeout: 4000 });
      } else {
        setTimeout(load, 2500);
      }
    }
    if (document.readyState === 'complete') {
      schedule();
    } else {
      window.addEventListener('load', schedule, { once: true });
    }
  })();
</script>
<link rel="dns-prefetch" href="https://www.googletagmanager.com">
<link rel="preconnect" href="https://www.googletagmanager.com" crossorigin>
{%- endif -%}
