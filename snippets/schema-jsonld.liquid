{%- comment -%}
  Schema.org JSON-LD structured data — Invicta Tools
  Renders sitewide WebSite, Organization + page-specific Product, BreadcrumbList, LocalBusiness
{%- endcomment -%}

{%- comment -%} ===== WEBSITE SCHEMA with SearchAction (sitewide) ===== {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": {{ shop.name | json }},
  "url": {{ shop.url | json }},
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": {{ shop.url | append: '/search?q={search_term_string}' | json }}
    },
    "query-input": "required name=search_term_string"
  }
}
</script>

{%- comment -%} ===== ORGANIZATION SCHEMA (sitewide) ===== {%- endcomment -%}
{%- liquid
  assign org_name = settings.seo_org_name | default: shop.name
-%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": {{ org_name | json }},
  "url": {{ shop.url | json }}
  {%- if settings.logo -%}
    ,"logo": {{ settings.logo | image_url: width: 600 | prepend: 'https:' | json }}
  {%- endif -%}
  {%- if settings.seo_org_telephone != blank -%}
    ,"telephone": {{ settings.seo_org_telephone | json }}
  {%- endif -%}
  {%- liquid
    assign social_links = ''
    if settings.social_facebook_link != blank
      assign social_links = social_links | append: settings.social_facebook_link | append: '|||'
    endif
    if settings.social_instagram_link != blank
      assign social_links = social_links | append: settings.social_instagram_link | append: '|||'
    endif
    if settings.social_youtube_link != blank
      assign social_links = social_links | append: settings.social_youtube_link | append: '|||'
    endif
    if settings.social_tiktok_link != blank
      assign social_links = social_links | append: settings.social_tiktok_link | append: '|||'
    endif
    if settings.social_twitter_link != blank
      assign social_links = social_links | append: settings.social_twitter_link | append: '|||'
    endif
    if settings.social_pinterest_link != blank
      assign social_links = social_links | append: settings.social_pinterest_link | append: '|||'
    endif
    assign social_array = social_links | split: '|||'
  -%}
  {%- if social_array.size > 0 -%}
    ,"sameAs": [
      {%- assign sameAs_first = true -%}
      {%- for link in social_array -%}
        {%- unless link == blank -%}
          {%- unless sameAs_first -%},{%- endunless -%}
          {{ link | json }}
          {%- assign sameAs_first = false -%}
        {%- endunless -%}
      {%- endfor -%}
    ]
  {%- endif -%}
}
</script>

{%- comment -%} ===== LOCAL BUSINESS SCHEMA (only if address configured) ===== {%- endcomment -%}
{%- if settings.seo_local_street != blank and settings.seo_local_city != blank and settings.seo_local_postcode != blank -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "HardwareStore",
  "name": {{ org_name | json }},
  "url": {{ shop.url | json }}
  {%- if settings.logo -%}
    ,"image": {{ settings.logo | image_url: width: 600 | prepend: 'https:' | json }}
  {%- endif -%}
  {%- if settings.seo_org_telephone != blank -%}
    ,"telephone": {{ settings.seo_org_telephone | json }}
  {%- endif -%}
  ,"address": {
    "@type": "PostalAddress",
    "streetAddress": {{ settings.seo_local_street | json }},
    "addressLocality": {{ settings.seo_local_city | json }}
    {%- if settings.seo_local_region != blank -%}
      ,"addressRegion": {{ settings.seo_local_region | json }}
    {%- endif -%}
    ,"postalCode": {{ settings.seo_local_postcode | json }},
    "addressCountry": "GB"
  }
  {%- if settings.seo_local_hours != blank -%}
    ,"openingHours": {{ settings.seo_local_hours | json }}
  {%- endif -%}
  ,"priceRange": "££"
}
</script>
{%- endif -%}

{%- comment -%} ===== PRODUCT SCHEMA (product pages only) ===== {%- endcomment -%}
{%- if request.page_type == 'product' -%}
{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_image = product.featured_image | image_url: width: 1200 | prepend: 'https:'
  assign product_desc = product.description | strip_html | truncate: 5000 | escape

  comment
    Aggregate rating source detection — mirrors snippets/invicta-star-rating.liquid.
    Prefers Shopify's native reviews metafield, then Judge.me. Only emits schema
    when real reviews exist (count > 0) to avoid Google fake-rating penalties.
  endcomment
  assign agg_rating = 0
  assign agg_count = 0
  if product.metafields.reviews.rating.value.rating != blank and product.metafields.reviews.rating_count != blank
    assign agg_rating = product.metafields.reviews.rating.value.rating | times: 1.0
    assign agg_count = product.metafields.reviews.rating_count | times: 1
  elsif product.metafields.judgeme.average_rating != blank and product.metafields.judgeme.review_count != blank
    assign agg_rating = product.metafields.judgeme.average_rating | times: 1.0
    assign agg_count = product.metafields.judgeme.review_count | times: 1
  endif
-%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ product_desc | json }},
  "url": {{ shop.url | append: product.url | json }}
  {%- if product.featured_image -%}
    ,"image": {{ product_image | json }}
  {%- endif -%}
  {%- if current_variant.sku != blank -%}
    ,"sku": {{ current_variant.sku | json }}
  {%- endif -%}
  {%- if current_variant.barcode != blank -%}
    ,"mpn": {{ current_variant.barcode | json }}
  {%- elsif current_variant.sku != blank -%}
    ,"mpn": {{ current_variant.sku | json }}
  {%- endif -%}
  {%- if product.vendor != blank -%}
    {%- comment -%} 6c: Brand with sameAs URL lookup {%- endcomment -%}
    {%- liquid
      assign vendor_lower = product.vendor | downcase
      assign brand_same_as = ''
      if vendor_lower contains 'makita'
        assign brand_same_as = 'https://www.makita.co.uk/'
      elsif vendor_lower contains 'dewalt'
        assign brand_same_as = 'https://www.dewalt.co.uk/'
      elsif vendor_lower contains 'hikoki'
        assign brand_same_as = 'https://www.hikoki-powertools.co.uk/'
      elsif vendor_lower contains 'milwaukee'
        assign brand_same_as = 'https://www.milwaukeetool.co.uk/'
      elsif vendor_lower contains 'bosch'
        assign brand_same_as = 'https://www.bosch-professional.com/gb/en/'
      elsif vendor_lower contains 'stanley'
        assign brand_same_as = 'https://www.stanleytools.co.uk/'
      elsif vendor_lower contains 'irwin'
        assign brand_same_as = 'https://www.irwintools.co.uk/'
      elsif vendor_lower contains 'bahco'
        assign brand_same_as = 'https://www.bahco.com/'
      elsif vendor_lower contains 'trend'
        assign brand_same_as = 'https://www.trend-uk.com/'
      elsif vendor_lower contains 'faithfull'
        assign brand_same_as = 'https://www.faithfulltools.com/'
      endif
    -%}
    ,"brand": {
      "@type": "Brand",
      "name": {{ product.vendor | json }}
      {%- if brand_same_as != blank -%}
        ,"sameAs": {{ brand_same_as | json }}
      {%- endif -%}
    }
  {%- endif -%}
  {%- comment -%} 6a: PropertyValue specifications from metafields {%- endcomment -%}
  {%- liquid
    assign has_specs = false
    if product.metafields.custom.voltage != blank or product.metafields.custom.max_torque != blank or product.metafields.custom.motor_type != blank
      assign has_specs = true
    endif
  -%}
  {%- if has_specs -%}
    ,"additionalProperty": [
      {%- assign spec_comma = false -%}
      {%- if product.metafields.custom.voltage != blank -%}
        {%- if spec_comma -%},{%- endif -%}
        {
          "@type": "PropertyValue",
          "name": "Voltage",
          "value": {{ product.metafields.custom.voltage | json }}
          {%- assign voltage_str = product.metafields.custom.voltage | downcase -%}
          {%- if voltage_str contains 'v' -%}
            ,"unitCode": "VLT"
          {%- endif -%}
        }
        {%- assign spec_comma = true -%}
      {%- endif -%}
      {%- if product.metafields.custom.max_torque != blank -%}
        {%- if spec_comma -%},{%- endif -%}
        {
          "@type": "PropertyValue",
          "name": "Max Torque",
          "value": {{ product.metafields.custom.max_torque | json }}
          {%- assign torque_str = product.metafields.custom.max_torque | downcase -%}
          {%- if torque_str contains 'nm' or torque_str contains 'n.m' -%}
            ,"unitCode": "NU"
          {%- endif -%}
        }
        {%- assign spec_comma = true -%}
      {%- endif -%}
      {%- if product.metafields.custom.motor_type != blank -%}
        {%- if spec_comma -%},{%- endif -%}
        {
          "@type": "PropertyValue",
          "name": "Motor Type",
          "value": {{ product.metafields.custom.motor_type | json }}
        }
      {%- endif -%}
    ]
  {%- endif -%}
  ,"offers": {
    "@type": "Offer",
    "url": {{ shop.url | append: product.url | json }},
    "priceCurrency": "GBP",
    "price": {{ current_variant.price | money_without_currency | remove: ',' | json }},
    "priceValidUntil": "{{ 'now' | date: '%Y' | plus: 1 }}-12-31",
    "itemCondition": "https://schema.org/NewCondition"
    {%- if current_variant.available -%}
      ,"availability": "https://schema.org/InStock"
    {%- else -%}
      ,"availability": "https://schema.org/OutOfStock"
    {%- endif -%}
  }
  {%- if agg_rating > 0 and agg_count > 0 -%}
    ,"aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": {{ agg_rating | json }},
      "reviewCount": {{ agg_count | json }},
      "bestRating": 5,
      "worstRating": 1
    }
  {%- endif -%}
}
</script>

{%- comment -%} ===== 6b: FAQ SCHEMA from product description sections ===== {%- endcomment -%}
{%- liquid
  assign faq_desc = product.description
  assign faq_pairs = ''
  assign faq_count = 0

  comment
    Extract Key Features content — look for the heading marker
  endcomment
  assign kf_marker_lower = 'key features'
  assign desc_lower = faq_desc | downcase
  if desc_lower contains kf_marker_lower
    assign kf_split = faq_desc | split: 'Key Features'
    if kf_split.size > 1
      assign kf_raw = kf_split[1] | split: '<h' | first
      assign kf_clean = kf_raw | strip_html | strip | truncate: 2000
      if kf_clean != blank
        assign faq_count = faq_count | plus: 1
      endif
    endif
  endif

  comment
    Extract What's in the Box content
  endcomment
  assign witb_found = false
  assign witb_clean = ''
  if desc_lower contains 'in the box' or desc_lower contains "what's included" or desc_lower contains 'whats included'
    assign witb_markers = 'What,In the Box,Included' | split: ','
    for marker in witb_markers
      if faq_desc contains marker
        assign witb_split = faq_desc | split: marker
        if witb_split.size > 1
          assign witb_raw = witb_split.last | split: '<h' | first
          assign witb_test = witb_raw | strip_html | strip
          if witb_test != blank and witb_test.size > 5
            assign witb_clean = witb_test | truncate: 2000
            assign witb_found = true
            assign faq_count = faq_count | plus: 1
            break
          endif
        endif
      endif
    endfor
  endif
-%}
{%- if faq_count > 0 -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- assign faq_comma = false -%}
    {%- if kf_clean != blank -%}
      {%- if faq_comma -%},{%- endif -%}
      {
        "@type": "Question",
        "name": "What are the key features?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": {{ kf_clean | json }}
        }
      }
      {%- assign faq_comma = true -%}
    {%- endif -%}
    {%- if witb_found and witb_clean != blank -%}
      {%- if faq_comma -%},{%- endif -%}
      {
        "@type": "Question",
        "name": "What's in the box?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": {{ witb_clean | json }}
        }
      }
    {%- endif -%}
  ]
}
</script>
{%- endif -%}
{%- endif -%}

{%- comment -%} ===== BREADCRUMBLIST SCHEMA ===== {%- endcomment -%}
{%- if request.page_type == 'product' -%}
  {%- liquid
    assign bc_collection = nil
    assign current_path = request.path
    for col in product.collections
      assign col_path = col.url
      if current_path contains col_path
        assign bc_collection = col
        break
      endif
    endfor
    if bc_collection == nil
      assign bc_collection = product.collections | first
    endif
  -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": {{ shop.url | json }}
      }
      {%- if bc_collection -%}
      ,{
        "@type": "ListItem",
        "position": 2,
        "name": {{ bc_collection.title | json }},
        "item": {{ shop.url | append: bc_collection.url | json }}
      }
      ,{
        "@type": "ListItem",
        "position": 3,
        "name": {{ product.title | json }}
      }
      {%- else -%}
      ,{
        "@type": "ListItem",
        "position": 2,
        "name": {{ product.title | json }}
      }
      {%- endif -%}
    ]
  }
  </script>
{%- elsif request.page_type == 'collection' -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": {{ shop.url | json }}
      }
      ,{
        "@type": "ListItem",
        "position": 2,
        "name": {{ collection.title | json }}
      }
    ]
  }
  </script>
  {%- comment -%} ===== COLLECTION PAGE SCHEMA (ItemList of products) ===== {%- endcomment -%}
  {%- if collection.products.size > 0 -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": {{ collection.title | json }},
    "url": {{ shop.url | append: collection.url | json }}
    {%- if collection.description != blank -%}
      ,"description": {{ collection.description | strip_html | truncate: 5000 | json }}
    {%- endif -%}
    ,"mainEntity": {
      "@type": "ItemList",
      "numberOfItems": {{ collection.products.size }},
      "itemListElement": [
        {%- for product in collection.products limit: 24 -%}
          {
            "@type": "ListItem",
            "position": {{ forloop.index }},
            "item": {{ shop.url | append: product.url | json }},
            "name": {{ product.title | json }}
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    }
  }
  </script>
  {%- endif -%}
{%- elsif request.page_type == 'article' -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": {{ shop.url | json }}
      }
      ,{
        "@type": "ListItem",
        "position": 2,
        "name": {{ blog.title | json }},
        "item": {{ shop.url | append: blog.url | json }}
      }
      ,{
        "@type": "ListItem",
        "position": 3,
        "name": {{ article.title | json }}
      }
    ]
  }
  </script>
{%- elsif request.page_type == 'blog' -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": {{ shop.url | json }}
      }
      ,{
        "@type": "ListItem",
        "position": 2,
        "name": {{ blog.title | json }}
      }
    ]
  }
  </script>
{%- endif -%}
