{% comment %}
  Cart Breakdown Snippet
  ======================
  Displays a detailed breakdown of cart costs:
  - Subtotal (ex VAT)
  - VAT amount
  - Discounts applied
  - Shipping estimate (FREE highlight when qualified)
  - Savings callout (when free shipping qualifies)
  - Total

  Usage: {% render 'cart-breakdown', cart: cart %}
{% endcomment %}

{%- liquid
  assign inv_vat_rate = settings.inv_vat_rate | default: 20
  assign inv_vat_divisor = 100 | plus: inv_vat_rate
  assign inv_vat_rounding = inv_vat_divisor | divided_by: 2
  assign subtotal_inc_vat = cart.total_price
  assign subtotal_ex_vat = subtotal_inc_vat | times: 100 | plus: inv_vat_rounding | divided_by: inv_vat_divisor
  assign vat_amount = subtotal_inc_vat | minus: subtotal_ex_vat

  assign has_discounts = false
  if cart.total_discount > 0
    assign has_discounts = true
  endif

  assign free_shipping_threshold = settings.inv_free_shipping_pence | plus: 0
  assign shipping_remaining = free_shipping_threshold | minus: cart.total_price
  assign standard_shipping_pence = settings.inv_standard_shipping_pence | default: 499
  assign qualifies_for_free = false
  if cart.total_price >= free_shipping_threshold
    assign qualifies_for_free = true
  endif
-%}

<div class="invicta-cart-breakdown" data-cart-breakdown>

  <div class="invicta-vat-indicator" data-vat-indicator>
    {{ 'invicta.cart.prices_include_vat' | t }}
  </div>

  <div class="invicta-cart-breakdown__row invicta-cart-breakdown__row--subtotal">
    <span class="invicta-cart-breakdown__label">{{ 'invicta.cart.subtotal_ex_vat' | t }}</span>
    <span class="invicta-cart-breakdown__value" data-breakdown-subtotal-ex>
      {{ subtotal_ex_vat | money }}
    </span>
  </div>

  <div class="invicta-cart-breakdown__row invicta-cart-breakdown__row--vat">
    <span class="invicta-cart-breakdown__label">{{ 'invicta.cart.vat_rate' | t: rate: settings.inv_vat_rate }}</span>
    <span class="invicta-cart-breakdown__value" data-breakdown-vat>
      {{ vat_amount | money }}
    </span>
  </div>

  {%- if has_discounts -%}
    {%- for discount in cart.cart_level_discount_applications -%}
      <div class="invicta-cart-breakdown__row invicta-cart-breakdown__row--discount">
        <span class="invicta-cart-breakdown__label">
          {{ 'invicta.cart.discount' | t }}
          <small>({{ discount.title }})</small>
        </span>
        <span class="invicta-cart-breakdown__value invicta-cart-breakdown__value--negative" data-breakdown-discount>
          -{{ discount.total_allocated_amount | money }}
        </span>
      </div>
    {%- endfor -%}
  {%- endif -%}

  <div class="invicta-cart-breakdown__row invicta-cart-breakdown__row--shipping">
    <span class="invicta-cart-breakdown__label">{{ 'invicta.cart.shipping' | t }}</span>
    <span class="invicta-cart-breakdown__value" data-breakdown-shipping>
      {%- if qualifies_for_free -%}
        <span class="invicta-cart-breakdown__free-label">{{ 'invicta.cart.shipping_free' | t }}</span>
      {%- else -%}
        {{ 'invicta.cart.shipping_calculated' | t }}
      {%- endif -%}
    </span>
  </div>

  {%- if qualifies_for_free -%}
    <div class="inv-cart-summary__savings" role="status">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" focusable="false" aria-hidden="true"><path d="M1 3h15v13H1z"/><path d="M16 8h4l3 4v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
      <span>You're saving <strong>{{ standard_shipping_pence | money }}</strong> on delivery</span>
    </div>
  {%- else -%}
    {%- if cart.total_price > 0 -%}
      {%- assign shipping_remaining_formatted = shipping_remaining | money -%}
      <div class="invicta-cart-breakdown__shipping-progress">
        <div class="invicta-cart-breakdown__shipping-text">
          {{ 'invicta.cart.shipping_progress_html' | t: amount: shipping_remaining_formatted }}
        </div>
        <div class="invicta-cart-breakdown__shipping-bar">
          {%- assign progress_percent = cart.total_price | times: 100 | divided_by: free_shipping_threshold -%}
          <div class="invicta-cart-breakdown__shipping-fill" style="width: {{ progress_percent }}%;"></div>
        </div>
      </div>
    {%- endif -%}
  {%- endif -%}

  <div class="invicta-cart-breakdown__row invicta-cart-breakdown__row--total">
    <span class="invicta-cart-breakdown__label">Total</span>
    <span class="invicta-cart-breakdown__value invicta-cart-breakdown__value--stacked" data-breakdown-total>
      <span class="invicta-cart-breakdown__total-inc">
        {{ cart.total_price | money }}<small class="invicta-cart-breakdown__total-suffix"> inc VAT</small>
      </span>
      <span class="invicta-cart-breakdown__total-ex">
        {{ subtotal_ex_vat | money }}<small class="invicta-cart-breakdown__total-suffix"> ex VAT</small>
      </span>
    </span>
  </div>

</div>
{%- comment -%} Styles merged into invicta-cart.css, which is loaded by every cart context that renders this snippet. {%- endcomment -%}
