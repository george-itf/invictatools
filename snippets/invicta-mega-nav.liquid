{% comment %}
  Invicta Mega Nav — Desktop category navigation bar.
  Renders from the same link_list as the mobile drawer.
  Hidden on mobile (CSS handles visibility).
{% endcomment %}

{%- assign mega_menu = section.settings.menu | default: 'main-menu' -%}
{%- assign mega_links = linklists[mega_menu].links -%}

{%- if mega_links.size > 0 -%}
  {{ 'invicta-mega-nav.css' | asset_url | stylesheet_tag }}

  <nav class="inv-mega-nav" aria-label="Main categories">
    <ul class="inv-mega-nav__list" role="list">
      {%- for link in mega_links -%}
        {%- assign has_children = false -%}
        {%- if link.links.size > 0 -%}
          {%- assign has_children = true -%}
        {%- endif -%}

        <li class="inv-mega-nav__item"
          {%- if has_children %} data-has-children{% endif -%}
        >
          <a
            href="{{ link.url }}"
            class="inv-mega-nav__link"
            {% if link.current %}aria-current="page"{% endif %}
            {%- if has_children %}
              aria-expanded="false"
              aria-haspopup="true"
            {% endif -%}
          >
            {{ link.title | escape }}
            {%- if has_children -%}
              <svg class="inv-mega-nav__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" focusable="false" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            {%- endif -%}
          </a>

          {%- if has_children -%}
            <div class="inv-mega-nav__panel" role="menu">
              <ul class="inv-mega-nav__sublist" role="list">
                {%- for childlink in link.links -%}
                  <li role="none">
                    <a
                      href="{{ childlink.url }}"
                      class="inv-mega-nav__sublink"
                      role="menuitem"
                      {% if childlink.current %}aria-current="page"{% endif %}
                    >
                      {{ childlink.title | escape }}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
              <a href="{{ link.url }}" class="inv-mega-nav__view-all" role="menuitem">
                View All {{ link.title | escape }}
              </a>
            </div>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>
  </nav>

  <script src="{{ 'invicta-mega-nav.js' | asset_url }}" defer></script>
{%- endif -%}
