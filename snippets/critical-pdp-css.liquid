{%- comment -%}
  Critical above-fold CSS for Product V2 — inlined to eliminate render-blocking.
  Full styles loaded async via media="print" onload pattern.
{%- endcomment -%}
<style>
/* Base container */
.inv-pdp{max-width:var(--inv-container,1400px);margin:0 auto;padding:0 var(--inv-space-lg) 60px;font-family:inherit;color:var(--inv-fg-near-black);line-height:1.6;box-sizing:border-box}
.inv-pdp *,.inv-pdp *::before,.inv-pdp *::after{box-sizing:border-box}
/* Breadcrumb */
.inv-pdp__breadcrumb-bar{display:flex;align-items:center;padding:var(--inv-space-sm-plus) 0;border-bottom:1px solid var(--inv-grey-200);margin-bottom:var(--inv-space-xl);gap:var(--inv-space-sm-plus)}
.inv-pdp__breadcrumb{font-size:13px;color:var(--inv-grey-500)}
.inv-pdp__breadcrumb ol{display:flex;align-items:center;list-style:none;margin:0;padding:0;flex-wrap:wrap}
.inv-pdp__breadcrumb a{color:var(--inv-grey-500);text-decoration:none}
.inv-pdp__breadcrumb-sep{margin:0 8px;color:var(--inv-grey-300)}
.inv-pdp__breadcrumb-current{color:var(--inv-fg-near-black);font-weight:500}
.inv-pdp__sku{font-size:11px;color:var(--inv-grey-400);margin-left:auto;flex-shrink:0}
/* Grid */
.inv-pdp__grid{display:grid;grid-template-columns:1fr 460px;gap:var(--inv-space-2xl);align-items:start}
@media(max-width:1200px){.inv-pdp__grid{grid-template-columns:1fr 400px;gap:var(--inv-space-xl)}}
.inv-pdp__left{display:flex;flex-direction:column;gap:var(--inv-space-lg)}
/* Gallery */
.inv-pdp__gallery{display:flex;gap:var(--inv-space-md)}
.inv-pdp__gallery--single .inv-pdp__gallery-thumbs{display:none}
.inv-pdp__gallery-thumbs{display:flex;flex-direction:column;gap:var(--inv-space-sm);flex-shrink:0;max-height:560px;overflow-y:auto;overflow-x:hidden}
.inv-pdp__gallery-thumb{width:72px;height:72px;border:2px solid var(--inv-grey-200);background:var(--inv-bg-elevated);cursor:pointer;padding:4px;box-sizing:border-box;overflow:hidden;flex-shrink:0}
.inv-pdp__gallery-thumb--active{border-color:var(--inv-accent)}
.inv-pdp__gallery-thumb img{display:block;width:100%;height:100%;object-fit:contain}
.inv-pdp__gallery-main{flex:1;min-width:0;height:560px;background:var(--inv-bg-elevated);border:1px solid var(--inv-grey-200);position:relative;display:flex;align-items:center;justify-content:center;overflow:hidden}
.inv-pdp__gallery-image-wrap{display:flex;align-items:center;justify-content:center;width:100%;height:100%;padding:16px;box-sizing:border-box}
.inv-pdp__gallery-image{display:block;max-width:100%;max-height:100%;width:auto;height:auto;object-fit:contain}
.inv-pdp__gallery-badge{position:absolute;top:12px;left:12px;background:var(--inv-accent);color:var(--inv-bg-elevated);padding:6px 12px;font-size:11px;font-weight:700;z-index:2}
/* Buy box */
.inv-pdp__right{position:sticky;top:20px;height:fit-content}
.inv-pdp__buybox{background:var(--inv-bg-elevated);border:2px solid var(--inv-grey-200);overflow:hidden}
.inv-pdp__buybox-body{padding:var(--inv-space-lg);display:flex;flex-direction:column;gap:20px}
/* Stock banner */
.inv-pdp__stock-banner{padding:12px 16px;font-size:14px;font-weight:600;display:flex;align-items:flex-start;gap:10px}
.inv-pdp__stock-banner-content{display:flex;flex-direction:column;gap:4px;min-width:0}
.inv-pdp__stock-banner--in-stock{background:var(--inv-success-light);color:var(--inv-success-dark);border-bottom:2px solid var(--inv-success)}
.inv-pdp__stock-banner--out-of-stock{background:var(--inv-error-bg);color:var(--inv-error-dark);border-bottom:2px solid var(--inv-error-border)}
.inv-pdp__stock-dot{width:10px;height:10px;background:currentColor;border-radius:50%;flex-shrink:0;margin-top:4px}
/* Title */
.inv-pdp__title{font-size:clamp(18px,3.5vw,24px);font-weight:700;line-height:1.2;margin:0;color:var(--inv-fg-near-black);letter-spacing:-0.025em}
/* Price */
.inv-pdp__price{padding:16px 0 var(--inv-space-md);border-top:1px solid var(--inv-grey-200);border-bottom:1px solid var(--inv-grey-200)}
.inv-pdp__price-inline{display:flex;flex-direction:column;gap:4px}
.inv-pdp__price-line{display:flex;align-items:baseline;gap:6px;flex-wrap:wrap}
.inv-pdp__price-current{font-size:clamp(26px,5vw,32px);font-weight:700;color:var(--inv-fg-near-black);line-height:1;letter-spacing:-0.02em}
.inv-pdp__price-label{font-size:14px;font-weight:600;color:var(--inv-grey-500);margin-right:6px}
/* ATC */
.inv-pdp__atc-row{display:flex;gap:var(--inv-space-sm-plus);align-items:stretch}
.inv-pdp .inv-pdp__buybox .inv-pdp__atc-btn{flex:1 1 auto;min-height:52px;border:none;cursor:pointer;font-size:16px;font-weight:700;background:var(--inv-accent);color:#fff;display:flex;align-items:center;justify-content:center;position:relative}
/* Trust strip */
/* Trust strip removed */
/* Utilities */
.inv-vat--hidden{display:none!important}
.inv-pdp--hidden{display:none}
/* Mobile critical */
@media(max-width:749px){
.inv-pdp__grid{display:flex;flex-direction:column;gap:0}
.inv-pdp{padding:0 0 130px 0;margin:0}
.inv-pdp__right{position:static}
.inv-pdp__gallery{flex-direction:column}
.inv-pdp__gallery-thumbs{flex-direction:row;max-height:none;overflow-x:auto}
.inv-pdp__gallery-main{height:auto;aspect-ratio:1/1;max-height:400px}
.inv-pdp__gallery-thumb{width:56px;height:56px}
.inv-pdp__title{font-size:18px}
.inv-pdp__price-current{font-size:24px}
.inv-pdp__trust-strip{grid-template-columns:1fr}
}
</style>
