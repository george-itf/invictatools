{%- comment -%}
  Reusable checkbox filter group for search page.
  Renders brand or product type filter with accordion, search input, and checkbox list.

  Parameters:
    filter_name       - Shopify filter param name (e.g. "filter.p.vendor", "filter.p.product_type")
    group_id          - Unique ID suffix for the group (e.g. "brand", "type", "brand-mobile")
    title_key         - Translation key for the group title
    search_key        - Translation key for the search placeholder
    active_values     - Array of filter_value objects with active: true, pre-sorted by count desc
    inactive_values   - Array of filter_value objects with active: false, pre-sorted by count desc
    default_open      - Whether accordion starts expanded
{%- endcomment -%}

<div class="inv-filter-group" data-filter-group-id="{{ group_id }}">
  <button
    type="button"
    class="inv-filter-group__header"
    data-accordion-toggle
    aria-expanded="{% if default_open %}true{% else %}false{% endif %}"
    aria-controls="inv-filter-body-{{ group_id }}"
  >
    <span class="inv-filter-group__title">{{ title_key | t }}</span>
    <svg class="inv-filter-group__chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" focusable="false" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
  </button>
  <div
    class="inv-filter-group__body"
    id="inv-filter-body-{{ group_id }}"
    aria-hidden="{% if default_open %}false{% else %}true{% endif %}"
  >
    <div class="inv-filter-group__search">
      <input
        type="text"
        class="inv-filter-group__search-input"
        data-filter-search
        placeholder="{{ search_key | t }}"
        aria-label="{{ search_key | t }}"
      >
    </div>
    <div class="inv-filter-group__list">
      {%- for value in active_values -%}
        {%- if value.count > 0 -%}
          <label class="inv-filter-checkbox">
            <input type="checkbox" name="{{ filter_name }}" value="{{ value.label | escape }}" checked>
            <span class="inv-filter-checkbox__check"></span>
            <span class="inv-filter-checkbox__label">{{ value.label }}</span>
            <span class="inv-filter-checkbox__count">({{ value.count }})</span>
          </label>
        {%- endif -%}
      {%- endfor -%}
      {%- for value in inactive_values -%}
        {%- if value.count > 0 -%}
          <label class="inv-filter-checkbox">
            <input type="checkbox" name="{{ filter_name }}" value="{{ value.label | escape }}">
            <span class="inv-filter-checkbox__check"></span>
            <span class="inv-filter-checkbox__label">{{ value.label }}</span>
            <span class="inv-filter-checkbox__count">({{ value.count }})</span>
          </label>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>
